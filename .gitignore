# Dependencies
node_modules/
**/node_modules/
.venv/
**/.venv/
*.egg-info/
**/*.egg-info/

# Build outputs
**/dist/
**/.astro/
**/.cache/
**/coverage/
**/.pytest_cache/
**/.ruff_cache/

# Python caches
**/__pycache__/
*.pyc

# Environment files
# Convention:
#   apps/api/.env.api               local runtime (uvicorn / pytest / docker compose)
#   apps/web/.env.web               local runtime (npm run dev / docker compose)
#   apps/api/.env.api.example, apps/web/.env.web.example
#                                   committed templates (the only env files under version control)
#   apps/api/.env.api.jenkins, apps/web/.env.web.jenkins
#                                   local copy of the Jenkins credential payload (gitignored)
.env
.env.*
!.env.example
!.env.*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.worktrees/

# AI Workloads
.claude/

# Local scratch / safety-net files
.local/
