---
import type { CollectionEntry } from "astro:content";

import CoverMediaImage from "../components/CoverMediaImage.astro";
import PostAdminActions from "../components/public/PostAdminActions";
import BaseLayout from "./BaseLayout.astro";
import { formatDateLabel, toIsoDateTime } from "../lib/format-date";
import {
  buildImageFallbackOnError,
  getCoverMediaMetadata,
  normalizeCoverMedia,
  toBrowserImageUrl,
  type CoverMediaSource,
} from "../lib/cover-media";

type MarkdownPostData = CollectionEntry<"blog">["data"];

interface DbPostData {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  coverImage?: CoverMediaSource;
}

interface SeriesContext {
  seriesSlug: string;
  seriesTitle: string;
  orderIndex: number;
  totalPosts: number;
  prevPostSlug: string | null;
  prevPostTitle: string | null;
  nextPostSlug: string | null;
  nextPostTitle: string | null;
}

interface SeriesPostItem {
  slug: string;
  title: string;
  excerpt?: string;
  coverImageUrl?: string;
  relation: "prev" | "next";
}

interface BlogPostAdminProps {
  postSlug?: string;
  adminPostSlug?: string;
  showAdminActions?: boolean;
  seriesContext?: SeriesContext;
  seriesPosts?: SeriesPostItem[];
}

type Props = (MarkdownPostData | DbPostData) & BlogPostAdminProps;

const {
  title,
  description,
  pubDate,
  updatedDate,
  coverImage,
  adminPostSlug = "",
  showAdminActions = false,
  seriesContext,
  seriesPosts = [],
} = Astro.props;
const shouldRenderAdminActions = Boolean(showAdminActions && adminPostSlug);
const detailCoverWidth = 1400;
const detailCoverHeight = 1000;
const defaultSeriesPostCoverImage = "/images/empty-series-image.png";
const defaultSeriesPostCoverImageSrc = toBrowserImageUrl(defaultSeriesPostCoverImage, {
  width: 224,
  height: 126,
  fit: "cover",
});
const coverImageFallbackSrc = toBrowserImageUrl("/images/empty-article-image.png", {
  width: detailCoverWidth,
  height: detailCoverHeight,
  fit: "inside",
});
const hasSeriesSidebar = Boolean(seriesContext && seriesPosts.length > 0);
const coverMedia = normalizeCoverMedia(coverImage);
const pubDateLabel = formatDateLabel(pubDate);
const pubDateIso = toIsoDateTime(pubDate);
const updatedDateLabel = updatedDate ? formatDateLabel(updatedDate) : "";
const updatedDateIso = updatedDate ? toIsoDateTime(updatedDate) : "";
const seriesPostCoverImageFallbackOnError = buildImageFallbackOnError(defaultSeriesPostCoverImageSrc);
---

<BaseLayout
  title={title}
  description={description}
  image={getCoverMediaMetadata(coverMedia)}
  bodyClass="page-blog-post"
>
  <div
    class:list={[
      "mx-auto grid w-full gap-8",
      hasSeriesSidebar
        ? "max-w-6xl xl:grid-cols-[minmax(0,3fr)_minmax(336px,1.08fr)]"
        : "max-w-3xl",
    ]}
  >
    <article class="min-w-0">
      <nav
        class="flex flex-wrap items-center justify-between gap-3"
        aria-label="Post navigation"
      >
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          href="/blog/"
        >
          <span aria-hidden="true">‹</span>
          <span>블로그로 돌아가기</span>
        </a>
        {
          shouldRenderAdminActions && (
            <PostAdminActions client:load adminPostSlug={adminPostSlug} />
          )
        }
      </nav>

      {
        coverMedia && (
          <CoverMediaImage
            className="mt-8 h-auto w-full rounded-3xl shadow-[0_30px_80px_rgba(15,23,42,0.12)]"
            media={coverMedia}
            alt={title}
            width={detailCoverWidth}
            height={detailCoverHeight}
            fallbackSrc={coverImageFallbackSrc}
            fit="inside"
          />
        )
      }

      <header class="mt-8 space-y-4">
        <p
          class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
        >
          <time datetime={pubDateIso}>{pubDateLabel}</time>
          {
            updatedDate && (
              <>
                <span aria-hidden="true">/</span>
                <span>
                  updated{" "}
                  <time datetime={updatedDateIso}>{updatedDateLabel}</time>
                </span>
              </>
            )
          }
        </p>
        <h1
          class="text-balance text-4xl font-semibold tracking-tight sm:text-5xl"
        >
          {title}
        </h1>
        <p class="max-w-2xl text-lg text-muted-foreground">{description}</p>
      </header>

      <section
        class="mt-10 text-base leading-8 text-foreground/90 [&_blockquote]:mb-5 [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:text-muted-foreground [&_figcaption]:mt-2 [&_figcaption]:text-center [&_figcaption]:text-sm [&_figcaption]:text-muted-foreground [&_figure]:mb-5 [&_figure>img]:block [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h4]:mt-6 [&_h4]:mb-3 [&_h4]:text-lg [&_h4]:font-semibold [&_img]:max-w-full [&_img]:rounded-2xl [&_img]:border [&_img]:border-border/60 [&_li]:leading-8 [&_ol]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-5 [&_pre]:overflow-x-auto [&_pre]:rounded-[1.75rem] [&_pre]:border [&_pre]:border-slate-900/70 [&_pre]:bg-[#07142b] [&_pre]:px-6 [&_pre]:py-5 [&_pre]:shadow-[0_24px_64px_rgba(2,6,23,0.2)] [&_pre_code]:bg-transparent [&_ul]:mb-5 [&_ul]:list-disc [&_ul]:pl-6 [&_video]:mb-5 [&_video]:block [&_video]:max-w-full [&_video]:rounded-2xl [&_video]:border [&_video]:border-border/60"
      >
        <slot />
      </section>

      <nav class="mt-12 flex justify-center" aria-label="Blog archive">
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          href="/blog/"
        >
          <span aria-hidden="true">☰</span>
          <span>모든 글 보기</span>
        </a>
      </nav>
    </article>

    {
      hasSeriesSidebar && seriesContext && (
        <aside
          class="xl:sticky xl:top-24 xl:self-start"
          aria-label="시리즈 탐색"
        >
          <section class="rounded-3xl border border-white/80 bg-white/96 p-5 shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
            <div class="space-y-1">
              <a
                class="block font-medium text-foreground transition-colors hover:text-primary"
                href={`/series/${seriesContext.seriesSlug}`}
              >
                {seriesContext.seriesTitle}
              </a>
              <p class="text-sm text-muted-foreground">
                {seriesContext.totalPosts}개 글 중 {seriesContext.orderIndex}번째
              </p>
            </div>
            <ol class="mt-4 grid gap-3">
              {seriesPosts.map((seriesPost) => {
                const previewText = (seriesPost.excerpt ?? "").trim();
                const relationLabel =
                  seriesPost.relation === "prev" ? "이전 글" : "다음 글";
                const resolvedSeriesPostCoverImageSrc = seriesPost.coverImageUrl
                  ? toBrowserImageUrl(seriesPost.coverImageUrl, {
                      width: 224,
                      height: 126,
                    })
                  : defaultSeriesPostCoverImageSrc;

                return (
                  <li>
                    <a
                      class="group grid grid-cols-[124px_minmax(0,1fr)] items-center gap-4 rounded-2xl border border-white/80 bg-white/92 p-3.5 shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition duration-200 hover:-translate-y-0.5 hover:border-sky-200/70 hover:bg-white"
                      href={`/blog/${seriesPost.slug}`}
                    >
                      <img
                        class="aspect-[16/9] w-full rounded-xl border border-white/70 bg-slate-100 object-cover object-center"
                        src={resolvedSeriesPostCoverImageSrc}
                        alt={seriesPost.title}
                        decoding="async"
                        loading="lazy"
                        onerror={seriesPostCoverImageFallbackOnError}
                      />
                      <span class="grid min-w-0 content-center gap-1.5">
                        <small class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">
                          {relationLabel}
                        </small>
                        <strong class="text-sm font-semibold leading-6 text-foreground">
                          {seriesPost.title}
                        </strong>
                        <em class="line-clamp-2 text-sm not-italic text-muted-foreground">
                          {previewText.length > 0 ? previewText : "요약 없음"}
                        </em>
                      </span>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        </aside>
      )
    }
  </div>
</BaseLayout>
