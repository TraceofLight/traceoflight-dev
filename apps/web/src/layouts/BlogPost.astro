---
import type { CollectionEntry } from "astro:content";

import CoverMediaImage from "../components/CoverMediaImage.astro";
import PostAdminActions from "../components/public/PostAdminActions";
import PostComments from "../components/public/PostComments";
import { SITE_AUTHOR, SITE_URL } from "../consts";
import BaseLayout from "./BaseLayout.astro";
import { formatDateLabel, toIsoDateTime } from "../lib/format-date";
import {
  buildImageFallbackOnError,
  getCoverMediaMetadata,
  normalizeCoverMedia,
  toBrowserImageUrl,
  type CoverMediaSource,
} from "../lib/cover-media";
import { toYoutubeEmbedUrl } from "../lib/youtube";
import {
  PUBLIC_PANEL_SURFACE_CLASS,
  PUBLIC_PANEL_SURFACE_SOFT_CLASS,
  PUBLIC_SURFACE_ACTION_CLASS,
} from "../lib/ui-effects";
import type { PostCommentThreadList } from "../lib/post-comments";

type MarkdownPostData = CollectionEntry<"blog">["data"];

interface DbPostData {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  coverImage?: CoverMediaSource;
  topMediaKind?: "image" | "youtube" | "video";
  topMediaImageUrl?: string;
  topMediaYoutubeUrl?: string;
  topMediaVideoUrl?: string;
}

interface SeriesContext {
  seriesSlug: string;
  seriesTitle: string;
  orderIndex: number;
  totalPosts: number;
  prevPostSlug: string | null;
  prevPostTitle: string | null;
  nextPostSlug: string | null;
  nextPostTitle: string | null;
}

interface SeriesPostItem {
  slug: string;
  title: string;
  excerpt?: string;
  coverImageUrl?: string;
  relation: "prev" | "next";
}

interface BlogPostAdminProps {
  postSlug?: string;
  adminPostSlug?: string;
  showAdminActions?: boolean;
  isAdminViewer?: boolean;
  seriesContext?: SeriesContext;
  seriesPosts?: SeriesPostItem[];
  commentsData?: PostCommentThreadList;
}

type Props = (MarkdownPostData | DbPostData) & BlogPostAdminProps;

const {
  title,
  description,
  pubDate,
  updatedDate,
  coverImage,
  topMediaKind = "image",
  topMediaImageUrl,
  topMediaYoutubeUrl,
  topMediaVideoUrl,
  postSlug = "",
  adminPostSlug = "",
  showAdminActions = false,
  isAdminViewer = false,
  seriesContext,
  seriesPosts = [],
  commentsData = { comment_count: 0, items: [] },
} = Astro.props;
const shouldRenderAdminActions = Boolean(showAdminActions && adminPostSlug);
const detailCoverWidth = 1400;
const detailCoverHeight = 1000;
const defaultSeriesPostCoverImage = "/images/empty-series-image.png";
const defaultSeriesPostCoverImageSrc = toBrowserImageUrl(defaultSeriesPostCoverImage, {
  width: 224,
  height: 126,
  fit: "cover",
});
const coverImageFallbackSrc = toBrowserImageUrl("/images/empty-article-image.png", {
  width: detailCoverWidth,
  height: detailCoverHeight,
  fit: "inside",
});
const hasSeriesSidebar = Boolean(seriesContext && seriesPosts.length > 0);
const coverMedia = normalizeCoverMedia(coverImage);
const pubDateLabel = formatDateLabel(pubDate);
const pubDateIso = toIsoDateTime(pubDate);
const seriesPostCoverImageFallbackOnError = buildImageFallbackOnError(defaultSeriesPostCoverImageSrc);
const topMediaEmbedUrl =
  topMediaKind === "youtube" ? toYoutubeEmbedUrl(topMediaYoutubeUrl) : null;
const topMediaImage = normalizeCoverMedia(topMediaImageUrl ?? coverImage);
const seoImageMetadata =
  topMediaImage?.kind === "optimized"
    ? topMediaImage.src
    : getCoverMediaMetadata(coverMedia);
const seoImageUrl =
  topMediaImage?.kind === "native"
    ? topMediaImage.src
    : coverMedia?.kind === "native"
      ? coverMedia.src
      : undefined;
const canonicalPostUrl = postSlug
  ? new URL(`/blog/${postSlug}`, SITE_URL).toString()
  : undefined;
const articleStructuredData = postSlug
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      url: canonicalPostUrl,
      mainEntityOfPage: canonicalPostUrl,
      inLanguage: "ko-KR",
      datePublished: pubDate.toISOString(),
      ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
      author: [
        {
          "@type": "Person",
          name: SITE_AUTHOR,
          url: SITE_URL,
        },
      ],
      publisher: {
        "@type": "Person",
        name: SITE_AUTHOR,
        url: SITE_URL,
      },
      ...((seoImageUrl || seoImageMetadata?.src)
        ? {
            image: [
              new URL(seoImageUrl ?? seoImageMetadata!.src, SITE_URL).toString(),
            ],
          }
        : {}),
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: new URL("/", SITE_URL).toString(),
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Blog",
            item: new URL("/blog", SITE_URL).toString(),
          },
          {
            "@type": "ListItem",
            position: 3,
            name: title,
            item: canonicalPostUrl,
          },
        ],
      },
    }
  : undefined;
---

<BaseLayout
  title={title}
  description={description}
  image={seoImageMetadata}
  imageUrl={seoImageUrl}
  bodyClass="page-blog-post"
  pageType="article"
  author={SITE_AUTHOR}
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  structuredData={articleStructuredData}
>
  <div
    class:list={[
      "mx-auto grid w-full gap-8",
      hasSeriesSidebar
        ? "max-w-[1320px] xl:grid-cols-[minmax(0,3.7fr)_minmax(320px,0.9fr)]"
        : "max-w-3xl",
    ]}
  >
    <article class="min-w-0">
      <nav
        class="flex flex-wrap items-center justify-between gap-3"
        aria-label="Post navigation"
      >
        <a
          class={PUBLIC_SURFACE_ACTION_CLASS}
          href="/blog/"
        >
          <span aria-hidden="true">‹</span>
          <span>블로그로 돌아가기</span>
        </a>
        {
          shouldRenderAdminActions && (
            <PostAdminActions client:load adminPostSlug={adminPostSlug} />
          )
        }
      </nav>

      {
        topMediaKind === "video" && topMediaVideoUrl ? (
          <video
            class="mt-8 aspect-[16/9] h-auto w-full rounded-3xl object-cover shadow-[0_30px_80px_rgba(15,23,42,0.12)]"
            controls
            preload="metadata"
            src={topMediaVideoUrl}
          >
          </video>
        ) : topMediaEmbedUrl ? (
          <div class="mt-8 overflow-hidden rounded-3xl shadow-[0_30px_80px_rgba(15,23,42,0.12)]">
            <iframe
              class="aspect-[16/9] h-full w-full"
              src={topMediaEmbedUrl}
              title={title}
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            />
          </div>
        ) : topMediaImage && (
          <CoverMediaImage
            className="mt-8 h-auto w-full rounded-3xl shadow-[0_30px_80px_rgba(15,23,42,0.12)]"
            media={topMediaImage}
            alt={title}
            width={detailCoverWidth}
            height={detailCoverHeight}
            fallbackSrc={coverImageFallbackSrc}
            fit="inside"
          />
        )
      }

      <header class="mt-8 space-y-4">
        <p
          class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
        >
          <time datetime={pubDateIso}>{pubDateLabel}</time>
        </p>
        <h1
          class="text-balance text-4xl font-semibold tracking-tight sm:text-5xl"
        >
          {title}
        </h1>
        <p class="max-w-2xl text-lg text-muted-foreground">{description}</p>
      </header>

      <section
        class="markdown-prose mt-10 text-base leading-8 text-foreground/90 [&_.md-video-embed]:relative [&_.md-video-embed]:mb-5 [&_.md-video-embed]:aspect-video [&_.md-video-embed]:overflow-hidden [&_.md-video-embed]:rounded-[1.75rem] [&_.md-video-embed]:border [&_.md-video-embed]:border-border/60 [&_.md-video-embed]:bg-slate-950 [&_.md-video-embed]:shadow-[0_24px_64px_rgba(2,6,23,0.16)] [&_blockquote]:mb-5 [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:text-muted-foreground [&_figcaption]:mt-2 [&_figcaption]:text-center [&_figcaption]:text-sm [&_figcaption]:text-muted-foreground [&_figure]:mb-5 [&_figure>img]:block [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h4]:mt-6 [&_h4]:mb-3 [&_h4]:text-lg [&_h4]:font-semibold [&_iframe]:h-full [&_iframe]:w-full [&_iframe]:border-0 [&_img]:max-w-full [&_img]:rounded-2xl [&_img]:border [&_img]:border-border/60 [&_li]:leading-8 [&_ol]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-5 [&_ul]:mb-5 [&_ul]:list-disc [&_ul]:pl-6 [&_video]:mb-5 [&_video]:block [&_video]:max-w-full [&_video]:rounded-2xl [&_video]:border [&_video]:border-border/60"
      >
        <slot />
      </section>

      <nav class="mt-12 flex justify-center" aria-label="Blog archive">
        <a
          class={PUBLIC_SURFACE_ACTION_CLASS}
          href="/blog/"
        >
          <span aria-hidden="true">☰</span>
          <span>모든 글 보기</span>
        </a>
      </nav>

      {
        postSlug && (
          <section class="mt-10">
            <PostComments
              client:load
              initialComments={commentsData}
              isAdminViewer={isAdminViewer}
              postSlug={postSlug}
            />
          </section>
        )
      }
    </article>

    {
      hasSeriesSidebar && seriesContext && (
        <aside
          class="xl:sticky xl:top-24 xl:self-start"
          aria-label="시리즈 탐색"
        >
          <section class={`rounded-3xl bg-white/96 p-5 ${PUBLIC_PANEL_SURFACE_CLASS}`}>
            <div class="space-y-1">
              <a
                class="block font-medium text-foreground transition-colors hover:text-primary"
                href={`/series/${seriesContext.seriesSlug}`}
              >
                {seriesContext.seriesTitle}
              </a>
              <p class="text-sm text-muted-foreground">
                {seriesContext.totalPosts}개 글 중 {seriesContext.orderIndex}번째
              </p>
            </div>
            <ol class="mt-4 grid gap-3">
              {seriesPosts.map((seriesPost) => {
                const previewText = (seriesPost.excerpt ?? "").trim();
                const relationLabel =
                  seriesPost.relation === "prev" ? "이전 글" : "다음 글";
                const resolvedSeriesPostCoverImageSrc = seriesPost.coverImageUrl
                  ? toBrowserImageUrl(seriesPost.coverImageUrl, {
                      width: 224,
                      height: 126,
                    })
                  : defaultSeriesPostCoverImageSrc;

                return (
                  <li>
                    <a
                      class={`group grid grid-cols-[124px_minmax(0,1fr)] items-center gap-4 rounded-2xl p-3.5 transition duration-200 hover:-translate-y-0.5 hover:border-sky-200/70 hover:bg-white ${PUBLIC_PANEL_SURFACE_SOFT_CLASS}`}
                      href={`/blog/${seriesPost.slug}`}
                    >
                      <img
                        class="aspect-[16/9] w-full rounded-xl border border-white/70 bg-slate-100 object-cover object-center"
                        src={resolvedSeriesPostCoverImageSrc}
                        alt={seriesPost.title}
                        decoding="async"
                        loading="lazy"
                        onerror={seriesPostCoverImageFallbackOnError}
                      />
                      <span class="grid min-w-0 content-center gap-1.5">
                        <small class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">
                          {relationLabel}
                        </small>
                        <strong class="text-sm font-semibold leading-6 text-foreground">
                          {seriesPost.title}
                        </strong>
                        <em class="line-clamp-2 text-sm not-italic text-muted-foreground">
                          {previewText.length > 0 ? previewText : "요약 없음"}
                        </em>
                      </span>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        </aside>
      )
    }
  </div>
</BaseLayout>
