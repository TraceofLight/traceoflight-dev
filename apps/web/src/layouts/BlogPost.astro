---
import type { CollectionEntry } from "astro:content";

import HeroMediaImage from "../components/HeroMediaImage.astro";
import PostAdminActions from "../components/public/PostAdminActions";
import BaseLayout from "./BaseLayout.astro";
import { formatDateLabel, toIsoDateTime } from "../lib/format-date";
import {
  getHeroMediaMetadata,
  normalizeHeroMedia,
  type HeroMediaSource,
} from "../lib/hero-media";

type MarkdownPostData = CollectionEntry<"blog">["data"];

interface DbPostData {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: HeroMediaSource;
}

interface SeriesContext {
  seriesSlug: string;
  seriesTitle: string;
  orderIndex: number;
  totalPosts: number;
  prevPostSlug: string | null;
  prevPostTitle: string | null;
  nextPostSlug: string | null;
  nextPostTitle: string | null;
}

interface SeriesPostItem {
  slug: string;
  title: string;
  excerpt?: string;
  coverImageUrl?: string;
  relation: "prev" | "next";
}

interface BlogPostAdminProps {
  postSlug?: string;
  adminPostSlug?: string;
  showAdminActions?: boolean;
  seriesContext?: SeriesContext;
  seriesPosts?: SeriesPostItem[];
}

type Props = (MarkdownPostData | DbPostData) & BlogPostAdminProps;

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  adminPostSlug = "",
  showAdminActions = false,
  seriesContext,
  seriesPosts = [],
} = Astro.props;
const shouldRenderAdminActions = Boolean(showAdminActions && adminPostSlug);
const defaultSeriesPostCoverImage = "/images/empty-series-image.png";
const hasSeriesSidebar = Boolean(seriesContext && seriesPosts.length > 0);
const heroMedia = normalizeHeroMedia(heroImage);
const pubDateLabel = formatDateLabel(pubDate);
const pubDateIso = toIsoDateTime(pubDate);
const updatedDateLabel = updatedDate ? formatDateLabel(updatedDate) : "";
const updatedDateIso = updatedDate ? toIsoDateTime(updatedDate) : "";
---

<BaseLayout
  title={title}
  description={description}
  image={getHeroMediaMetadata(heroMedia)}
  bodyClass="page-blog-post"
>
  <div
    class:list={[
      "mx-auto grid w-full gap-8",
      hasSeriesSidebar
        ? "max-w-6xl xl:grid-cols-[minmax(0,3fr)_minmax(280px,1fr)]"
        : "max-w-3xl",
    ]}
  >
    <article class="min-w-0">
      <nav
        class="flex flex-wrap items-center justify-between gap-3"
        aria-label="Post navigation"
      >
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          href="/blog/"
        >
          <span aria-hidden="true">‹</span>
          <span>블로그로 돌아가기</span>
        </a>
        {
          shouldRenderAdminActions && (
            <PostAdminActions client:load adminPostSlug={adminPostSlug} />
          )
        }
      </nav>

      {
        heroMedia && (
          <HeroMediaImage
            className="mt-8 aspect-[16/9] w-full rounded-3xl border border-border/60 object-cover shadow-sm"
            media={heroMedia}
            alt={title}
            width={1200}
            height={630}
          />
        )
      }

      <header class="mt-8 space-y-4">
        <p
          class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
        >
          <time datetime={pubDateIso}>{pubDateLabel}</time>
          {
            updatedDate && (
              <>
                <span aria-hidden="true">/</span>
                <span>
                  updated{" "}
                  <time datetime={updatedDateIso}>{updatedDateLabel}</time>
                </span>
              </>
            )
          }
        </p>
        <h1
          class="text-balance text-4xl font-semibold tracking-tight sm:text-5xl"
        >
          {title}
        </h1>
        <p class="max-w-2xl text-lg text-muted-foreground">{description}</p>
      </header>

      <section
        class="mt-10 text-base leading-8 text-foreground/90 [&_blockquote]:mb-5 [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:text-muted-foreground [&_figcaption]:mt-2 [&_figcaption]:text-center [&_figcaption]:text-sm [&_figcaption]:text-muted-foreground [&_figure]:mb-5 [&_figure>img]:block [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h4]:mt-6 [&_h4]:mb-3 [&_h4]:text-lg [&_h4]:font-semibold [&_img]:max-w-full [&_img]:rounded-2xl [&_img]:border [&_img]:border-border/60 [&_li]:leading-8 [&_ol]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-5 [&_ul]:mb-5 [&_ul]:list-disc [&_ul]:pl-6 [&_video]:mb-5 [&_video]:block [&_video]:max-w-full [&_video]:rounded-2xl [&_video]:border [&_video]:border-border/60"
      >
        <slot />
      </section>

      <nav class="mt-12 flex justify-center" aria-label="Blog archive">
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          href="/blog/"
        >
          <span aria-hidden="true">☰</span>
          <span>모든 글 보기</span>
        </a>
      </nav>
    </article>

    {
      hasSeriesSidebar && seriesContext && (
        <aside
          class="xl:sticky xl:top-24 xl:self-start"
          aria-label="시리즈 탐색"
        >
          <section class="rounded-3xl border border-border/60 bg-card p-5 shadow-sm">
            <p class="text-sm text-muted-foreground">
              <a
                class="font-medium text-foreground transition-colors hover:text-primary"
                href={`/series/${seriesContext.seriesSlug}`}
              >
                {seriesContext.seriesTitle}
              </a>
              <span>
                {" "}
                · {seriesContext.orderIndex}/{seriesContext.totalPosts}
              </span>
            </p>
            <ol class="mt-4 grid gap-3">
              {seriesPosts.map((seriesPost) => {
                const previewText = (seriesPost.excerpt ?? "").trim();
                const relationLabel =
                  seriesPost.relation === "prev" ? "이전 글" : "다음 글";

                return (
                  <li>
                    <a
                      class="group grid grid-cols-[112px_minmax(0,1fr)] gap-3 rounded-2xl border border-border/60 bg-background/70 p-3 transition hover:border-foreground/15 hover:bg-accent/40"
                      href={`/blog/${seriesPost.slug}`}
                    >
                      <img
                        class="aspect-[16/9] w-full rounded-xl border border-border/60 bg-muted object-cover"
                        src={
                          seriesPost.coverImageUrl ??
                          defaultSeriesPostCoverImage
                        }
                        alt={seriesPost.title}
                        loading="lazy"
                      />
                      <span class="grid min-w-0 content-start gap-1">
                        <small class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">
                          {relationLabel}
                        </small>
                        <strong class="text-sm font-semibold leading-6 text-foreground">
                          {seriesPost.title}
                        </strong>
                        <em class="line-clamp-2 text-sm not-italic text-muted-foreground">
                          {previewText.length > 0 ? previewText : "요약 없음"}
                        </em>
                      </span>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        </aside>
      )
    }
  </div>
</BaseLayout>
