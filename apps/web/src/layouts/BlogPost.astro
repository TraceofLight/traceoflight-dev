---
import type { CollectionEntry } from 'astro:content';

import FormattedDate from '../components/FormattedDate.astro';
import HeroMediaImage from '../components/HeroMediaImage.astro';
import BaseLayout from './BaseLayout.astro';
import { getHeroMediaMetadata, normalizeHeroMedia, type HeroMediaSource } from '../lib/hero-media';

type MarkdownPostData = CollectionEntry<'blog'>['data'];

interface DbPostData {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: HeroMediaSource;
}

interface SeriesContext {
  seriesSlug: string;
  seriesTitle: string;
  orderIndex: number;
  totalPosts: number;
  prevPostSlug: string | null;
  prevPostTitle: string | null;
  nextPostSlug: string | null;
  nextPostTitle: string | null;
}

interface SeriesPostItem {
  slug: string;
  title: string;
  excerpt?: string;
  coverImageUrl?: string;
  relation: 'prev' | 'next';
}

interface BlogPostAdminProps {
  postSlug?: string;
  adminPostSlug?: string;
  showAdminActions?: boolean;
  seriesContext?: SeriesContext;
  seriesPosts?: SeriesPostItem[];
}

type Props = (MarkdownPostData | DbPostData) & BlogPostAdminProps;

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  adminPostSlug = '',
  showAdminActions = false,
  seriesContext,
  seriesPosts = [],
} = Astro.props;
const shouldRenderAdminActions = Boolean(showAdminActions && adminPostSlug);
const encodedAdminPostSlug = adminPostSlug ? encodeURIComponent(adminPostSlug) : '';
const defaultSeriesPostCoverImage = '/images/empty-series-image.png';
const hasSeriesSidebar = Boolean(seriesContext && seriesPosts.length > 0);
const heroMedia = normalizeHeroMedia(heroImage);
---

<BaseLayout
  title={title}
  description={description}
  image={getHeroMediaMetadata(heroMedia)}
  bodyClass="page-blog-post"
>
  <div class={`post-layout${hasSeriesSidebar ? ' has-series-sidebar' : ''}`}>
    <article class="post-shell">
      <nav class="post-top-nav" aria-label="Post navigation">
        <a class="post-back-link button button-ghost" href="/blog/">
          <span aria-hidden="true">‹</span>
          <span>블로그로 돌아가기</span>
        </a>
        {
          shouldRenderAdminActions && (
            <div id="post-admin-actions" class="post-admin-actions">
              <a class="button button-ghost post-admin-action-edit" href={`/admin/posts/${encodedAdminPostSlug}/edit`}>
                수정
              </a>
              <button id="post-admin-delete-trigger" class="button button-ghost post-admin-action-delete" type="button">
                삭제
              </button>
            </div>
          )
        }
      </nav>

      {
        heroMedia && <HeroMediaImage className="post-hero" media={heroMedia} alt={title} width={1200} height={630} />
      }

      <header class="post-header">
        <p class="post-meta">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <>
                {' '}
                / updated <FormattedDate date={updatedDate} />
              </>
            )
          }
        </p>
        <h1>{title}</h1>
        <p class="post-description">{description}</p>
      </header>

      <section class="post-content">
        <slot />
      </section>

      <nav class="post-bottom-nav" aria-label="Blog archive">
        <a class="post-archive-link button button-ghost" href="/blog/">
          <span aria-hidden="true">☰</span>
          <span>모든 글 보기</span>
        </a>
      </nav>
    </article>

    {
      hasSeriesSidebar && seriesContext && (
        <aside class="post-series-sidebar" aria-label="시리즈 탐색">
          <section class="post-series-nav">
            <p class="post-series-kicker">
              <a href={`/series/${seriesContext.seriesSlug}`}>{seriesContext.seriesTitle}</a>
              <span>
                {' '}
                · {seriesContext.orderIndex}/{seriesContext.totalPosts}
              </span>
            </p>
            <ol class="post-series-links post-series-sidebar-list">
              {seriesPosts.map((seriesPost) => {
                const relationClass = seriesPost.relation === 'prev' ? 'post-series-prev' : 'post-series-next';
                const previewText = (seriesPost.excerpt ?? '').trim();
                const relationLabel = seriesPost.relation === 'prev' ? '이전 글' : '다음 글';
                return (
                  <li class="post-series-sidebar-item">
                    <a class={`post-series-sidebar-link ${relationClass}`} href={`/blog/${seriesPost.slug}`}>
                      <img
                        class="post-series-sidebar-thumb"
                        src={seriesPost.coverImageUrl ?? defaultSeriesPostCoverImage}
                        alt={seriesPost.title}
                        loading="lazy"
                      />
                      <span class="post-series-sidebar-content">
                        <small>{relationLabel}</small>
                        <strong>{seriesPost.title}</strong>
                        <em>{previewText.length > 0 ? previewText : '요약 없음'}</em>
                      </span>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        </aside>
      )
    }
  </div>

  {
    shouldRenderAdminActions && (
      <div id="post-admin-delete-modal" class="post-admin-modal" data-open="false" data-post-slug={adminPostSlug} hidden>
        <button
          id="post-admin-delete-backdrop"
          class="post-admin-modal-backdrop"
          type="button"
          aria-label="삭제 확인 닫기"
        />
        <section class="post-admin-modal-panel" role="dialog" aria-modal="true" aria-labelledby="post-admin-delete-title">
          <h2 id="post-admin-delete-title">게시글 삭제</h2>
          <p class="post-admin-modal-description">
            <strong>{adminPostSlug}</strong> 게시글을 삭제합니다. 이 작업은 되돌릴 수 없습니다.
          </p>
          <p id="post-admin-delete-feedback" class="post-admin-modal-feedback" data-state="info"></p>
          <div class="post-admin-modal-actions">
            <button id="post-admin-delete-cancel" class="button button-ghost" type="button">취소</button>
            <button id="post-admin-delete-confirm" class="button post-admin-danger" type="button">삭제</button>
          </div>
        </section>
      </div>
    )
  }
</BaseLayout>

{
  shouldRenderAdminActions && (
    <script type="module">
      const initializePostAdminDeleteModal = () => {
        const modal = document.querySelector('#post-admin-delete-modal');
        if (!(modal instanceof HTMLElement)) return;
        if (modal.dataset.deleteModalBound === 'true') return;

        const slug = typeof modal.dataset.postSlug === 'string' ? modal.dataset.postSlug.trim() : '';
        if (!slug) return;

        const openButton = document.querySelector('#post-admin-delete-trigger');
        const closeButton = document.querySelector('#post-admin-delete-cancel');
        const backdropButton = document.querySelector('#post-admin-delete-backdrop');
        const confirmButton = document.querySelector('#post-admin-delete-confirm');
        const feedback = document.querySelector('#post-admin-delete-feedback');
        if (!(openButton instanceof HTMLButtonElement)) return;
        if (!(closeButton instanceof HTMLButtonElement)) return;
        if (!(backdropButton instanceof HTMLButtonElement)) return;
        if (!(confirmButton instanceof HTMLButtonElement)) return;

        const setFeedback = (message, state = 'info') => {
          if (!(feedback instanceof HTMLElement)) return;
          feedback.textContent = message;
          feedback.dataset.state = state;
        };

        const setModalOpen = (nextOpen) => {
          modal.hidden = !nextOpen;
          modal.dataset.open = nextOpen ? 'true' : 'false';
          if (!nextOpen) {
            setFeedback('', 'info');
          }
        };

        const handleClose = () => setModalOpen(false);
        modal.dataset.deleteModalBound = 'true';
        openButton.addEventListener('click', () => setModalOpen(true));
        closeButton.addEventListener('click', handleClose);
        backdropButton.addEventListener('click', handleClose);

        confirmButton.addEventListener('click', async () => {
          confirmButton.disabled = true;
          setFeedback('삭제 처리 중...', 'info');
          try {
            const postPath = `/internal-api/posts/${encodeURIComponent(slug)}`;
            let response = await fetch(postPath, {
              method: 'DELETE',
            });
            if (response.status === 403) {
              response = await fetch(postPath, {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ action: 'delete' }),
              });
            }

            if (response.ok || response.status === 404) {
              window.location.assign('/blog/');
              return;
            }

            if (response.status === 401) {
              setFeedback('관리자 세션이 만료되었습니다. 다시 로그인해 주세요.', 'error');
              return;
            }

            if (response.status === 503) {
              setFeedback('백엔드 연결 상태가 불안정합니다. 잠시 후 다시 시도해 주세요.', 'error');
              return;
            }

            setFeedback('게시글 삭제에 실패했습니다. 잠시 후 다시 시도해 주세요.', 'error');
          } catch {
            setFeedback('네트워크 오류로 게시글 삭제에 실패했습니다.', 'error');
          } finally {
            confirmButton.disabled = false;
          }
        });

        window.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          if (modal.dataset.open !== 'true') return;
          event.preventDefault();
          setModalOpen(false);
        });
      };

      initializePostAdminDeleteModal();
      document.addEventListener('astro:page-load', initializePostAdminDeleteModal);
    </script>
  )
}
