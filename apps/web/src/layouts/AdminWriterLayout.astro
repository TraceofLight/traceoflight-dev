---
import BaseHead from '../components/BaseHead.astro';
import '@milkdown/crepe/theme/common/style.css';
import '@milkdown/crepe/theme/nord.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="writer-body">
    <main class="writer-page">
      <slot />
    </main>
    <script>
      let writerBootstrapPromise;

      const loadWriterBootstrap = async () => {
        writerBootstrapPromise ??= import("../lib/admin/writer-page-bootstrap");
        return writerBootstrapPromise;
      };

      const bootWriterPage = async () => {
        const { bootAdminWriterPage } = await loadWriterBootstrap();
        await bootAdminWriterPage();
      };

      void bootWriterPage();
      document.addEventListener("astro:page-load", () => {
        void bootWriterPage();
      });
    </script>
  </body>
</html>
