---
import type { ImageMetadata } from 'astro';

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PageTransitions from '../components/PageTransitions.astro';
import FloatingUtilityButtons from '../components/public/FloatingUtilityButtons.astro';
import { getGa4VisitorSummary } from '../lib/server/ga4-summary';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  imageUrl?: string;
  bodyClass?: string;
  pageType?: 'website' | 'article';
  author?: string;
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  structuredData?: Record<string, unknown>;
  robots?: string;
  locale?: string;
  alternates?: ReadonlyArray<{ hrefLang: string; href: URL | string }>;
}

const { title, description, image, bodyClass = '', locale = 'ko', alternates = [] } = Astro.props;
const {
  imageUrl,
  pageType,
  author,
  publishedTime,
  modifiedTime,
  structuredData,
  robots,
} = Astro.props;
const htmlClassName = bodyClass.trim() || undefined;
const visitorSummary = await getGa4VisitorSummary();
---

<!doctype html>
<html lang={locale} class={htmlClassName}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      imageUrl={imageUrl}
      pageType={pageType}
      author={author}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      structuredData={structuredData}
      robots={robots}
      locale={locale}
      alternates={alternates}
    />
    <PageTransitions />
  </head>
  <body class="site-shell">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" class="page container" transition:name="page-content">
      <slot />
    </main>
    <Footer visitorSummary={visitorSummary} />
    <FloatingUtilityButtons />
  </body>
</html>
