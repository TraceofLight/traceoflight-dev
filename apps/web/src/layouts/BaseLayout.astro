---
import type { ImageMetadata } from 'astro';

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PageTransitions from '../components/PageTransitions.astro';
import FloatingUtilityButtons from '../components/public/FloatingUtilityButtons';
import { getGa4VisitorSummary } from '../lib/server/ga4-summary';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  bodyClass?: string;
}

const { title, description, image, bodyClass = '' } = Astro.props;
const htmlClassName = bodyClass.trim() || undefined;
const visitorSummary = await getGa4VisitorSummary();
---

<!doctype html>
<html lang="en" class={htmlClassName}>
  <head>
    <BaseHead title={title} description={description} image={image} />
    <PageTransitions />
  </head>
  <body class="site-shell">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" class="page container" transition:name="page-content">
      <slot />
    </main>
    <Footer visitorSummary={visitorSummary} />
    <FloatingUtilityButtons client:only="react" />
  </body>
</html>
