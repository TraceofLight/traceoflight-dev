---
import {
  DEFAULT_SERIES_IMAGE,
  SITE_AUTHOR,
  SITE_TITLE,
  SITE_URL,
} from "../../../consts";
import PostAdminActions from "../../../components/public/PostAdminActions";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../../lib/admin-auth";
import { getPublishedDbProjectBySlug } from "../../../lib/projects";
import { normalizeCoverMedia } from "../../../lib/cover-media";
import {
  PUBLIC_BADGE_STRONG_CLASS,
  PUBLIC_EMPTY_STATE_CLASS,
  PUBLIC_PANEL_SURFACE_CLASS,
  PUBLIC_SECTION_SURFACE_CLASS,
  PUBLIC_SURFACE_ACTION_CLASS,
} from "../../../lib/ui-effects";
import { toYoutubeEmbedUrl } from "../../../lib/youtube";
import { buildProjectCreativeWorkSchema } from "../../../lib/seo/structured-data";
import {
  isSupportedPublicLocale,
  SUPPORTED_PUBLIC_LOCALES,
  type PublicLocale,
} from "../../../lib/i18n/locales";
import { pickDictionary } from "../../../lib/i18n/dictionary";
import { buildLocalizedAlternates } from "../../../lib/seo/localized-urls";

// ── Locale validation ──────────────────────────────────────────────────────
const rawLocale = Astro.params.locale;
if (!rawLocale || !isSupportedPublicLocale(rawLocale)) {
  return new Response(null, { status: 404 });
}
const locale: PublicLocale = rawLocale;
const t = pickDictionary(locale);

// ── Data fetching ──────────────────────────────────────────────────────────
const slug = Astro.params.slug ?? "";
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? await verifyAccessToken(accessToken) : false;
const project = await getPublishedDbProjectBySlug(slug, { locale });
const projectProfile = project
  ? {
      role: project.role,
      period: project.period,
      highlights: project.highlights,
      links: project.links,
    }
  : null;
const youtubeEmbedUrl =
  project && project.topMediaKind === "youtube"
    ? toYoutubeEmbedUrl(project.topMediaYoutubeUrl)
    : null;
const shouldRenderProjectTopVideo = project?.topMediaKind === "video" && project.topMediaVideoUrl;

if (!project) {
  Astro.response.status = 404;
}

const projectStructuredData = project
  ? buildProjectCreativeWorkSchema({
      slug: project.slug,
      title: project.title,
      summary: project.summary,
      stack: project.stack,
      locale,
      coverImageUrl: project.coverImageUrl ?? project.topMediaImageUrl ?? undefined,
    })
  : undefined;

// ── SEO alternates ─────────────────────────────────────────────────────────
const alternates = project
  ? buildLocalizedAlternates(
      Object.fromEntries(
        SUPPORTED_PUBLIC_LOCALES.map((l) => [l, `/${l}/projects/${project.slug}`]),
      ) as Record<PublicLocale, string>,
      new URL(SITE_URL),
    )
  : [];
---

{
  project ? (
    <BaseLayout
      title={`${project.title} | Projects | ${SITE_TITLE}`}
      description={project.summary}
      pageType="article"
      author={SITE_AUTHOR}
      imageUrl={project.coverImageUrl ?? project.topMediaImageUrl}
      locale={locale}
      alternates={alternates}
      structuredData={projectStructuredData}
    >
      <section class="mx-auto flex max-w-[1398px] flex-col gap-8 py-10 sm:py-12">
        <nav class="flex flex-wrap items-center justify-between gap-3" aria-label="Project navigation">
          <a
            class={PUBLIC_SURFACE_ACTION_CLASS}
            href={`/${locale}/projects`}
          >
            <span aria-hidden="true">‹</span>
            <span>{t.blogPost.backToBlog.replace("블로그", t.nav.projects)}</span>
          </a>
          {
            isAdminViewer && (
              <PostAdminActions client:load adminPostSlug={project.slug} />
            )
          }
        </nav>

        <header class={`grid gap-8 p-6 lg:grid-cols-[minmax(0,1.1fr)_320px] lg:p-8 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          <div class="space-y-5">
            <div class="space-y-4">
              <p class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
                ABOUT PROJECT
              </p>
              <h1 class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
                {project.title}
              </h1>
              {
                project.summary && (
                  <p class="max-w-2xl text-base leading-8 text-foreground/78">
                    {project.summary}
                  </p>
                )
              }
            </div>

            <div class="flex flex-wrap items-center gap-2">
              {project.stack.map((skill) => (
                <span class={PUBLIC_BADGE_STRONG_CLASS}>
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <div class={`rounded-3xl bg-white/88 p-5 ${PUBLIC_PANEL_SURFACE_CLASS}`}>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              {t.projectDetail.role}
            </h2>
            <p class="mt-4 text-base leading-8 text-foreground/85">
              {projectProfile?.role}
            </p>
            <p class="mt-2 text-sm text-muted-foreground">{projectProfile?.period}</p>
          </div>
        </header>

        <div class={`overflow-hidden ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          {
            shouldRenderProjectTopVideo ? (
              <video
                class="aspect-[16/9] h-full w-full object-cover"
                controls
                data-project-top-video
                preload="metadata"
              >
                <source src={project.topMediaVideoUrl} type="video/mp4" />
              </video>
            ) : youtubeEmbedUrl ? (
              <iframe
                class="aspect-[16/9] h-full w-full"
                src={youtubeEmbedUrl}
                title={project.title}
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allow="autoplay; encrypted-media"
                allowfullscreen
              />
            ) : (
              <img
                alt={project.title}
                class="aspect-[16/9] h-full w-full object-cover"
                height={780}
                loading="lazy"
                src={project.topMediaImageUrl ?? project.coverImageUrl ?? DEFAULT_SERIES_IMAGE}
                width={1400}
              />
            )
          }
        </div>

        <section class="grid gap-6 lg:grid-cols-[minmax(0,1.7fr)_minmax(260px,0.8fr)]">
          <article class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              {t.projectDetail.highlights}
            </h2>
            <p class="mt-4 text-base leading-8 text-foreground/85">
              {project.intro}
            </p>
            {
              projectProfile?.highlights.length ? (
                <ul class="mt-5 grid gap-3 text-sm leading-7 text-muted-foreground">
                  {projectProfile.highlights.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : null
            }
          </article>

          <article class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              {t.projectDetail.resources}
            </h2>
            {
              (projectProfile?.links.length ?? 0) > 0 ? (
                <div class="mt-4 flex flex-col items-start gap-3">
                  {projectProfile?.links.map((link) => {
                    const isExternal = /^https?:\/\//.test(link.href);
                    return (
                      <a
                        class={`w-full justify-start ${PUBLIC_SURFACE_ACTION_CLASS}`}
                        href={link.href}
                        rel={isExternal ? "noreferrer" : undefined}
                        target={isExternal ? "_blank" : undefined}
                      >
                        {link.label}
                      </a>
                    );
                  })}
                </div>
              ) : (
                <p class="mt-4 text-sm leading-7 text-muted-foreground">
                  {t.empty.noResults}
                </p>
              )
            }
          </article>
        </section>

        <section class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          <div class="space-y-2">
            <h2 class="text-2xl font-semibold tracking-tight text-foreground">
              {t.projectDetail.period}
            </h2>
          </div>
          <div class="markdown-prose mt-5 text-base leading-8 text-foreground/85" set:html={project.description} />
        </section>

        {
          project.relatedSeriesPosts.length > 0 && (
            <section class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
                  RELATED SERIES
                </p>
                <h2 class="text-2xl font-semibold tracking-tight text-foreground">
                  {t.blogPost.relatedSeries}
                </h2>
              </div>
              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {project.relatedSeriesPosts.map((post) => (
                  <PostCard
                    post={{
                      slug: post.slug,
                      title: post.title,
                      description: post.excerpt,
                      pubDate: post.publishedAt ?? new Date(),
                      coverMedia: normalizeCoverMedia(post.coverImageUrl),
                      body: post.excerpt,
                      tags: [],
                      visibility: post.visibility,
                    }}
                    locale={locale}
                  />
                ))}
              </div>
            </section>
          )
        }
        <nav class="flex justify-center" aria-label="Projects archive">
          <a
            class={PUBLIC_SURFACE_ACTION_CLASS}
            href={`/${locale}/projects`}
          >
            <span aria-hidden="true">☰</span>
            <span>{t.buttons.viewAll}</span>
          </a>
        </nav>
      </section>

      {
        shouldRenderProjectTopVideo ? (
          <script is:inline>
            {`
              (() => {
                const reloadProjectTopVideo = () => {
                  const video = document.querySelector("video[data-project-top-video]");
                  if (!(video instanceof HTMLVideoElement)) {
                    return;
                  }
                  const hasMp4Source = Array.from(video.querySelectorAll("source")).some(
                    (source) => source instanceof HTMLSourceElement && source.type === "video/mp4" && Boolean(source.src),
                  );
                  if (!hasMp4Source) {
                    return;
                  }
                  video.load();
                };

                reloadProjectTopVideo();
                document.addEventListener("astro:page-load", reloadProjectTopVideo);
              })();
            `}
          </script>
        ) : null
      }
    </BaseLayout>
  ) : (
    <BaseLayout
      title={`${t.notFound.title} | ${SITE_TITLE}`}
      description={t.notFound.description}
      robots="noindex"
      locale={locale}
    >
      <section class="mx-auto flex max-w-3xl flex-col gap-6 py-16">
        <div class={`${PUBLIC_EMPTY_STATE_CLASS} px-6 py-12 text-center`}>
          <p class="text-base text-muted-foreground">
            {t.notFound.description}
          </p>
          <a
            class={`${PUBLIC_SURFACE_ACTION_CLASS} mt-5`}
            href={`/${locale}/projects`}
          >
            {t.buttons.backToList}
          </a>
        </div>
      </section>
    </BaseLayout>
  )
}
