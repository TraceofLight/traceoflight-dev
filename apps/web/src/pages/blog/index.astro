---
import BlogArchiveFilters from "../../components/public/BlogArchiveFilters";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import { listAllPublishedDbPosts } from "../../lib/blog-db";
import {
  getBlogSource,
  getContentProvider,
  toPostCard,
  type PostCard as PostCardData,
} from "../../lib/content-source";
import { formatReadingTimeLabel } from "../../lib/reading-time";

const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
let posts: PostCardData[] = [];

if (provider === "db") {
  try {
    const dbPosts = await listAllPublishedDbPosts({
      includePrivate: isAdminViewer,
    });
    posts = dbPosts.map((post) => ({
      slug: post.slug,
      title: post.title,
      description: post.description,
      body: post.bodyMarkdown,
      pubDate: post.publishedAt,
      updatedDate: post.updatedAt,
      heroMedia: post.heroMedia,
      visibility: post.visibility,
      tags: post.tags.map((tag) => tag.slug),
    }));
  } catch {
    posts = [];
  }
} else {
  posts = (await getBlogSource().listPosts()).map(toPostCard);
}

const publicCount = posts.filter(
  (post) => post.visibility !== "private",
).length;
const privateCount = posts.filter(
  (post) => post.visibility === "private",
).length;
const tagCountMap = new Map<string, number>();
for (const post of posts) {
  const normalizedTags = new Set(
    (post.tags ?? []).map((tag) => tag.trim().toLowerCase()).filter(Boolean),
  );
  for (const tag of normalizedTags) {
    tagCountMap.set(tag, (tagCountMap.get(tag) ?? 0) + 1);
  }
}
const tagFilters = Array.from(tagCountMap.entries())
  .map(([slug, count]) => ({ slug, count }))
  .sort((left, right) => left.slug.localeCompare(right.slug, "ko-KR"));
const selectedTagsFromQuery = Astro.url.searchParams
  .getAll("tag")
  .map((value) => value.trim().toLowerCase())
  .filter(Boolean);

function resolveHeroImageSrc(post: PostCardData) {
  if (!post.heroMedia) {
    return "/images/empty-article-image.png";
  }

  return post.heroMedia.kind === "optimized"
    ? post.heroMedia.src.src
    : post.heroMedia.src;
}

const archivePosts = posts.map((post) => ({
  slug: post.slug,
  title: post.title,
  description: post.description,
  visibility: post.visibility === "private" ? "private" : "public",
  tags: (post.tags ?? [])
    .map((tag) => tag.trim().toLowerCase())
    .filter(Boolean),
  publishedAt: post.pubDate.toISOString(),
  publishedAtValue: post.pubDate.valueOf(),
  readingLabel: formatReadingTimeLabel(post.body ?? ""),
  heroImageSrc: resolveHeroImageSrc(post),
}));
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <BlogArchiveFilters
    client:load
    initialSelectedTags={selectedTagsFromQuery}
    isAdminViewer={isAdminViewer}
    posts={archivePosts}
    tagFilters={tagFilters}
  />
</BaseLayout>
