---
import PostCard from "../../components/PostCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import { listPublishedDbPosts } from "../../lib/blog-db";
import {
  getBlogSource,
  getContentProvider,
  toPostCard,
  type PostCard as PostCardData,
} from "../../lib/content-source";

const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
let posts: PostCardData[] = [];

if (provider === "db") {
  try {
    const dbPosts = await listPublishedDbPosts(50, {
      includePrivate: isAdminViewer,
    });
    posts = dbPosts.map((post) => ({
      slug: post.slug,
      title: post.title,
      description: post.description,
      pubDate: post.publishedAt,
      updatedDate: post.updatedAt,
      heroImage: post.coverImageUrl,
      visibility: post.visibility,
      tags: post.tags.map((tag) => tag.slug),
    }));
  } catch {
    posts = [];
  }
} else {
  posts = (await getBlogSource().listPosts()).map(toPostCard);
}

const publicCount = posts.filter(
  (post) => post.visibility !== "private",
).length;
const privateCount = posts.filter(
  (post) => post.visibility === "private",
).length;
const tagCountMap = new Map<string, number>();
for (const post of posts) {
  const normalizedTags = new Set(
    (post.tags ?? []).map((tag) => tag.trim().toLowerCase()).filter(Boolean),
  );
  for (const tag of normalizedTags) {
    tagCountMap.set(tag, (tagCountMap.get(tag) ?? 0) + 1);
  }
}
const tagFilters = Array.from(tagCountMap.entries())
  .map(([slug, count]) => ({ slug, count }))
  .sort((left, right) => left.slug.localeCompare(right.slug, "ko-KR"));
const selectedTagsFromQuery = Astro.url.searchParams
  .getAll("tag")
  .map((value) => value.trim().toLowerCase())
  .filter(Boolean);
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <section class="blog-archive">
    <header class="blog-archive-hero">
      <h1>Blog</h1>
      <p>TraceofLight의 개발과 다양한 이야기 Archive</p>
    </header>

    {
      posts.length > 0 ? (
        <>
          <section
            class="blog-archive-control-bar"
            aria-label="Blog archive controls"
          >
            <label class="blog-archive-search" for="blog-search">
              <span class="sr-only">포스트 검색</span>
              <input
                id="blog-search"
                type="search"
                placeholder="포스트 검색..."
                autocomplete="off"
              />
            </label>

            <div class="blog-archive-control-actions">
              {isAdminViewer && (
                <a
                  id="blog-admin-write"
                  class="button button-ghost blog-admin-write"
                  href="/admin/posts/new"
                >
                  글 작성
                </a>
              )}
              <select id="blog-sort" aria-label="정렬 방식">
                <option value="latest">최신순</option>
                <option value="oldest">오래된순</option>
                <option value="title">제목순</option>
              </select>
            </div>
          </section>

          {
            isAdminViewer && (
              <section class="blog-import-panel" id="blog-import-panel">
                <p class="blog-import-title">Velog Import</p>
                <div class="blog-import-grid">
                  <label class="blog-import-field" for="blog-import-username">
                    <span>Velog 사용자명</span>
                    <input
                      id="blog-import-username"
                      type="text"
                      value="traceoflight"
                      placeholder="traceoflight"
                      autocomplete="off"
                    />
                  </label>
                  <label class="blog-import-field" for="blog-import-snapshot-id">
                    <span>Snapshot ID</span>
                    <input
                      id="blog-import-snapshot-id"
                      type="text"
                      placeholder="스냅샷 생성 후 자동 입력"
                      autocomplete="off"
                    />
                  </label>
                </div>
                <div class="blog-import-actions">
                  <button
                    id="blog-import-build"
                    class="button button-ghost"
                    type="button"
                  >
                    Velog 크롤링 + ZIP 저장
                  </button>
                  <button
                    id="blog-import-apply"
                    class="button button-brand"
                    type="button"
                  >
                    ZIP에서 DB 반영
                  </button>
                </div>
                <p id="blog-import-feedback" class="blog-import-feedback">
                  대기 중
                </p>
              </section>
            )
          }

          <section class="blog-archive-filter-panel" id="blog-filter-panel">
            <p class="blog-archive-filter-label">게시글 필터</p>
            <div class="blog-archive-filter-chips">
              <button
                class="is-active"
                type="button"
                data-visibility-filter="all"
                aria-pressed="true"
              >
                전체 ({posts.length})
              </button>
              {isAdminViewer && (
                <>
                  <button
                    type="button"
                    data-visibility-filter="public"
                    aria-pressed="false"
                  >
                    공개 ({publicCount})
                  </button>
                  <button
                    type="button"
                    data-visibility-filter="private"
                    aria-pressed="false"
                  >
                    비공개 ({privateCount})
                  </button>
                </>
              )}
              {tagFilters.map((tag) => {
                const isActive = selectedTagsFromQuery.includes(tag.slug);
                return (
                  <button
                    class={isActive ? "is-active" : undefined}
                    type="button"
                    data-tag-filter={tag.slug}
                    aria-pressed={isActive ? "true" : "false"}
                  >
                    {tag.slug} ({tag.count})
                  </button>
                );
              })}
            </div>
          </section>

          <p id="blog-post-count" class="blog-archive-count">
            총 {posts.length}개의 포스트
          </p>

          <section id="blog-post-grid" class="blog-archive-grid">
            {posts.map((post) => (
              <PostCard
                post={post}
                variant="archive"
                showVisibility={isAdminViewer}
              />
            ))}
          </section>
        </>
      ) : (
        <div class="empty-state">게시글이 아직 없습니다.</div>
      )
    }
  </section>
</BaseLayout>

<script type="module">
  function initializeBlogArchivePage() {
    const searchInput = document.querySelector("#blog-search");
    const sortSelect = document.querySelector("#blog-sort");
    const postCountText = document.querySelector("#blog-post-count");
    const postGrid = document.querySelector("#blog-post-grid");
    const importUsernameInput = document.querySelector("#blog-import-username");
    const importSnapshotIdInput = document.querySelector(
      "#blog-import-snapshot-id",
    );
    const importBuildButton = document.querySelector("#blog-import-build");
    const importApplyButton = document.querySelector("#blog-import-apply");
    const importFeedback = document.querySelector("#blog-import-feedback");
    const importSnapshotStorageKey = "traceoflight.velog.import.snapshot-id";

    if (!(postGrid instanceof HTMLElement)) return;
    if (postGrid.dataset.archiveBound === "true") return;
    postGrid.dataset.archiveBound = "true";

    const archiveRoot = postGrid.closest(".blog-archive");
    const filterScope =
      archiveRoot instanceof HTMLElement ? archiveRoot : document;
    const getCards = () =>
      Array.from(postGrid.querySelectorAll("[data-visibility]")).filter(
        (card) => card instanceof HTMLElement,
      );
    const filterButtons = Array.from(
      filterScope.querySelectorAll("[data-visibility-filter]"),
    ).filter((button) => button instanceof HTMLButtonElement);
    const tagButtons = Array.from(
      filterScope.querySelectorAll("[data-tag-filter]"),
    ).filter((button) => button instanceof HTMLButtonElement);
    let activeVisibility = "all";
    let activeTags = new Set();

    const normalize = (value) =>
      typeof value === "string" ? value.trim().toLowerCase() : "";
    const parseCardTags = (value) =>
      (typeof value === "string" ? value : "")
        .split(",")
        .map((tag) => normalize(tag))
        .filter(Boolean);
    const setImportFeedback = (message, state = "idle") => {
      if (!(importFeedback instanceof HTMLElement)) return;
      importFeedback.textContent = message;
      importFeedback.dataset.state = state;
    };

    const setImportBusy = (busy) => {
      if (importBuildButton instanceof HTMLButtonElement) {
        importBuildButton.disabled = busy;
      }
      if (importApplyButton instanceof HTMLButtonElement) {
        importApplyButton.disabled = busy;
      }
    };

    const readJsonSafe = async (response) => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };

    const resolveErrorMessage = (payload, fallback) => {
      if (payload && typeof payload === "object") {
        if (typeof payload.detail === "string" && payload.detail.trim()) {
          return payload.detail.trim();
        }
        if (typeof payload.message === "string" && payload.message.trim()) {
          return payload.message.trim();
        }
      }
      return fallback;
    };

    const restoreSnapshotId = () => {
      if (!(importSnapshotIdInput instanceof HTMLInputElement)) return;
      const stored = window.localStorage.getItem(importSnapshotStorageKey) ?? "";
      if (stored.trim() && !importSnapshotIdInput.value.trim()) {
        importSnapshotIdInput.value = stored.trim();
      }
    };

    const sortCards = (visibleCards) => {
      const selectedSort =
        sortSelect instanceof HTMLSelectElement ? sortSelect.value : "latest";

      return [...visibleCards].sort((left, right) => {
        const leftTimestamp = Number(left.dataset.publishedAt || 0);
        const rightTimestamp = Number(right.dataset.publishedAt || 0);
        const leftTitle = left.dataset.sortTitle || "";
        const rightTitle = right.dataset.sortTitle || "";

        if (selectedSort === "oldest") return leftTimestamp - rightTimestamp;
        if (selectedSort === "title")
          return leftTitle.localeCompare(rightTitle, "ko-KR");
        return rightTimestamp - leftTimestamp;
      });
    };

    const applyFiltersAndSort = () => {
      const cards = getCards();
      const searchTerm = normalize(
        searchInput instanceof HTMLInputElement ? searchInput.value : "",
      );
      const visibleCards = [];
      const hiddenCards = [];

      cards.forEach((card) => {
        const cardVisibility = normalize(card.dataset.visibility || "public");
        const title = normalize(card.dataset.title || "");
        const description = normalize(card.dataset.description || "");
        const cardTags = parseCardTags(card.dataset.tags || "");
        const matchesVisibility =
          activeVisibility === "all" || cardVisibility === activeVisibility;
        const matchesSearch =
          !searchTerm ||
          title.includes(searchTerm) ||
          description.includes(searchTerm);
        const matchesTag =
          activeTags.size === 0 || cardTags.some((tag) => activeTags.has(tag));
        const isVisible = matchesVisibility && matchesSearch && matchesTag;

        card.toggleAttribute("hidden", !isVisible);
        if (isVisible) {
          visibleCards.push(card);
          return;
        }
        hiddenCards.push(card);
      });

      const sorted = sortCards(visibleCards);
      [...sorted, ...hiddenCards].forEach((card) => postGrid.append(card));

      if (postCountText instanceof HTMLElement) {
        postCountText.textContent = `총 ${visibleCards.length}개의 포스트`;
      }
    };

    const syncTagFilterButtons = () => {
      tagButtons.forEach((button) => {
        const tagValue = normalize(button.dataset.tagFilter || "");
        const isActive = tagValue ? activeTags.has(tagValue) : false;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
    };

    const syncTagQuery = () => {
      const url = new URL(window.location.href);
      url.searchParams.delete("tag");
      const firstTag = Array.from(activeTags)[0];
      if (firstTag) {
        url.searchParams.set("tag", firstTag);
      }
      window.history.replaceState(
        {},
        "",
        `${url.pathname}${url.search}${url.hash}`,
      );
    };

    const setActiveFilter = (value) => {
      activeVisibility = normalize(value || "all") || "all";
      filterButtons.forEach((button) => {
        const isActive =
          normalize(button.dataset.visibilityFilter) === activeVisibility;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
      applyFiltersAndSort();
    };

    const initializeTagFilterFromQuery = () => {
      const searchParams = new URLSearchParams(window.location.search);
      const initialTags = searchParams
        .getAll("tag")
        .map((value) => normalize(value))
        .filter(Boolean);
      activeTags = new Set(initialTags.slice(0, 1));
      syncTagFilterButtons();
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveFilter(button.dataset.visibilityFilter || "all");
      });
    });

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tagValue = normalize(button.dataset.tagFilter || "");
        if (!tagValue) {
          return;
        }
        if (activeTags.has(tagValue)) {
          activeTags.clear();
        } else {
          activeTags = new Set([tagValue]);
        }
        syncTagFilterButtons();
        syncTagQuery();
        applyFiltersAndSort();
      });
    });

    if (sortSelect instanceof HTMLSelectElement) {
      sortSelect.addEventListener("change", applyFiltersAndSort);
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", applyFiltersAndSort);
    }

    if (
      importBuildButton instanceof HTMLButtonElement &&
      importApplyButton instanceof HTMLButtonElement
    ) {
      restoreSnapshotId();

      importBuildButton.addEventListener("click", async () => {
        const username =
          importUsernameInput instanceof HTMLInputElement
            ? importUsernameInput.value.trim().replace(/^@+/, "")
            : "";
        if (!username) {
          setImportFeedback("Velog 사용자명을 입력해 주세요.", "error");
          return;
        }

        setImportBusy(true);
        setImportFeedback("Velog 글을 수집해 ZIP 스냅샷을 생성 중입니다...", "pending");
        try {
          const response = await fetch("/internal-api/imports/snapshots/velog", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ username }),
          });
          const payload = await readJsonSafe(response);
          if (!response.ok) {
            setImportFeedback(
              resolveErrorMessage(payload, "스냅샷 생성에 실패했습니다."),
              "error",
            );
            return;
          }

          const snapshotId =
            payload && typeof payload.snapshot_id === "string"
              ? payload.snapshot_id.trim()
              : "";
          const totalItems =
            payload && typeof payload.total_items === "number"
              ? payload.total_items
              : 0;
          if (snapshotId && importSnapshotIdInput instanceof HTMLInputElement) {
            importSnapshotIdInput.value = snapshotId;
            window.localStorage.setItem(importSnapshotStorageKey, snapshotId);
          }
          setImportFeedback(
            `스냅샷 생성 완료: ${snapshotId || "-"} (${totalItems}개 포스트)`,
            "ok",
          );
        } catch {
          setImportFeedback("스냅샷 요청 중 네트워크 오류가 발생했습니다.", "error");
        } finally {
          setImportBusy(false);
        }
      });

      importApplyButton.addEventListener("click", async () => {
        const snapshotId =
          importSnapshotIdInput instanceof HTMLInputElement
            ? importSnapshotIdInput.value.trim()
            : "";
        if (!snapshotId) {
          setImportFeedback("먼저 스냅샷을 생성하거나 Snapshot ID를 입력해 주세요.", "error");
          return;
        }

        setImportBusy(true);
        setImportFeedback("스냅샷에서 DB 반영을 실행 중입니다...", "pending");
        try {
          const response = await fetch(
            `/internal-api/imports/snapshots/${encodeURIComponent(snapshotId)}/jobs`,
            {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ mode: "apply" }),
            },
          );
          const payload = await readJsonSafe(response);
          if (!response.ok) {
            setImportFeedback(
              resolveErrorMessage(payload, "DB 반영 실행에 실패했습니다."),
              "error",
            );
            return;
          }

          const created =
            payload && typeof payload.created_items === "number"
              ? payload.created_items
              : 0;
          const updated =
            payload && typeof payload.updated_items === "number"
              ? payload.updated_items
              : 0;
          const failed =
            payload && typeof payload.failed_items === "number"
              ? payload.failed_items
              : 0;
          const statusText =
            failed > 0
              ? `DB 반영 완료(일부 실패): 생성 ${created}, 수정 ${updated}, 실패 ${failed}`
              : `DB 반영 완료: 생성 ${created}, 수정 ${updated}`;
          setImportFeedback(statusText, failed > 0 ? "error" : "ok");
          window.localStorage.setItem(importSnapshotStorageKey, snapshotId);
        } catch {
          setImportFeedback("DB 반영 요청 중 네트워크 오류가 발생했습니다.", "error");
        } finally {
          setImportBusy(false);
        }
      });
    }

    initializeTagFilterFromQuery();
    setActiveFilter("all");
  }

  initializeBlogArchivePage();
  document.addEventListener("astro:page-load", initializeBlogArchivePage);
</script>
