---
import { render } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../layouts/BlogPost.astro";
import EmptyStateNotice from "../../components/EmptyStateNotice.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import { buildBackendApiUrl, requestBackend } from "../../lib/backend-api";
import { getPublishedDbPostBySlug, renderDbMarkdown } from "../../lib/blog-db";
import { getBlogSource, getContentProvider } from "../../lib/content-source";
import { getSeriesBySlug } from "../../lib/series-db";
import type { PostCommentThreadList } from "../../lib/post-comments";

const slug = Astro.params.slug ?? "";
const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? await verifyAccessToken(accessToken) : false;
const markdownPost =
  provider === "file" ? await getBlogSource().getPostBySlug(slug) : null;
let dbPost: Awaited<ReturnType<typeof getPublishedDbPostBySlug>> = null;

if (provider === "db") {
  try {
    dbPost = await getPublishedDbPostBySlug(slug, {
      includePrivate: isAdminViewer,
    });
  } catch {
    dbPost = null;
  }
}

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let dbPostHtml: string | null = null;
let dbSeriesPostsForSidebar: {
  slug: string;
  title: string;
  excerpt: string;
  coverImageUrl?: string;
  relation: "prev" | "next";
}[] = [];
let commentsData: PostCommentThreadList = {
  comment_count: 0,
  items: [],
};

async function fetchInitialComments(postSlug: string, includePrivate: boolean) {
  const path = `/posts/${encodeURIComponent(postSlug)}/comments`;
  const response = includePrivate
    ? await requestBackend(path)
    : await fetch(buildBackendApiUrl(path), { cache: "no-store" });
  if (response.status === 404) {
    return commentsData;
  }
  if (!response.ok) {
    return commentsData;
  }
  return (await response.json()) as PostCommentThreadList;
}

if (markdownPost) {
  ({ Content } = await render(markdownPost));
  commentsData = await fetchInitialComments(slug, isAdminViewer).catch(() => commentsData);
} else if (dbPost) {
  dbPostHtml = renderDbMarkdown(dbPost.bodyMarkdown);
  commentsData = await fetchInitialComments(dbPost.slug, isAdminViewer).catch(() => commentsData);
  const seriesSlug = dbPost.seriesContext?.seriesSlug?.trim() ?? "";
  if (seriesSlug.length > 0) {
    try {
      const detail = await getSeriesBySlug(seriesSlug, {
        includePrivate: isAdminViewer,
      });
      if (detail?.posts?.length) {
        const bySlug = new Map(
          detail.posts.map((post) => [
            post.slug,
            {
              slug: post.slug,
              title: post.title,
              excerpt: post.excerpt ?? "",
              coverImageUrl: post.coverImageUrl,
            },
          ]),
        );

        const prevPostSlug = dbPost.seriesContext?.prevPostSlug?.trim() ?? "";
        const nextPostSlug = dbPost.seriesContext?.nextPostSlug?.trim() ?? "";

        if (prevPostSlug.length > 0) {
          const prevPost = bySlug.get(prevPostSlug);
          dbSeriesPostsForSidebar.push({
            slug: prevPostSlug,
            title:
              prevPost?.title ??
              dbPost.seriesContext?.prevPostTitle ??
              prevPostSlug,
            excerpt: prevPost?.excerpt ?? "",
            coverImageUrl: prevPost?.coverImageUrl,
            relation: "prev",
          });
        }

        if (nextPostSlug.length > 0) {
          const nextPost = bySlug.get(nextPostSlug);
          dbSeriesPostsForSidebar.push({
            slug: nextPostSlug,
            title:
              nextPost?.title ??
              dbPost.seriesContext?.nextPostTitle ??
              nextPostSlug,
            excerpt: nextPost?.excerpt ?? "",
            coverImageUrl: nextPost?.coverImageUrl,
            relation: "next",
          });
        }
      }
    } catch {
      dbSeriesPostsForSidebar = [];
    }
  }
} else {
  Astro.response.status = 404;
}
---

{
  markdownPost && Content ? (
    <BlogPost {...markdownPost.data} postSlug={slug} showAdminActions={false} isAdminViewer={isAdminViewer} commentsData={commentsData}>
      <Content />
    </BlogPost>
  ) : dbPost && dbPostHtml ? (
    <BlogPost
      title={dbPost.title}
      description={dbPost.description}
      pubDate={dbPost.publishedAt}
      updatedDate={dbPost.updatedAt}
      coverImage={dbPost.coverImageUrl}
      topMediaKind={dbPost.topMediaKind}
      topMediaImageUrl={dbPost.topMediaImageUrl}
      topMediaYoutubeUrl={dbPost.topMediaYoutubeUrl}
      topMediaVideoUrl={dbPost.topMediaVideoUrl}
      postSlug={dbPost.slug}
      adminPostSlug={dbPost.slug}
      showAdminActions={isAdminViewer}
      isAdminViewer={isAdminViewer}
      seriesContext={dbPost.seriesContext}
      seriesPosts={dbSeriesPostsForSidebar}
      commentsData={commentsData}
    >
      <div set:html={dbPostHtml} />
    </BlogPost>
  ) : (
    <BaseLayout
      title="게시글을 찾을 수 없습니다"
      description="삭제되었거나 비공개로 전환된 글일 수 있습니다."
    >
      <section class="flex justify-center py-8 sm:py-12">
        <EmptyStateNotice
          title="게시글을 찾을 수 없습니다"
          description="삭제되었거나 비공개로 전환된 글일 수 있습니다."
          href="/blog"
          actionLabel="블로그로 돌아가기"
        />
      </section>
    </BaseLayout>
  )
}
