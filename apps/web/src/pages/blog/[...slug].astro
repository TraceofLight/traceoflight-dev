---
import { render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../layouts/BlogPost.astro';
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from '../../lib/admin-auth';
import { getPublishedDbPostBySlug, renderDbMarkdown } from '../../lib/blog-db';
import { getBlogSource, getContentProvider } from '../../lib/content-source';

const slug = Astro.params.slug ?? '';
const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? '';
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
const markdownPost = provider === 'file' ? await getBlogSource().getPostBySlug(slug) : null;
let dbPost: Awaited<ReturnType<typeof getPublishedDbPostBySlug>> = null;

if (provider === 'db') {
  try {
    dbPost = await getPublishedDbPostBySlug(slug, { includePrivate: isAdminViewer });
  } catch {
    dbPost = null;
  }
}

let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
let dbPostHtml: string | null = null;

if (markdownPost) {
  ({ Content } = await render(markdownPost));
} else if (dbPost) {
  dbPostHtml = renderDbMarkdown(dbPost.bodyMarkdown);
} else {
  Astro.response.status = 404;
}
---

{
  markdownPost && Content ? (
    <BlogPost {...markdownPost.data} showAdminActions={false}>
      <Content />
    </BlogPost>
  ) : dbPost && dbPostHtml ? (
    <BlogPost
      title={dbPost.title}
      description={dbPost.description}
      pubDate={dbPost.publishedAt}
      updatedDate={dbPost.updatedAt}
      heroImage={dbPost.coverImageUrl}
      adminPostSlug={dbPost.slug}
      showAdminActions={isAdminViewer}
    >
      <div set:html={dbPostHtml} />
    </BlogPost>
  ) : (
    <BaseLayout title="Lorem ipsum" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit.">
      <section class="section">
        <div class="empty-state">
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
          <a class="button" href="/blog">Lorem ipsum</a>
        </div>
      </section>
    </BaseLayout>
  )
}
