---
import { SITE_TITLE } from "../../consts";
import PostAdminActions from "../../components/public/PostAdminActions";
import SeriesAdminPanel from "../../components/public/SeriesAdminPanel";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import { getPublishedDbProjectBySlug } from "../../lib/projects";
import { normalizeCoverMedia } from "../../lib/cover-media";
import { getSeriesBySlug } from "../../lib/series-db";
import {
  PUBLIC_BADGE_STRONG_CLASS,
  PUBLIC_EMPTY_STATE_CLASS,
  PUBLIC_PANEL_SURFACE_CLASS,
  PUBLIC_SECTION_SURFACE_CLASS,
  PUBLIC_SURFACE_ACTION_CLASS,
} from "../../lib/ui-effects";
import { toYoutubeEmbedUrl } from "../../lib/youtube";

const slug = Astro.params.slug ?? "";
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
const project = await getPublishedDbProjectBySlug(slug);
const projectProfile = project
  ? {
      role: project.role,
      period: project.period,
      highlights: project.highlights,
      links: project.links,
    }
  : null;
const relatedSeriesSlug = project?.seriesTitle
  ? project.seriesTitle
      .trim()
      .split("")
      .reduce(
        (state, char) => {
          if (/[\p{L}\p{N}]/u.test(char)) {
            state.chars.push(char);
            state.lastWasDash = false;
            return state;
          }
          if (!state.lastWasDash) {
            state.chars.push("-");
            state.lastWasDash = true;
          }
          return state;
        },
        { chars: [] as string[], lastWasDash: false },
      )
      .chars.join("")
      .replace(/^-+|-+$/g, "") || "series"
  : null;
const relatedSeries = relatedSeriesSlug
  ? await getSeriesBySlug(relatedSeriesSlug, { includePrivate: isAdminViewer }).catch(
      () => null,
    )
  : null;
const adminSeries = relatedSeries
  ? {
      slug: relatedSeries.slug,
      title: relatedSeries.title,
      description: relatedSeries.description,
      coverImageUrl: relatedSeries.coverImageUrl ?? "",
      defaultCoverImage: "/images/empty-series-image.png",
      posts: relatedSeries.posts
        .filter((post) => post.slug !== project?.slug)
        .map((post) => ({
          slug: post.slug,
          title: post.title,
          excerpt: post.excerpt,
          coverImageUrl: post.coverImageUrl ?? "",
          orderIndex: post.orderIndex,
        })),
    }
  : null;
const youtubeEmbedUrl =
  project?.detailMediaKind === "youtube"
    ? toYoutubeEmbedUrl(project.youtubeUrl)
    : null;

if (!project) {
  Astro.response.status = 404;
}
---

{
  project ? (
    <BaseLayout
      title={`${project.title} | Projects | ${SITE_TITLE}`}
      description={project.summary}
    >
      <section class="mx-auto flex max-w-5xl flex-col gap-8 py-10 sm:py-12">
        <nav class="flex flex-wrap items-center justify-between gap-3" aria-label="Project navigation">
          <a
            class={PUBLIC_SURFACE_ACTION_CLASS}
            href="/projects"
          >
            <span aria-hidden="true">‹</span>
            <span>프로젝트로 돌아가기</span>
          </a>
          {
            isAdminViewer && (
              <PostAdminActions client:load adminPostSlug={project.slug} />
            )
          }
        </nav>

        <header class={`grid gap-8 p-6 lg:grid-cols-[minmax(0,1.1fr)_320px] lg:p-8 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          <div class="space-y-5">
            <div class="space-y-4">
              <p class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
                PROJECT DETAIL
              </p>
              <h1 class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
                {project.title}
              </h1>
              <p class="max-w-2xl text-base text-muted-foreground sm:text-lg">
                {project.summary}
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              {project.stack.map((skill) => (
                <span class={PUBLIC_BADGE_STRONG_CLASS}>
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <div class={`rounded-3xl bg-white/88 p-5 ${PUBLIC_PANEL_SURFACE_CLASS}`}>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              프로젝트 역할
            </h2>
            <p class="mt-4 text-base leading-8 text-foreground/85">
              {projectProfile?.role}
            </p>
            <p class="mt-2 text-sm text-muted-foreground">{projectProfile?.period}</p>
          </div>
        </header>

        {isAdminViewer && adminSeries ? (
          <SeriesAdminPanel client:load series={adminSeries} />
        ) : null}

        <div class={`overflow-hidden ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          {
            youtubeEmbedUrl ? (
              <iframe
                class="aspect-[16/9] h-full w-full"
                src={youtubeEmbedUrl}
                title={project.title}
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            ) : (
              <img
                alt={project.title}
                class="aspect-[16/9] h-full w-full object-cover"
                height={780}
                loading="lazy"
                src={project.detailImageUrl ?? project.coverImageUrl ?? "/images/empty-series-image.png"}
                width={1400}
              />
            )
          }
        </div>

        <section class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
          <article class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
            <div class="mt-4 text-base leading-8 text-foreground/85" set:html={project.description} />
          </article>

          <article class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
              주요 항목
            </h2>
            <ul class="mt-4 grid gap-3 text-sm leading-7 text-muted-foreground">
              {projectProfile?.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        </section>

        <section class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          <div class="flex flex-wrap gap-3">
            {projectProfile?.links.map((link) => {
              const isExternal = /^https?:\/\//.test(link.href);
              return (
                <a
                  class={PUBLIC_SURFACE_ACTION_CLASS}
                  href={link.href}
                  rel={isExternal ? "noreferrer" : undefined}
                  target={isExternal ? "_blank" : undefined}
                >
                  {link.label}
                </a>
              );
            })}
          </div>
        </section>

        {
          project.relatedSeriesPosts.length > 0 && (
            <section class={`rounded-3xl p-6 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
                  RELATED SERIES
                </p>
                <h2 class="text-2xl font-semibold tracking-tight text-foreground">
                  연관된 포스팅 시리즈
                </h2>
              </div>
              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {project.relatedSeriesPosts.map((post) => (
                  <PostCard
                    post={{
                      slug: post.slug,
                      title: post.title,
                      description: post.excerpt,
                      pubDate: post.publishedAt ?? new Date(),
                      coverMedia: normalizeCoverMedia(post.coverImageUrl),
                      body: post.excerpt,
                      tags: [],
                      visibility: post.visibility,
                    }}
                  />
                ))}
              </div>
            </section>
          )
        }

        <nav class="flex justify-center" aria-label="Projects archive">
          <a
            class={PUBLIC_SURFACE_ACTION_CLASS}
            href="/projects"
          >
            <span aria-hidden="true">☰</span>
            <span>모든 프로젝트 보기</span>
          </a>
        </nav>
      </section>
    </BaseLayout>
  ) : (
    <BaseLayout
      title={`프로젝트를 찾을 수 없습니다 | ${SITE_TITLE}`}
      description="요청한 프로젝트를 찾을 수 없습니다."
    >
      <section class="mx-auto flex max-w-3xl flex-col gap-6 py-16">
        <div class={`${PUBLIC_EMPTY_STATE_CLASS} px-6 py-12 text-center`}>
          <p class="text-base text-muted-foreground">
            요청한 프로젝트를 찾을 수 없습니다.
          </p>
          <a
            class={`${PUBLIC_SURFACE_ACTION_CLASS} mt-5`}
            href="/projects"
          >
            프로젝트 목록으로 돌아가기
          </a>
        </div>
      </section>
    </BaseLayout>
  )
}
