---
import ProjectCard from "../../components/ProjectCard.astro";
import { SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/projects";

const projects = getProjects();
---

<BaseLayout
  title={`Projects | ${SITE_TITLE}`}
  description="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
>
  <section class="mx-auto flex max-w-6xl flex-col gap-8 py-10 sm:py-12">
    <header class="rounded-[2.25rem] border border-white/80 bg-white/92 p-6 shadow-[0_24px_60px_rgba(15,23,42,0.08)] lg:p-8">
      <div class="space-y-4">
        <h1
          class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
        >
          Lorem ipsum dolor sit amet
        </h1>
        <p class="max-w-2xl text-base text-muted-foreground sm:text-lg">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>
      </div>
    </header>

    <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
  </section>
</BaseLayout>
