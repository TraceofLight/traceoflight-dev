---
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import { toBrowserImageUrl } from "../../lib/cover-media";
import { listSeries } from "../../lib/series-db";

const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
const defaultSeriesCoverImage = "/images/empty-series-image.png";
const defaultSeriesCoverImageSrc = toBrowserImageUrl(defaultSeriesCoverImage, {
  width: 960,
  height: 600,
});

let series: Awaited<ReturnType<typeof listSeries>> = [];
try {
  series = await listSeries({ includePrivate: isAdminViewer, limit: 100 });
} catch {
  series = [];
}
---

<BaseLayout
  title={`Series | ${SITE_TITLE}`}
  description="TraceofLight series archive"
>
  <section
    id="series-archive"
    class="mx-auto flex max-w-6xl flex-col gap-8 py-10 sm:py-12"
  >
    <header
      class="rounded-[2.25rem] border border-white/80 bg-white/92 p-6 shadow-[0_24px_60px_rgba(15,23,42,0.08)] lg:p-8"
    >
      <div class="space-y-4">
        <h1
          class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
        >
          Series
        </h1>
        <p class="max-w-2xl text-base text-muted-foreground sm:text-lg">
          TraceofLightмЭШ лЛ§мЦСнХЬ мЭімХЉкЄ∞л•Љ м£Љм†Ьл≥Дл°Ь мЧЃмЭА мДЬк≥†
        </p>
      </div>
    </header>

    {
      series.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {series.map((series) => (
            <article class="group h-full">
              <a
                class="flex h-full flex-col overflow-hidden rounded-3xl border border-white/80 bg-white/92 text-card-foreground shadow-[0_24px_60px_rgba(15,23,42,0.08)] transition duration-300 hover:-translate-y-1.5 hover:bg-white hover:shadow-[0_32px_80px_rgba(15,23,42,0.12)]"
                href={`/series/${series.slug}`}
              >
                <div class="aspect-[16/10] overflow-hidden border-b border-white/80 bg-slate-100/90">
                  <img
                    alt={series.title}
                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                    loading="lazy"
                    src={series.coverImageUrl ?? defaultSeriesCoverImageSrc}
                  />
                </div>
                <div class="flex flex-1 flex-col gap-4 p-5">
                  <div class="space-y-2">
                    <h2 class="text-xl font-semibold tracking-tight text-foreground">
                      {series.title}
                    </h2>
                    <p class="line-clamp-3 text-sm text-muted-foreground">
                      {series.description}
                    </p>
                  </div>
                  <p class="mt-auto flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                    <span>{series.postCount} posts</span>
                    <span aria-hidden="true">вАҐ</span>
                    <FormattedDate date={series.updatedAt} />
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="rounded-3xl border border-dashed border-white/80 bg-white/84 px-6 py-10 text-center text-sm text-muted-foreground shadow-[0_18px_48px_rgba(15,23,42,0.06)]">
          мХДмІБ лУ±л°ЭлРЬ мЛЬл¶ђм¶Ик∞А мЧЖмКµлЛИлЛ§.
        </div>
      )
    }
  </section>
</BaseLayout>
