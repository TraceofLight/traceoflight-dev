---
import SeriesAdminPanel from "../../components/public/SeriesAdminPanel";
import { SITE_TITLE } from "../../consts";
import FormattedDate from "../../components/FormattedDate.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../../lib/admin-auth";
import {
  buildImageFallbackOnError,
  toBrowserImageUrl,
} from "../../lib/cover-media";
import { getSeriesBySlug } from "../../lib/series-db";
import {
  PUBLIC_EMPTY_STATE_CLASS,
  PUBLIC_PANEL_SURFACE_CLASS,
  PUBLIC_SECTION_SURFACE_CLASS,
  PUBLIC_SURFACE_ACTION_CLASS,
} from "../../lib/ui-effects";

const slug = Astro.params.slug ?? "";
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
const defaultSeriesCoverImage = "/images/empty-series-image.png";
const defaultSeriesPostCoverImage = "/images/empty-series-image.png";
const defaultSeriesCoverImageSrc = toBrowserImageUrl(defaultSeriesCoverImage, {
  width: 960,
  height: 720,
  fit: "cover",
});
const defaultSeriesPostCoverImageSrc = toBrowserImageUrl(defaultSeriesPostCoverImage, {
  width: 224,
  height: 126,
  fit: "cover",
});
const seriesCoverImageFallbackOnError = buildImageFallbackOnError(defaultSeriesCoverImageSrc);
const seriesPostCoverImageFallbackOnError = buildImageFallbackOnError(defaultSeriesPostCoverImageSrc);

let series = null;
try {
  series = await getSeriesBySlug(slug, { includePrivate: isAdminViewer });
} catch {
  series = null;
}

if (!series) {
  Astro.response.status = 404;
}

const resolvedSeriesCoverImageSrc = series?.coverImageUrl
  ? toBrowserImageUrl(series.coverImageUrl, {
      width: 960,
      height: 720,
    })
  : defaultSeriesCoverImageSrc;

const adminSeries = series
  ? {
      slug: series.slug,
      title: series.title,
      description: series.description,
      coverImageUrl: series.coverImageUrl ?? "",
      defaultCoverImage: defaultSeriesCoverImage,
      posts: series.posts.map((post) => ({
        slug: post.slug,
        title: post.title,
        excerpt: post.excerpt,
        coverImageUrl: post.coverImageUrl ?? "",
        orderIndex: post.orderIndex,
      })),
    }
  : null;
---

<BaseLayout
  title={series
    ? `${series.title} | Series | ${SITE_TITLE}`
    : `Series | ${SITE_TITLE}`}
  description={series?.description ?? "Series not found"}
>
  {
    series ? (
      <section class="mx-auto flex max-w-6xl flex-col gap-8 py-10 sm:py-12">
        <header class={`grid gap-8 p-6 lg:grid-cols-[minmax(0,1.1fr)_320px] lg:p-8 ${PUBLIC_SECTION_SURFACE_CLASS}`}>
          <div class="space-y-6">
            <div class="space-y-4">
              <p class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
                SERIES
              </p>
              <h1 class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
                {series.title}
              </h1>
              <p
                id="series-summary-text"
                class="max-w-2xl text-base text-muted-foreground sm:text-lg"
              >
                {series.description}
              </p>
            </div>

            <p class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
              <span>{series.postCount} posts</span>
              <span aria-hidden="true">•</span>
              <FormattedDate date={series.updatedAt} />
            </p>

            {series.posts.length > 0 && (
              <a
                id="series-start-link"
                class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground transition hover:opacity-90"
                href={`/blog/${series.posts[0].slug}`}
              >
                <span aria-hidden="true">↗</span>
                <span>시리즈 시작하기</span>
              </a>
            )}
          </div>

          <div class="overflow-hidden rounded-3xl border border-white/80 bg-slate-100/92 shadow-[0_24px_60px_rgba(15,23,42,0.08)]">
            <img
              id="series-cover-image"
              alt={series.title}
              class="aspect-[4/3] h-full w-full object-cover"
              data-default-cover={defaultSeriesCoverImage}
              decoding="async"
              loading="lazy"
              onerror={seriesCoverImageFallbackOnError}
              src={resolvedSeriesCoverImageSrc}
            />
          </div>
        </header>

        {isAdminViewer && (
          <SeriesAdminPanel client:load series={adminSeries!} />
        )}

        {!isAdminViewer &&
          (series.posts.length > 0 ? (
            <ol id="series-post-list" class="grid gap-3">
                {series.posts.map((post, index) => (
                  (() => {
                    const resolvedSeriesPostCoverImageSrc = post.coverImageUrl
                      ? toBrowserImageUrl(post.coverImageUrl, {
                          width: 224,
                          height: 126,
                        })
                      : defaultSeriesPostCoverImageSrc;

                    return (
                      <li
                        class={`p-3 ${PUBLIC_PANEL_SURFACE_CLASS}`}
                        data-post-slug={post.slug}
                        data-series-order={post.orderIndex}
                      >
                        <a
                          class="group grid gap-3 sm:grid-cols-[40px_minmax(0,1fr)_112px] sm:items-center"
                          href={`/blog/${post.slug}`}
                        >
                          <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/80 bg-white text-sm font-semibold text-foreground shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
                            {index + 1}
                          </span>
                          <span class="min-w-0 space-y-1">
                            <strong class="block truncate text-sm font-semibold text-foreground">
                              {post.title}
                            </strong>
                            <em class="line-clamp-2 text-sm not-italic text-muted-foreground">
                              {post.excerpt.trim().length > 0
                                ? post.excerpt
                                : "요약 없음"}
                            </em>
                          </span>
                          <img
                            alt={post.title}
                            class="aspect-[16/9] w-full rounded-xl border border-white/80 bg-slate-100/90 object-cover"
                            decoding="async"
                            loading="lazy"
                            onerror={seriesPostCoverImageFallbackOnError}
                            src={resolvedSeriesPostCoverImageSrc}
                          />
                        </a>
                      </li>
                    );
                  })()
              ))}
            </ol>
          ) : (
            <section class={`${PUBLIC_EMPTY_STATE_CLASS} px-6 py-10 text-center text-sm text-muted-foreground`}>
              아직 시리즈에 포함된 글이 없습니다.
            </section>
          ))}

        <nav class="flex justify-center" aria-label="Series archive">
          <a
            class={PUBLIC_SURFACE_ACTION_CLASS}
            href="/series"
          >
            <span aria-hidden="true">☰</span>
            <span>모든 시리즈 보기</span>
          </a>
        </nav>
      </section>
    ) : (
      <section class="mx-auto flex max-w-3xl flex-col gap-6 py-16">
        <div class={`${PUBLIC_EMPTY_STATE_CLASS} px-6 py-12 text-center`}>
          <p class="text-base text-muted-foreground">
            시리즈를 찾을 수 없습니다.
          </p>
          <a
            class={`${PUBLIC_SURFACE_ACTION_CLASS} mt-5`}
            href="/series"
          >
            시리즈 목록
          </a>
        </div>
      </section>
    )
  }
</BaseLayout>
