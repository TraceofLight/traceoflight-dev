---
import { Image } from "astro:assets";

import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import profileImage from "../assets/traceoflight-profile.png";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";
import { listPublishedDbPosts } from "../lib/blog-db";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import {
  getBlogSource,
  getContentProvider,
  toPostCard,
  type PostCard as PostCardData,
} from "../lib/content-source";
import { formatDateLabel, toIsoDateTime } from "../lib/format-date";
import { getProjects } from "../lib/projects";
import { getSeriesBySlug, listSeries } from "../lib/series-db";

const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
let posts: PostCardData[] = [];
if (provider === "db") {
  try {
    const dbPosts = await listPublishedDbPosts(3, {
      includePrivate: isAdminViewer,
    });
    posts = dbPosts.map((post) => ({
      slug: post.slug,
      title: post.title,
      description: post.description,
      body: post.bodyMarkdown,
      pubDate: post.publishedAt,
      updatedDate: post.updatedAt,
      heroMedia: post.heroMedia,
      visibility: post.visibility,
      tags: post.tags.map((tag) => tag.slug),
    }));
  } catch {
    posts = [];
  }
} else {
  posts = (await getBlogSource().listPosts()).slice(0, 3).map(toPostCard);
}
const projects = getProjects().slice(0, 3);
const defaultSeriesCoverImage = "/images/empty-series-image.png";
const sectionShellClass =
  "rounded-3xl border border-border/60 bg-card p-6 shadow-sm";
const pillClass =
  "inline-flex items-center gap-2 rounded-full border border-border/60 bg-background px-3.5 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground";

const profile = {
  name: "Hi there, I'm TraceofLight!",
};

type ResumeBadge = {
  label: string;
  icon: string;
};

type ResumeItem = {
  main: string;
  period?: string;
  sub?: string;
  badges?: ResumeBadge[];
};

type ResumeSection = {
  title: string;
  items: ResumeItem[];
};

type ResumeDisplay = {
  period?: string;
  text: string;
};

type TechStackItem =
  | {
      divider: true;
    }
  | {
      label: string;
      icon?: string;
      fallback?: string;
    };

type TechStackGroup = {
  title: string;
  items: TechStackItem[];
};

const inferResumePeriod = (main: string): ResumeDisplay => {
  const value = main.trim();
  const rangeMatch = value.match(
    /^(\d{4}\.\d{2}\.\s*~\s*\d{4}\.\d{2}\.)\s*(.+)$/u,
  );
  if (rangeMatch) {
    return { period: rangeMatch[1], text: rangeMatch[2] };
  }
  const monthMatch = value.match(/^(\d{4}\.\d{2}\.)\s*(.+)$/u);
  if (monthMatch) {
    return { period: monthMatch[1], text: monthMatch[2] };
  }
  const yearMatch = value.match(/^(\d{4})\s+(.+)$/u);
  if (yearMatch) {
    return { period: yearMatch[1], text: yearMatch[2] };
  }
  return { text: main };
};

const toResumeDisplay = (item: ResumeItem): ResumeDisplay => {
  if (item.period) {
    return { period: item.period, text: item.main };
  }
  return inferResumePeriod(item.main);
};

const heroRoleTokens = [
  "Game Development",
  "Graphics Programming",
  "Database Engineering",
];

const longIntroTop =
  "상상을 현실로, 가상 세계에 생동감을 불어넣는 개발자 TraceofLight입니다.";
const longIntroBottom =
  "위로는 새로운 기술에 대한 호기심, 아래로는 기반 지식에 대한 꾸준한 탐구를 바탕으로 성장 중입니다.";

const resumeLeftSections: ResumeSection[] = [
  {
    title: "Education",
    items: [
      { main: "2026.02. 크래프톤 정글 게임테크랩 2기 수료" },
      { main: "2023.08. 삼성 청년 SW 아카데미 8기 수료" },
      { main: "2022.08. 연세대학교 도시공학과 졸업" },
    ],
  },
  {
    title: "License",
    items: [{ main: "2022.12. SQL 개발자" }],
  },
  {
    title: "Military Service",
    items: [{ main: "2017.06. ~ 2019.05. 공군 병장 만기전역" }],
  },
];

const resumeRightSections: ResumeSection[] = [
  {
    title: "Career",
    items: [{ main: "2023.10. ~ 2024.11. 티맥스티베로 DB본부 연구원" }],
  },
  {
    title: "Experience",
    items: [
      {
        period: "2023.10. ~ 2024.11.",
        main: "Cloud-Native 차세대 DB 개발 프로젝트 참여",
        badges: [
          { label: "C++", icon: "/icons/tech/cplusplus.svg" },
          { label: "Shellscript", icon: "/icons/tech/gnubash.svg" },
          { label: "Vim", icon: "/icons/tech/vim.svg" },
        ],
      },
    ],
  },
  {
    title: "Award",
    items: [
      {
        main: "2021.11. 도시공학과 종합설계 작품전 우수작품상",
        sub: "미래 모빌리티와 연계한 고양시 발전방향 기획안\n: 성남시와 비교 분석",
      },
    ],
  },
];

const techStackGroups: TechStackGroup[] = [
  {
    title: "Language",
    items: [
      { label: "C++", icon: "/icons/tech/cplusplus.svg" },
      { label: "HLSL", fallback: "HLSL" },
      { label: "Shellscript", icon: "/icons/tech/gnubash.svg" },
      { label: "Java", icon: "/icons/tech/java.svg" },
      { label: "Python", icon: "/icons/tech/python.svg" },
      { label: "SQL", icon: "/icons/tech/sql.svg" },
    ],
  },
  {
    title: "Game Development",
    items: [
      { label: "DirectX 11", icon: "/icons/tech/directx11.webp" },
      { label: "Unreal Engine 5", icon: "/icons/tech/unrealengine.svg" },
    ],
  },
  {
    title: "SCM",
    items: [
      { label: "Git", icon: "/icons/tech/git.svg" },
      { label: "Perforce", icon: "/icons/tech/perforce.svg" },
    ],
  },
  {
    title: "Web",
    items: [
      { label: "FastAPI", icon: "/icons/tech/fastapi.svg" },
      { label: "Spring Boot", icon: "/icons/tech/springboot.svg" },
      { divider: true },
      { label: "React", icon: "/icons/tech/react.svg" },
    ],
  },
];

type FeaturedSeriesCard = {
  slug: string;
  title: string;
  summary: string;
  postCount: number;
  latestPostAt: Date;
  coverImageUrl?: string;
};

const featuredSeriesCards: FeaturedSeriesCard[] =
  provider === "db"
    ? await (async () => {
        try {
          const seriesList = await listSeries({
            includePrivate: isAdminViewer,
            limit: 100,
          });
          const detailRows = await Promise.all(
            seriesList.map(async (series) => {
              const detail = await getSeriesBySlug(series.slug, {
                includePrivate: isAdminViewer,
              }).catch(() => null);
              if (!detail) {
                return null;
              }

              const latestPostAt = detail.posts.reduce<Date>((latest, post) => {
                const candidate = post.publishedAt ?? series.updatedAt;
                return candidate.getTime() > latest.getTime()
                  ? candidate
                  : latest;
              }, series.updatedAt);

              return {
                slug: series.slug,
                title: series.title,
                summary: series.description,
                postCount: detail.postCount,
                latestPostAt,
                coverImageUrl: series.coverImageUrl,
              } satisfies FeaturedSeriesCard;
            }),
          );

          return detailRows
            .filter((row): row is FeaturedSeriesCard => row !== null)
            .sort((a, b) => b.latestPostAt.getTime() - a.latestPostAt.getTime())
            .slice(0, 3);
        } catch {
          return [];
        }
      })()
    : [];

const connectLinks = [
  { label: "GitHub", href: "https://github.com/TraceofLight", external: true },
  { label: "Email", href: "mailto:rickyjun96@gmail.com", external: false },
  { label: "Resume PDF", href: "/resume.pdf", external: false },
  { label: "Blog", href: "/blog", external: false },
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="mx-auto flex max-w-6xl flex-col gap-8 py-10 sm:py-12">
    <section
      class="grid gap-8 rounded-[2rem] border border-border/60 bg-card p-6 shadow-sm lg:grid-cols-[minmax(0,1.2fr)_280px] lg:p-8"
      aria-labelledby="home-profile-title"
    >
      <div class="space-y-6">
        <div class="space-y-4">
          <p class={pillClass}>About Me</p>
          <h1
            id="home-profile-title"
            class="text-balance text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
          >
            {profile.name}
          </h1>
          <div class="space-y-3 text-base text-muted-foreground sm:text-lg">
            <p>{longIntroTop}</p>
            <p>{longIntroBottom}</p>
          </div>
        </div>

        <ul class="flex flex-wrap gap-3">
          {heroRoleTokens.map((role) => <li class={pillClass}>{role}</li>)}
        </ul>

        <div class="flex flex-wrap gap-3">
          <a
            class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground transition hover:opacity-90"
            href="/projects"
          >
            프로젝트 보기
          </a>
          <a
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-5 py-2.5 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-foreground"
            href="/blog"
          >
            블로그 보기
          </a>
        </div>
      </div>

      <div class="flex items-center justify-center">
        <div
          class="overflow-hidden rounded-[2rem] border border-border/60 bg-muted shadow-sm"
        >
          <Image
            src={profileImage}
            alt=""
            width={320}
            height={320}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </section>

    <section
      id="home-experience-education"
      class={sectionShellClass}
      aria-labelledby="home-experience-heading"
    >
      <div class="space-y-2">
        <h2
          id="home-experience-heading"
          class="text-2xl font-semibold tracking-tight text-foreground"
        >
          Profile
        </h2>
      </div>

      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <div class="grid gap-4">
          {
            resumeLeftSections.map((section) => (
              <article class="rounded-2xl border border-border/60 bg-background/70 p-5">
                <h3 class="text-lg font-semibold tracking-tight text-foreground">
                  {section.title}
                </h3>
                <ul class="mt-4 grid gap-4">
                  {section.items.map((item) => {
                    const display = toResumeDisplay(item);
                    return (
                      <li class="space-y-3">
                        {display.period ? (
                          <div class="grid gap-1 sm:grid-cols-[136px_minmax(0,1fr)] sm:items-start sm:gap-3">
                            <p class="text-sm font-medium text-foreground">
                              {display.period}
                            </p>
                            <div class="space-y-1">
                              <p class="text-sm leading-7 text-muted-foreground">
                                {display.text}
                              </p>
                              {item.sub ? (
                                <p class="whitespace-pre-line text-sm leading-7 text-muted-foreground">
                                  {item.sub}
                                </p>
                              ) : null}
                            </div>
                          </div>
                        ) : (
                          <div class="space-y-1">
                            <p class="text-sm leading-7 text-muted-foreground">
                              {display.text}
                            </p>
                            {item.sub ? (
                              <p class="whitespace-pre-line text-sm leading-7 text-muted-foreground">
                                {item.sub}
                              </p>
                            ) : null}
                          </div>
                        )}
                        {item.badges?.length ? (
                          <ul
                            class="flex flex-wrap gap-2"
                            aria-label="Experience stack"
                          >
                            {item.badges.map((badge) => (
                              <li class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-card px-2.5 py-1 text-xs text-muted-foreground">
                                <img
                                  src={badge.icon}
                                  alt=""
                                  loading="lazy"
                                  width="14"
                                  height="14"
                                />
                                <span>{badge.label}</span>
                              </li>
                            ))}
                          </ul>
                        ) : null}
                      </li>
                    );
                  })}
                </ul>
              </article>
            ))
          }
        </div>

        <div class="grid gap-4">
          {
            resumeRightSections.map((section) => (
              <article class="rounded-2xl border border-border/60 bg-background/70 p-5">
                <h3 class="text-lg font-semibold tracking-tight text-foreground">
                  {section.title}
                </h3>
                <ul class="mt-4 grid gap-4">
                  {section.items.map((item) => {
                    const display = toResumeDisplay(item);
                    return (
                      <li class="space-y-3">
                        {display.period ? (
                          <div class="grid gap-1 sm:grid-cols-[136px_minmax(0,1fr)] sm:items-start sm:gap-3">
                            <p class="text-sm font-medium text-foreground">
                              {display.period}
                            </p>
                            <div class="space-y-1">
                              <p class="text-sm leading-7 text-muted-foreground">
                                {display.text}
                              </p>
                              {item.sub ? (
                                <p class="whitespace-pre-line text-sm leading-7 text-muted-foreground">
                                  {item.sub}
                                </p>
                              ) : null}
                            </div>
                          </div>
                        ) : (
                          <div class="space-y-1">
                            <p class="text-sm leading-7 text-muted-foreground">
                              {display.text}
                            </p>
                            {item.sub ? (
                              <p class="whitespace-pre-line text-sm leading-7 text-muted-foreground">
                                {item.sub}
                              </p>
                            ) : null}
                          </div>
                        )}
                        {item.badges?.length ? (
                          <ul
                            class="flex flex-wrap gap-2"
                            aria-label="Experience stack"
                          >
                            {item.badges.map((badge) => (
                              <li class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-card px-2.5 py-1 text-xs text-muted-foreground">
                                <img
                                  src={badge.icon}
                                  alt=""
                                  loading="lazy"
                                  width="14"
                                  height="14"
                                />
                                <span>{badge.label}</span>
                              </li>
                            ))}
                          </ul>
                        ) : null}
                      </li>
                    );
                  })}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="home-tech-stack"
      class={sectionShellClass}
      aria-labelledby="home-tech-heading"
    >
      <div class="space-y-2">
        <h2
          id="home-tech-heading"
          class="text-2xl font-semibold tracking-tight text-foreground"
        >
          Skill
        </h2>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {
          techStackGroups.map((group) => (
            <article class="rounded-2xl border border-border/60 bg-background/70 p-5">
              <h3 class="text-lg font-semibold tracking-tight text-foreground">
                {group.title}
              </h3>
              <ul class="mt-4 flex flex-wrap gap-2">
                {group.items.map((item) =>
                  "divider" in item ? (
                    <li
                      class="mx-1 hidden h-6 w-px self-center bg-border sm:block"
                      role="separator"
                      aria-hidden="true"
                    />
                  ) : (
                    <li class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-card px-3 py-1.5 text-xs font-medium text-muted-foreground">
                      {item.icon ? (
                        <img
                          src={item.icon}
                          alt={`${item.label} logo`}
                          loading="lazy"
                          width="18"
                          height="18"
                        />
                      ) : (
                        <span aria-hidden="true">{item.fallback}</span>
                      )}
                      <span>{item.label}</span>
                    </li>
                  ),
                )}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section
      id="home-featured-projects"
      class={sectionShellClass}
      aria-labelledby="home-projects-heading"
    >
      <div class="flex flex-wrap items-end justify-between gap-3">
        <h2
          id="home-projects-heading"
          class="text-2xl font-semibold tracking-tight text-foreground"
        >
          Featured Projects
        </h2>
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-foreground"
          href="/projects"
        >
          View All Projects
        </a>
      </div>

      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          projects.map((project) => (
            <ProjectCard
              project={project}
              imageWidth={960}
              imageHeight={540}
              stackLimit={3}
            />
          ))
        }
      </div>
    </section>

    <section
      id="home-featured-series"
      class={sectionShellClass}
      aria-labelledby="home-series-heading"
    >
      <div class="flex flex-wrap items-end justify-between gap-3">
        <h2
          id="home-series-heading"
          class="text-2xl font-semibold tracking-tight text-foreground"
        >
          Featured Series
        </h2>
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-foreground"
          href="/series"
        >
          View All Series
        </a>
      </div>

      {
        featuredSeriesCards.length > 0 ? (
          <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {featuredSeriesCards.map((card) => (
              <article class="group h-full">
                <a
                  class="flex h-full flex-col overflow-hidden rounded-3xl border border-border/60 bg-card text-card-foreground shadow-sm transition hover:-translate-y-1 hover:border-foreground/15 hover:shadow-lg"
                  href={`/series/${card.slug}`}
                >
                  <div class="aspect-[16/10] overflow-hidden border-b border-border/60 bg-muted">
                    <img
                      src={card.coverImageUrl ?? defaultSeriesCoverImage}
                      alt={card.title}
                      loading="lazy"
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                    />
                  </div>
                  <div class="flex flex-1 flex-col gap-4 p-5">
                    <div class="space-y-2">
                      <h3 class="text-xl font-semibold tracking-tight text-foreground">
                        {card.title}
                      </h3>
                      <p class="line-clamp-3 text-sm text-muted-foreground">
                        {card.summary}
                      </p>
                    </div>
                    <p class="mt-auto flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                      <span>{card.postCount} posts</span>
                      <span aria-hidden="true">•</span>
                      <time datetime={toIsoDateTime(card.latestPostAt)}>
                        {formatDateLabel(card.latestPostAt)}
                      </time>
                    </p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="mt-6 rounded-3xl border border-dashed border-border/60 bg-background/70 px-6 py-10 text-center text-sm text-muted-foreground">
            아직 등록된 시리즈가 없습니다.
          </div>
        )
      }
    </section>

    <section
      id="home-latest-posts"
      class={sectionShellClass}
      aria-labelledby="home-posts-heading"
    >
      <div class="flex flex-wrap items-end justify-between gap-3">
        <h2
          id="home-posts-heading"
          class="text-2xl font-semibold tracking-tight text-foreground"
        >
          Latest Posts
        </h2>
        <a
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-foreground"
          href="/blog"
        >
          View All Posts
        </a>
      </div>

      {
        posts.length > 0 ? (
          <div class="mt-6 grid gap-6 lg:grid-cols-3">
            {posts.map((post) => (
              <PostCard post={post} imageWidth={960} imageHeight={540} />
            ))}
          </div>
        ) : (
          <div class="mt-6 rounded-3xl border border-dashed border-border/60 bg-background/70 px-6 py-10 text-center text-sm text-muted-foreground">
            아직 공개된 글이 없습니다.
          </div>
        )
      }
    </section>

    <section
      id="home-connect"
      class={sectionShellClass}
      aria-labelledby="home-connect-heading"
    >
      <div
        class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.8fr)] lg:items-end"
      >
        <div class="space-y-3">
          <h2
            id="home-connect-heading"
            class="text-2xl font-semibold tracking-tight text-foreground"
          >
            Connect
          </h2>
          <p class="max-w-2xl text-base text-muted-foreground">
            협업이나 프로젝트 문의는 메일로 부탁드립니다. 이력서는 PDF로
            제공됩니다.
          </p>
        </div>

        <div class="flex flex-wrap gap-3 lg:justify-end">
          {
            connectLinks.map((link) => (
              <a
                class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-foreground"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
