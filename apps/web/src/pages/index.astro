---
import { Image } from "astro:assets";

import FormattedDate from "../components/FormattedDate.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import profileImage from "../assets/traceoflight-profile.png";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";
import { listPublishedDbPosts } from "../lib/blog-db";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import {
  getBlogSource,
  getContentProvider,
  toPostCard,
  type PostCard as PostCardData,
} from "../lib/content-source";
import { getProjects } from "../lib/projects";
import { getSeriesBySlug, listSeries } from "../lib/series-db";
import "../styles/components/home.css";

const provider = getContentProvider();
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
let posts: PostCardData[] = [];
if (provider === "db") {
  try {
    const dbPosts = await listPublishedDbPosts(3, {
      includePrivate: isAdminViewer,
    });
    posts = dbPosts.map((post) => ({
      slug: post.slug,
      title: post.title,
      description: post.description,
      body: post.bodyMarkdown,
      pubDate: post.publishedAt,
      updatedDate: post.updatedAt,
      heroMedia: post.heroMedia,
      visibility: post.visibility,
      tags: post.tags.map((tag) => tag.slug),
    }));
  } catch {
    posts = [];
  }
} else {
  posts = (await getBlogSource().listPosts()).slice(0, 3).map(toPostCard);
}
const projects = getProjects().slice(0, 3);
const defaultSeriesCoverImage = "/images/empty-series-image.png";

const profile = {
  name: "Hi there, I'm TraceofLight!",
};

type ResumeBadge = {
  label: string;
  icon: string;
};

type ResumeItem = {
  main: string;
  period?: string;
  sub?: string;
  badges?: ResumeBadge[];
};

type ResumeSection = {
  title: string;
  items: ResumeItem[];
};

type ResumeDisplay = {
  period?: string;
  text: string;
};

type TechStackItem =
  | {
      divider: true;
    }
  | {
      label: string;
      icon?: string;
      fallback?: string;
    };

type TechStackGroup = {
  title: string;
  items: TechStackItem[];
};

const inferResumePeriod = (main: string): ResumeDisplay => {
  const value = main.trim();
  const rangeMatch = value.match(
    /^(\d{4}\.\d{2}\.\s*~\s*\d{4}\.\d{2}\.)\s*(.+)$/u,
  );
  if (rangeMatch) {
    return { period: rangeMatch[1], text: rangeMatch[2] };
  }
  const monthMatch = value.match(/^(\d{4}\.\d{2}\.)\s*(.+)$/u);
  if (monthMatch) {
    return { period: monthMatch[1], text: monthMatch[2] };
  }
  const yearMatch = value.match(/^(\d{4})\s+(.+)$/u);
  if (yearMatch) {
    return { period: yearMatch[1], text: yearMatch[2] };
  }
  return { text: main };
};

const toResumeDisplay = (item: ResumeItem): ResumeDisplay => {
  if (item.period) {
    return { period: item.period, text: item.main };
  }
  return inferResumePeriod(item.main);
};

const heroRoleTokens = [
  "Game Development",
  "Graphics Programming",
  "Database Engineering",
];

const longIntroTop =
  "상상을 현실로, 가상 세계에 생동감을 불어넣는 개발자 TraceofLight입니다.";
const longIntroBottom =
  "위로는 새로운 기술에 대한 호기심, 아래로는 기반 지식에 대한 꾸준한 탐구를 바탕으로 성장 중입니다.";

const resumeLeftSections: ResumeSection[] = [
  {
    title: "Education",
    items: [
      { main: "2026.02. 크래프톤 정글 게임테크랩 2기 수료" },
      { main: "2023.08. 삼성 청년 SW 아카데미 8기 수료" },
      { main: "2022.08. 연세대학교 도시공학과 졸업" },
    ],
  },
  {
    title: "License",
    items: [{ main: "2022.12. SQL 개발자" }],
  },
  {
    title: "Military Service",
    items: [{ main: "2017.06. ~ 2019.05. 공군 병장 만기전역" }],
  },
];

const resumeRightSections: ResumeSection[] = [
  {
    title: "Career",
    items: [{ main: "2023.10. ~ 2024.11. 티맥스티베로 DB본부 연구원" }],
  },
  {
    title: "Experience",
    items: [
      {
        period: "2023.10. ~ 2024.11.",
        main: "Cloud-Native 차세대 DB 개발 프로젝트 참여",
        badges: [
          { label: "C++", icon: "/icons/tech/cplusplus.svg" },
          { label: "Shellscript", icon: "/icons/tech/gnubash.svg" },
          { label: "Vim", icon: "/icons/tech/vim.svg" },
        ],
      },
    ],
  },
  {
    title: "Award",
    items: [
      {
        main: "2021.11. 도시공학과 종합설계 작품전 우수작품상",
        sub: "미래 모빌리티와 연계한 고양시 발전방향 기획안\n: 성남시와 비교 분석",
      },
    ],
  },
];

const techStackGroups: TechStackGroup[] = [
  {
    title: "Language",
    items: [
      { label: "C++", icon: "/icons/tech/cplusplus.svg" },
      { label: "HLSL", fallback: "HLSL" },
      { label: "Shellscript", icon: "/icons/tech/gnubash.svg" },
      { label: "Java", icon: "/icons/tech/java.svg" },
      { label: "Python", icon: "/icons/tech/python.svg" },
      { label: "SQL", icon: "/icons/tech/sql.svg" },
    ],
  },
  {
    title: "Game Development",
    items: [
      { label: "DirectX 11", icon: "/icons/tech/directx11.webp" },
      { label: "Unreal Engine 5", icon: "/icons/tech/unrealengine.svg" },
    ],
  },
  {
    title: "SCM",
    items: [
      { label: "Git", icon: "/icons/tech/git.svg" },
      { label: "Perforce", icon: "/icons/tech/perforce.svg" },
    ],
  },
  {
    title: "Web",
    items: [
      { label: "FastAPI", icon: "/icons/tech/fastapi.svg" },
      { label: "Spring Boot", icon: "/icons/tech/springboot.svg" },
      { divider: true },
      { label: "React", icon: "/icons/tech/react.svg" },
    ],
  },
];

type FeaturedSeriesCard = {
  slug: string;
  title: string;
  summary: string;
  postCount: number;
  latestPostAt: Date;
  coverImageUrl?: string;
};

const featuredSeriesCards: FeaturedSeriesCard[] = provider === "db"
  ? (
      await (async () => {
        try {
          const seriesList = await listSeries({ includePrivate: isAdminViewer, limit: 100 });
          const detailRows = await Promise.all(
            seriesList.map(async (series) => {
              const detail = await getSeriesBySlug(series.slug, {
                includePrivate: isAdminViewer,
              }).catch(() => null);
              if (!detail) {
                return null;
              }

              const latestPostAt = detail.posts.reduce<Date>((latest, post) => {
                const candidate = post.publishedAt ?? series.updatedAt;
                return candidate.getTime() > latest.getTime() ? candidate : latest;
              }, series.updatedAt);

              return {
                slug: series.slug,
                title: series.title,
                summary: series.description,
                postCount: detail.postCount,
                latestPostAt,
                coverImageUrl: series.coverImageUrl,
              } satisfies FeaturedSeriesCard;
            }),
          );

          return detailRows
            .filter((row): row is FeaturedSeriesCard => row !== null)
            .sort((a, b) => b.latestPostAt.getTime() - a.latestPostAt.getTime())
            .slice(0, 3);
        } catch {
          return [];
        }
      })()
    )
  : [];

const connectLinks = [
  { label: "GitHub", href: "https://github.com/TraceofLight", external: true },
  { label: "Email", href: "mailto:rickyjun96@gmail.com", external: false },
  { label: "Resume PDF", href: "/resume.pdf", external: false },
  { label: "Blog", href: "/blog", external: false },
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="home-resume">
    <section
      class="home-panel home-profile"
      aria-labelledby="home-profile-title"
    >
      <div class="home-profile-content">
        <p class="home-eyebrow">About Me</p>
        <h1 id="home-profile-title">{profile.name}</h1>
        <div class="home-intro-copy">
          <p class="home-long-copy">{longIntroTop}</p>
          <p class="home-long-copy">{longIntroBottom}</p>
        </div>
        <ul class="home-role-list">
          {heroRoleTokens.map((role) => <li>{role}</li>)}
        </ul>
        <div class="home-profile-actions">
          <a class="button" href="/projects">프로젝트 보기</a>
          <a class="button button-ghost" href="/blog">블로그 보기</a>
        </div>
      </div>
      <div class="home-profile-visual" aria-hidden="true">
        <Image
          src={profileImage}
          alt=""
          width={264}
          height={264}
          class="home-profile-icon"
        />
      </div>
    </section>

    <section
      class="home-section"
      id="home-experience-education"
      aria-labelledby="home-experience-heading"
    >
      <div class="home-section-head">
        <h2 id="home-experience-heading">Profile</h2>
      </div>
      <div class="home-resume-grid">
        <div class="home-resume-column">
          {
            resumeLeftSections.map((section) => (
              <article class="home-resume-block">
                <h3>{section.title}</h3>
                <ul>
                  {section.items.map((item) => {
                    const display = toResumeDisplay(item);
                    return (
                      <li>
                        {display.period ? (
                          <div class="home-resume-main-split">
                            <p class="home-resume-main home-resume-period">
                              {display.period}
                            </p>
                            <p class="home-resume-main home-resume-main-text">
                              {display.text}
                            </p>
                            {item.sub ? (
                              <p class="home-resume-sub home-resume-sub-split">
                                {item.sub}
                              </p>
                            ) : null}
                          </div>
                        ) : (
                          <>
                            <p class="home-resume-main">{display.text}</p>
                            {item.sub ? (
                              <p class="home-resume-sub">{item.sub}</p>
                            ) : null}
                          </>
                        )}
                        {item.badges?.length ? (
                          <ul
                            class="home-resume-badges"
                            aria-label="Experience stack"
                          >
                            {item.badges.map((badge) => (
                              <li>
                                <img
                                  class="home-resume-badge-icon"
                                  src={badge.icon}
                                  alt=""
                                  loading="lazy"
                                  width="14"
                                  height="14"
                                />
                                <span>{badge.label}</span>
                              </li>
                            ))}
                          </ul>
                        ) : null}
                      </li>
                    );
                  })}
                </ul>
              </article>
            ))
          }
        </div>

        <div class="home-resume-column">
          {
            resumeRightSections.map((section) => (
              <article class="home-resume-block">
                <h3>{section.title}</h3>
                <ul>
                  {section.items.map((item) => {
                    const display = toResumeDisplay(item);
                    return (
                      <li>
                        {display.period ? (
                          <div class="home-resume-main-split">
                            <p class="home-resume-main home-resume-period">
                              {display.period}
                            </p>
                            <p class="home-resume-main home-resume-main-text">
                              {display.text}
                            </p>
                            {item.sub ? (
                              <p class="home-resume-sub home-resume-sub-split">
                                {item.sub}
                              </p>
                            ) : null}
                          </div>
                        ) : (
                          <>
                            <p class="home-resume-main">{display.text}</p>
                            {item.sub ? (
                              <p class="home-resume-sub">{item.sub}</p>
                            ) : null}
                          </>
                        )}
                        {item.badges?.length ? (
                          <ul
                            class="home-resume-badges"
                            aria-label="Experience stack"
                          >
                            {item.badges.map((badge) => (
                              <li>
                                <img
                                  class="home-resume-badge-icon"
                                  src={badge.icon}
                                  alt=""
                                  loading="lazy"
                                  width="14"
                                  height="14"
                                />
                                <span>{badge.label}</span>
                              </li>
                            ))}
                          </ul>
                        ) : null}
                      </li>
                    );
                  })}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="home-section"
      id="home-tech-stack"
      aria-labelledby="home-tech-heading"
    >
      <div class="home-section-head">
        <h2 id="home-tech-heading">Skill</h2>
      </div>
      <div class="home-stack-groups">
        {
          techStackGroups.map((group) => (
            <article
              class={`home-stack-card ${
                group.title === "Language" ? "home-stack-card-language" : ""
              }`.trim()}
            >
              <h3>{group.title}</h3>
              <ul
                class={`home-stack-items ${
                  group.title === "Language" ? "home-stack-items-inline" : ""
                }`.trim()}
              >
                {group.items.map((item) =>
                  "divider" in item ? (
                    <li
                      class="home-stack-divider"
                      role="separator"
                      aria-hidden="true"
                    />
                  ) : (
                    <li class="home-stack-item">
                      {item.icon ? (
                        <img
                          class="home-stack-icon"
                          src={item.icon}
                          alt={`${item.label} logo`}
                          loading="lazy"
                          width="18"
                          height="18"
                        />
                      ) : (
                        <span class="home-stack-fallback" aria-hidden="true">
                          {item.fallback}
                        </span>
                      )}
                      <span>{item.label}</span>
                    </li>
                  ),
                )}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="home-section"
      id="home-featured-projects"
      aria-labelledby="home-projects-heading"
    >
      <div class="home-section-head">
        <h2 id="home-projects-heading">Featured Projects</h2>
        <a href="/projects">View All Projects</a>
      </div>
      <div class="card-grid home-project-grid">
        {
          projects.map((project) => (
            <ProjectCard
              project={project}
              imageWidth={960}
              imageHeight={540}
              stackLimit={3}
            />
          ))
        }
      </div>
    </section>

    <section
      class="home-section"
      id="home-featured-series"
      aria-labelledby="home-series-heading"
    >
      <div class="home-section-head">
        <h2 id="home-series-heading">Featured Series</h2>
        <a href="/series">View All Series</a>
      </div>
      {
        featuredSeriesCards.length > 0 ? (
          <div class="home-series-grid">
            {featuredSeriesCards.map((card) => (
              <article class="home-series-card">
                <a class="home-series-card-anchor" href={`/series/${card.slug}`}>
                  <div class="home-series-card-thumb">
                    <img src={card.coverImageUrl ?? defaultSeriesCoverImage} alt={card.title} loading="lazy" />
                  </div>
                  <div class="home-series-card-body">
                    <h3>{card.title}</h3>
                    <p>{card.summary}</p>
                    <p class="home-series-card-meta">
                      <span>{card.postCount} posts</span>
                      <span>·</span>
                      <FormattedDate date={card.latestPostAt} />
                    </p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state home-series-empty">
            아직 등록된 시리즈가 없습니다.
          </div>
        )
      }
    </section>

    <section
      class="home-section"
      id="home-latest-posts"
      aria-labelledby="home-posts-heading"
    >
      <div class="home-section-head">
        <h2 id="home-posts-heading">Latest Posts</h2>
        <a href="/blog">View All Posts</a>
      </div>
      {
        posts.length > 0 ? (
          <div class="post-list home-post-list">
            {posts.map((post) => (
              <PostCard post={post} imageWidth={960} imageHeight={540} />
            ))}
          </div>
        ) : (
          <div class="empty-state">아직 공개된 글이 없습니다.</div>
        )
      }
    </section>

    <section
      class="home-section"
      id="home-connect"
      aria-labelledby="home-connect-heading"
    >
      <div class="home-connect-panel">
        <h2 id="home-connect-heading">Connect</h2>
        <p class="home-long-copy">
          협업이나 프로젝트 문의는 메일로 부탁드립니다. 이력서는 PDF로
          제공됩니다.
        </p>
        <div class="home-contact-links">
          {
            connectLinks.map((link) => (
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
