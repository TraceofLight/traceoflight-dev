---
import AdminWriterLayout from "../../../../layouts/AdminWriterLayout.astro";
import DialogLayers from "../../../../components/admin/post-form/DialogLayers.astro";
import EditorSection from "../../../../components/admin/post-form/EditorSection.astro";
import MetaPanel from "../../../../components/admin/post-form/MetaPanel.astro";
import PreviewSection from "../../../../components/admin/post-form/PreviewSection.astro";
import TitleInput from "../../../../components/admin/post-form/TitleInput.astro";
import { requestBackend } from "../../../../lib/backend-api";
import { normalizeAdminPostPayload } from "../../../../lib/admin/new-post-page/posts-api";
import { getMediaBaseUrl } from "../../../../lib/env";

const defaultMediaBaseUrl = getMediaBaseUrl();
const slug = (Astro.params.slug ?? "").trim();
let initialPayload = null;

if (!slug) {
  Astro.response.status = 404;
} else {
  try {
    const response = await requestBackend(`/posts/${encodeURIComponent(slug)}`);
    if (response.ok) {
      initialPayload = normalizeAdminPostPayload(await response.json());
    } else if (response.status === 404) {
      Astro.response.status = 404;
    } else {
      Astro.response.status = response.status;
    }
  } catch {
    Astro.response.status = 503;
  }
}

const initialContentKind =
  initialPayload?.content_kind === "project" ? "project" : "blog";
const initialVisibility =
  initialPayload?.visibility === "private" ? "private" : "public";
const initialSeriesTitle = initialPayload?.series_title?.trim() ?? "";
const initialTitle = initialPayload?.title?.trim() ?? "";
const initialProjectPeriod = initialPayload?.project_profile?.period_label ?? "";
const initialProjectRole = initialPayload?.project_profile?.role_summary ?? "";
const initialProjectIntro = initialPayload?.project_profile?.project_intro ?? "";
const initialProjectHighlights = (
  initialPayload?.project_profile?.highlights_json ??
  initialPayload?.project_profile?.highlights ??
  []
).join("\n");
const initialProjectLinks = (
  initialPayload?.project_profile?.resource_links_json ??
  initialPayload?.project_profile?.resource_links ??
  []
).map((link) => `${link.label} | ${link.href}`).join("\n");
const fallbackBackHref = initialContentKind === "project" ? "/projects/" : "/blog/";
const rawReferer = Astro.request.headers.get("referer")?.trim() ?? "";
let backHref = fallbackBackHref;

try {
  if (rawReferer) {
    const refererUrl = new URL(rawReferer);
    if (refererUrl.origin === Astro.url.origin) {
      backHref =
        `${refererUrl.pathname}${refererUrl.search}${refererUrl.hash}` ||
        fallbackBackHref;
    }
  }
} catch {
  backHref = fallbackBackHref;
}
---

<AdminWriterLayout title="Admin Writer" description="TraceofLight admin writer">
  <form
    id="admin-post-form"
    class="writer-form"
    data-media-base-url={defaultMediaBaseUrl}
    data-writer-mode="edit"
    data-edit-slug={slug}
    novalidate
  >
    <div class="writer-shell" data-compact-view="editor">
      <section class="writer-pane writer-pane-editor-column">
        <TitleInput initialTitle={initialTitle} />
        <MetaPanel
          initialContentKind={initialContentKind}
          initialVisibility={initialVisibility}
          initialSeriesTitle={initialSeriesTitle}
          initialProjectPeriod={initialProjectPeriod}
          initialProjectRole={initialProjectRole}
          initialProjectIntro={initialProjectIntro}
          initialProjectHighlights={initialProjectHighlights}
          initialProjectLinks={initialProjectLinks}
          preselectOptions
        />
        <EditorSection backHref={backHref} />
      </section>
      <PreviewSection initialContentKind={initialContentKind} />
    </div>

    <DialogLayers />
  </form>
  <script
    is:inline
    id="writer-initial-payload"
    type="application/json"
    set:html={JSON.stringify(initialPayload)}
  ></script>
</AdminWriterLayout>
