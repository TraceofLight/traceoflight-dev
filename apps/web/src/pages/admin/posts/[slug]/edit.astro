---
import AdminWriterLayout from "../../../../layouts/AdminWriterLayout.astro";

const siteUrl = import.meta.env.SITE_URL?.trim() ?? "";
const defaultMediaBaseUrl = siteUrl
  ? `${siteUrl.replace(/\/+$/, "")}/media`
  : "/media";
const slug = (Astro.params.slug ?? "").trim();

if (!slug) {
  Astro.response.status = 404;
}
---

<AdminWriterLayout title="Admin Writer" description="TraceofLight admin writer">
  <form
    id="admin-post-form"
    class="writer-form"
    data-media-base-url={defaultMediaBaseUrl}
    data-writer-mode="edit"
    data-edit-slug={slug}
    novalidate
  >
    <div class="writer-shell" data-compact-view="editor">
      <section class="writer-pane writer-pane-editor-column">
        <div class="writer-title-area">
          <input
            id="post-title"
            name="title"
            class="writer-title-input"
            type="text"
            placeholder="제목을 입력하세요"
          />
        </div>

        <div class="writer-meta-panel-wrap">
          <aside id="writer-meta-panel" class="writer-pane writer-pane-meta" data-content-kind="blog">
            <div class="writer-meta-head">
              <p class="writer-preview-kicker">Metadata</p>
              <h2>작성 설정</h2>
            </div>
            <div class="writer-meta-body">
            <label class="writer-field">
              <span>콘텐츠 타입</span>
              <select id="post-content-kind" name="content_kind">
                <option value="blog">Blog</option>
                <option value="project">Project</option>
              </select>
            </label>
            <label class="writer-field">
              <span>공개 범위</span>
              <select id="post-visibility" name="visibility">
                <option value="public">Public</option>
                <option value="private">Private</option>
              </select>
            </label>
            <label class="writer-field">
              <span>시리즈</span>
              <input
                id="post-series"
                name="series"
                type="text"
                list="writer-series-suggestions"
                placeholder="시리즈 이름 입력 (선택)"
              />
              <datalist id="writer-series-suggestions"></datalist>
            </label>

            <section
              id="writer-project-fields"
              class="writer-project-grid"
              hidden
              data-content-kind="blog"
              data-media-kind="image"
            >
              <label class="writer-field">
                <span>프로젝트 작업 기간</span>
                <input id="project-period" type="text" placeholder="2026.03 - ongoing" />
              </label>
              <label class="writer-field">
                <span>프로젝트 역할 요약</span>
                <input id="project-role-summary" type="text" placeholder="Lead developer" />
              </label>
              <label class="writer-field writer-field-span-2">
                <span>프로젝트 소개</span>
                <textarea id="project-intro" rows="2" placeholder="프로젝트 소개 문구를 입력하세요"></textarea>
              </label>
              <label class="writer-field">
                <span>상단 미디어 타입</span>
                <select id="project-detail-media-kind">
                  <option value="image">Image</option>
                  <option value="youtube">YouTube</option>
                  <option value="video">Uploaded Video</option>
                </select>
              </label>
              <label class="writer-field writer-field-span-2">
                <span>유튜브 URL</span>
                <input id="project-youtube-url" type="url" placeholder="https://www.youtube.com/watch?v=..." />
              </label>
              <label class="writer-field writer-field-span-2">
                <span>업로드된 영상 URL</span>
                <input id="project-detail-video-url" type="url" placeholder="/media/..." />
              </label>
              <div class="writer-project-upload writer-field-span-2">
                <button
                  id="project-video-upload-trigger"
                  class="writer-action writer-action-muted"
                  type="button"
                >
                  프로젝트 영상 업로드
                </button>
                <input
                  id="project-video-upload-input"
                  type="file"
                  accept="video/*"
                  hidden
                />
                <video id="project-video-preview" class="writer-project-video-preview" controls hidden>
                </video>
              </div>
              <label class="writer-field writer-field-span-2">
                <span>주요 항목</span>
                <textarea id="project-highlights" rows="5" placeholder="한 줄에 하나씩 입력"></textarea>
              </label>
              <label class="writer-field writer-field-span-2">
                <span>관련 링크</span>
                <textarea id="project-resource-links" rows="4" placeholder="GitHub | https://github.com/..."></textarea>
              </label>
            </section>
            </div>
          </aside>
        </div>

        <section class="writer-pane writer-pane-editor">
          <div
            id="writer-editor-drop-zone"
            class="writer-editor-shell"
            data-drop-state="idle"
            data-has-content="false"
          >
            <div class="writer-editor-drop-indicator" aria-hidden="true">
              <p class="writer-editor-drop-title">
                Drop media to insert into body
              </p>
              <p class="writer-editor-drop-caption">
                Images and videos are uploaded and inserted at the end.
              </p>
            </div>
            <div id="milkdown-editor" class="milkdown-editor"></div>
          </div>
        </section>

        <div id="writer-bottom-bar" class="writer-bottom-bar">
          <div class="writer-bottom-left">
            <a class="writer-bottom-back" href="/blog/">뒤로가기</a>
            <button
              id="writer-open-drafts"
              class="writer-bottom-back writer-bottom-drafts"
              type="button">임시저장</button
            >
          </div>
          <div class="writer-bottom-actions">
            <button
              id="writer-toggle-compact-view"
              class="writer-action writer-action-muted writer-compact-toggle"
              type="button"
              aria-pressed="false"
            >
              미리보기
            </button>
            <button
              id="writer-save-draft"
              class="writer-action writer-action-muted"
              type="submit"
              data-submit-status="draft"
            >
              저장
            </button>
            <button
              id="writer-open-publish"
              class="writer-action writer-action-primary"
              type="button"
            >
              출간
            </button>
          </div>
        </div>
      </section>
      <section class="writer-pane writer-pane-preview">
        <div class="writer-preview-head">
          <p class="writer-preview-kicker">Live Preview</p>
          <h1 id="writer-preview-title"></h1>
        </div>
        <section id="writer-preview-meta" class="writer-preview-meta">
          <div id="writer-preview-meta-kinds" class="writer-preview-meta-grid"></div>
          <div id="writer-preview-meta-summary" class="writer-preview-meta-block"></div>
          <div id="writer-preview-meta-series" class="writer-preview-meta-block"></div>
          <div id="writer-preview-meta-tags" class="writer-preview-meta-block"></div>
          <div id="writer-preview-meta-project" class="writer-preview-meta-block"></div>
          <div id="writer-preview-meta-highlights" class="writer-preview-meta-block"></div>
          <div id="writer-preview-meta-links" class="writer-preview-meta-block"></div>
        </section>
        <article id="writer-preview-content" class="writer-preview-content">
        </article>
      </section>
    </div>

    <div
      id="writer-draft-layer"
      class="writer-draft-layer"
      data-open="false"
      hidden
    >
      <button
        id="writer-draft-backdrop"
        class="writer-draft-backdrop"
        type="button"
        aria-label="Close drafts"></button>
      <section
        class="writer-draft-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="writer-draft-title"
      >
        <header class="writer-draft-head">
          <div class="writer-draft-head-copy">
            <p class="writer-draft-kicker">Drafts</p>
            <h2 id="writer-draft-title">임시저장 글</h2>
          </div>
          <button
            id="writer-close-drafts"
            class="writer-action writer-action-muted"
            type="button">닫기</button
          >
        </header>
        <p
          id="writer-draft-feedback"
          class="writer-draft-feedback"
          data-state="info"
        >
        </p>
        <ul id="writer-draft-list" class="writer-draft-list" aria-live="polite">
          <li class="writer-draft-empty">임시저장 글을 불러오는 중입니다.</li>
        </ul>
      </section>
    </div>

    <div
      id="writer-publish-layer"
      class="writer-publish-layer"
      data-open="false"
      hidden
    >
      <button
        id="writer-publish-backdrop"
        class="writer-publish-backdrop"
        type="button"
        aria-label="Close publish settings"
      >
      </button>
      <section
        class="writer-publish-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="writer-publish-title"
      >
        <header class="writer-publish-head">
          <div class="writer-publish-head-copy">
            <p class="writer-publish-kicker">Publish</p>
            <h2 id="writer-publish-title">출간 설정</h2>
            <p class="writer-publish-description">
              URL, 요약, 커버 이미지를 확인한 뒤 게시합니다.
            </p>
          </div>
        </header>
        <div class="writer-publish-body">
          <div class="writer-publish-column writer-publish-column-main">
            <label class="writer-field writer-field-slug">
              <span>Post URL</span>
              <div class="writer-slug-input-wrap">
                <span id="writer-slug-prefix" class="writer-slug-prefix">/blog/</span>
                <input
                  id="post-slug"
                  name="slug"
                  type="text"
                  placeholder="your-post-slug"
                />
              </div>
            </label>
            <p
              id="writer-slug-feedback"
              class="writer-field-feedback"
              data-state="idle"
              aria-live="polite"
            >
            </p>
            <label class="writer-field">
              <span>요약</span>
              <textarea
                id="post-excerpt"
                name="excerpt"
                rows="7"
                placeholder="게시글 요약을 입력하세요."></textarea>
            </label>
            <label class="writer-field">
              <span>태그</span>
              <input
                id="post-tags"
                name="tags"
                type="text"
                list="writer-tag-suggestions"
                placeholder="태그 입력 후 Enter 또는 콤마"
              />
              <datalist id="writer-tag-suggestions"></datalist>
            </label>
            <div id="writer-meta-chip-rail" class="writer-meta-chip-rail">
              <div id="writer-tag-chip-list" class="writer-tag-chip-list"></div>
            </div>
          </div>
          <div class="writer-publish-column writer-publish-column-side">
            <div
              id="writer-cover-preview"
              class="writer-cover-preview"
              data-empty="true"
              data-drop-state="idle"
            >
              <img
                id="writer-cover-preview-image"
                class="writer-cover-preview-image"
                alt="Cover preview"
                hidden
              />
              <p
                id="writer-cover-preview-empty"
                class="writer-cover-preview-empty"
              >
                커버 이미지를 설정하면 여기에 미리보기가 표시됩니다.
              </p>
            </div>
            <input
              id="writer-cover-upload-input"
              type="file"
              accept="image/*"
              hidden
            />
            <label
              id="writer-cover-drop-zone"
              class="writer-field writer-field-cover-drop"
              data-drop-state="idle"
            >
              <span>Cover Image URL</span>
              <input
                id="post-cover"
                name="cover_image_url"
                type="url"
                placeholder="https://..."
              />
              <span class="writer-cover-drop-indicator" aria-hidden="true">
                Drop cover image here to upload
              </span>
            </label>
            <p class="writer-helper">
              Drag/drop image to cover field, or paste URL/file from clipboard.
            </p>
          </div>
        </div>
        <div class="writer-publish-actions">
          <button
            id="writer-cancel-publish"
            class="writer-action writer-action-muted"
            type="button">취소</button
          >
          <button
            id="writer-confirm-publish"
            class="writer-action writer-action-primary"
            type="submit"
            data-submit-status="published"
          >
            지금 출간
          </button>
        </div>
      </section>
    </div>

    <p
      id="writer-toast"
      class="writer-toast"
      data-state="info"
      data-visible="false"
      role="status"
      aria-live="polite"
    >
      글 작성을 시작하세요.
    </p>
  </form>
</AdminWriterLayout>

<script>
  import { initNewPostAdminPage } from "../../../../lib/admin/new-post-page";

  void initNewPostAdminPage({ mode: "edit" });
</script>
