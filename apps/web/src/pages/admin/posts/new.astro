---
import AdminWriterLayout from '../../../layouts/AdminWriterLayout.astro';

const siteUrl = import.meta.env.SITE_URL?.trim() ?? '';
const defaultMediaBaseUrl = siteUrl ? `${siteUrl.replace(/\/+$/, '')}/media` : '/media';
---

<AdminWriterLayout title="Admin Writer" description="TraceofLight admin writer">
  <form id="admin-post-form" class="writer-form" data-media-base-url={defaultMediaBaseUrl}>
    <div class="writer-shell">
      <section class="writer-pane writer-pane-editor">
        <div class="writer-title-area">
          <input
            id="post-title"
            name="title"
            class="writer-title-input"
            type="text"
            required
            placeholder="제목을 입력하세요"
          />
        </div>

        <div id="writer-editor-drop-zone" class="writer-editor-shell" data-drop-state="idle" data-has-content="false">
          <div class="writer-editor-drop-indicator" aria-hidden="true">
            <p class="writer-editor-drop-title">Drop media to insert into body</p>
            <p class="writer-editor-drop-caption">Images and videos are uploaded and inserted at the end.</p>
          </div>
          <div id="milkdown-editor" class="milkdown-editor"></div>
        </div>

        <div id="writer-bottom-bar" class="writer-bottom-bar">
          <div class="writer-bottom-left">
            <a class="writer-bottom-back" href="/admin">Back</a>
            <button id="writer-open-drafts" class="writer-action writer-action-muted" type="button">임시저장</button>
          </div>
          <div class="writer-bottom-actions">
            <button id="writer-upload-trigger" class="writer-action writer-action-muted" type="button">Upload</button>
            <button
              id="writer-save-draft"
              class="writer-action writer-action-muted"
              type="submit"
              data-submit-status="draft"
            >
              Draft
            </button>
            <button id="writer-open-publish" class="writer-action writer-action-primary" type="button">
              Publish
            </button>
          </div>
          <input id="writer-upload-input" type="file" hidden />
        </div>
      </section>

      <section class="writer-pane writer-pane-preview">
        <div class="writer-preview-head">
          <p class="writer-preview-kicker">Live Preview</p>
          <h1 id="writer-preview-title">제목 없음</h1>
        </div>
        <article id="writer-preview-content" class="writer-preview-content"></article>
      </section>
    </div>

    <div id="writer-draft-layer" class="writer-draft-layer" data-open="false" hidden>
      <button id="writer-draft-backdrop" class="writer-draft-backdrop" type="button" aria-label="Close drafts"></button>
      <section class="writer-draft-panel" role="dialog" aria-modal="true" aria-labelledby="writer-draft-title">
        <header class="writer-draft-head">
          <div class="writer-draft-head-copy">
            <p class="writer-draft-kicker">Drafts</p>
            <h2 id="writer-draft-title">임시저장 글</h2>
          </div>
          <button id="writer-close-drafts" class="writer-action writer-action-muted" type="button">Close</button>
        </header>
        <p id="writer-draft-feedback" class="writer-draft-feedback" data-state="info"></p>
        <ul id="writer-draft-list" class="writer-draft-list" aria-live="polite">
          <li class="writer-draft-empty">임시저장 글을 불러오는 중입니다.</li>
        </ul>
      </section>
    </div>

    <div id="writer-publish-layer" class="writer-publish-layer" data-open="false" hidden>
      <button id="writer-publish-backdrop" class="writer-publish-backdrop" type="button" aria-label="Close publish settings">
      </button>
      <section class="writer-publish-panel" role="dialog" aria-modal="true" aria-labelledby="writer-publish-title">
        <header class="writer-publish-head">
          <div class="writer-publish-head-copy">
            <p class="writer-publish-kicker">Publish</p>
            <h2 id="writer-publish-title">출간 설정</h2>
            <p class="writer-publish-description">URL, 요약, 커버 이미지를 확인한 뒤 게시합니다.</p>
          </div>
        </header>
        <div class="writer-publish-body">
          <div class="writer-publish-column writer-publish-column-main">
            <label class="writer-field writer-field-slug">
              <span>Post URL</span>
              <div class="writer-slug-input-wrap">
                <span class="writer-slug-prefix">/blog/</span>
                <input id="post-slug" name="slug" type="text" required placeholder="your-post-slug" />
              </div>
            </label>
            <p id="writer-slug-feedback" class="writer-field-feedback" data-state="idle" aria-live="polite"></p>
            <label class="writer-field">
              <span>요약</span>
              <textarea id="post-excerpt" name="excerpt" rows="7" placeholder="게시글 요약을 입력하세요." />
            </label>
          </div>
          <div class="writer-publish-column writer-publish-column-side">
            <div id="writer-cover-preview" class="writer-cover-preview" data-empty="true" data-drop-state="idle">
              <img id="writer-cover-preview-image" class="writer-cover-preview-image" alt="Cover preview" hidden />
              <p id="writer-cover-preview-empty" class="writer-cover-preview-empty">
                커버 이미지를 설정하면 여기에 미리보기가 표시됩니다.
              </p>
            </div>
            <input id="writer-cover-upload-input" type="file" accept="image/*" hidden />
            <label class="writer-field">
              <span>Status</span>
              <select id="post-status" name="status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
              </select>
            </label>
            <label id="writer-cover-drop-zone" class="writer-field writer-field-cover-drop" data-drop-state="idle">
              <span>Cover Image URL</span>
              <input id="post-cover" name="cover_image_url" type="url" placeholder="https://..." />
              <span class="writer-cover-drop-indicator" aria-hidden="true">
                Drop cover image here to upload
              </span>
            </label>
            <p class="writer-helper">
              Drag/drop image to cover field, or paste URL/file from clipboard.
            </p>
          </div>
        </div>
        <div class="writer-publish-actions">
          <button id="writer-cancel-publish" class="writer-action writer-action-muted" type="button">Cancel</button>
          <button id="writer-confirm-publish" class="writer-action writer-action-primary" type="submit" data-submit-status="published">
            Publish now
          </button>
        </div>
      </section>
    </div>

    <p id="writer-toast" class="writer-toast" data-state="info" data-visible="false" role="status" aria-live="polite">
      글 작성을 시작하세요.
    </p>
  </form>
</AdminWriterLayout>

<script>
  import { initNewPostAdminPage } from '../../../lib/admin/new-post-page';

  void initNewPostAdminPage();
</script>
