---
import AdminWriterLayout from "../../../layouts/AdminWriterLayout.astro";
import DialogLayers from "../../../components/admin/post-form/DialogLayers.astro";
import EditorSection from "../../../components/admin/post-form/EditorSection.astro";
import MetaPanel from "../../../components/admin/post-form/MetaPanel.astro";
import PreviewSection from "../../../components/admin/post-form/PreviewSection.astro";
import TitleInput from "../../../components/admin/post-form/TitleInput.astro";
import { getMediaBaseUrl } from "../../../lib/env";

const defaultMediaBaseUrl = getMediaBaseUrl();
const initialContentKind =
  Astro.url.searchParams.get("content_kind")?.trim().toLowerCase() === "project"
    ? "project"
    : "blog";
const fallbackBackHref = initialContentKind === "project" ? "/projects/" : "/blog/";
const rawReferer = Astro.request.headers.get("referer")?.trim() ?? "";
let backHref = fallbackBackHref;

try {
  if (rawReferer) {
    const refererUrl = new URL(rawReferer);
    if (refererUrl.origin === Astro.url.origin) {
      backHref =
        `${refererUrl.pathname}${refererUrl.search}${refererUrl.hash}` ||
        fallbackBackHref;
    }
  }
} catch {
  backHref = fallbackBackHref;
}
---

<AdminWriterLayout title="Admin Writer" description="TraceofLight admin writer">
  <form
    id="admin-post-form"
    class="writer-form"
    data-media-base-url={defaultMediaBaseUrl}
    data-writer-mode="create"
    data-initial-content-kind={initialContentKind}
    novalidate
  >
    <div class="writer-shell" data-compact-view="editor">
      <section class="writer-pane writer-pane-editor-column">
        <TitleInput />
        <MetaPanel initialContentKind={initialContentKind} />
        <EditorSection backHref={backHref} />
      </section>
      <PreviewSection initialContentKind={initialContentKind} />
    </div>

    <DialogLayers />
  </form>
  <script id="writer-initial-payload" is:inline type="application/json">null</script>
</AdminWriterLayout>
