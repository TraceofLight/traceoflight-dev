---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { listSeries } from "../../../lib/series-db";

let series = [];
try {
  series = await listSeries({ includePrivate: true, limit: 200 });
} catch {
  series = [];
}
---

<BaseLayout title="Admin Series" description="Series management">
  <section class="hero">
    <p class="kicker">ADMIN SERIES</p>
    <h1>Series manager</h1>
    <p class="lead">시리즈 목록만 확인합니다. 편집/삭제는 제공하지 않습니다.</p>
  </section>

  <section class="section auth-shell">
    <div class="auth-panel">
      <a class="button" href="/admin/series/new">새 시리즈</a>
      <a class="button button-ghost" href="/admin">Admin Home</a>
    </div>
  </section>

  <section class="section">
    <div id="admin-series-list" class="surface-card">
      {series.length > 0 ? (
        <ul class="post-list">
          {series.map((item) => (
            <li class="surface-card">
              <h3>{item.title}</h3>
              <p>{item.slug}</p>
              <p>{item.postCount} posts</p>
              <div class="auth-panel">
                <a class="button button-ghost" href={`/series/${item.slug}`}>
                  View
                </a>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p>등록된 시리즈가 없습니다.</p>
      )}
    </div>
  </section>
</BaseLayout>
