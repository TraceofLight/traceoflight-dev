---
import AdminImportsPanel from "../../components/public/AdminImportsPanel";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { requestBackend } from "../../lib/backend-api";
import { ADMIN_IMPORTS_COPY } from "../../lib/admin/imports-page";

let initialResumeAvailable = false;
try {
  const response = await requestBackend("/resume/status", { method: "GET" });
  if (response.ok) {
    const payload = (await response.json().catch(() => null)) as
      | { available?: boolean }
      | null;
    initialResumeAvailable = payload?.available === true;
  }
} catch {
  initialResumeAvailable = false;
}
---

<BaseLayout
  title={ADMIN_IMPORTS_COPY.title}
  description={ADMIN_IMPORTS_COPY.description}
>
  <section class="mx-auto flex max-w-6xl flex-col py-10 sm:py-12">
    <AdminImportsPanel client:load initialResumeAvailable={initialResumeAvailable} />
  </section>
</BaseLayout>
