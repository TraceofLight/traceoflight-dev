---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ga4ReportsUrl = (process.env.GA4_REPORTS_URL ?? '').trim();
---

<BaseLayout title="Admin" description="Admin dashboard">
  <section class="hero">
    <p class="kicker">ADMIN</p>
    <h1>Admin dashboard</h1>
    <p class="lead">관리 작업은 이 페이지에서 시작하고, 글 작성/임시저장은 Writer에서 처리합니다.</p>
  </section>

  <section class="section auth-shell">
    <div class="auth-panel">
      <a class="button" href="/admin/posts/new">Go to Writer</a>
      {
        ga4ReportsUrl && (
          <a class="button button-ghost" href={ga4ReportsUrl} target="_blank" rel="noreferrer">
            GA4 대시보드
          </a>
        )
      }
      <a class="button button-ghost" href="/admin/logout">Logout</a>
    </div>
  </section>
</BaseLayout>
