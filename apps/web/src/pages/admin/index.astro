---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ga4ReportsUrl = (process.env.GA4_REPORTS_URL ?? '').trim();
---

<BaseLayout title="Admin" description="Admin dashboard">
  <section class="hero">
    <p class="kicker">ADMIN</p>
    <h1>Admin dashboard</h1>
    <p class="lead">관리 작업은 이 페이지에서 시작하고, 글 작성/임시저장은 Writer에서 처리합니다.</p>
  </section>

  <section class="section auth-shell">
    <div class="auth-panel">
      <a class="button" href="/admin/posts/new">Go to Writer</a>
      {
        ga4ReportsUrl && (
          <a class="button button-ghost" href={ga4ReportsUrl} target="_blank" rel="noreferrer">
            GA4 대시보드
          </a>
        )
      }
      <button id="admin-logout-button" class="button button-ghost" type="button">Logout</button>
      <p id="logout-feedback" class="auth-feedback" data-state="info"></p>
    </div>
  </section>
</BaseLayout>

<script type="module">
  const logoutButton = document.querySelector('#admin-logout-button');
  const feedback = document.querySelector('#logout-feedback');

  function setFeedback(message, state) {
    if (!feedback) return;
    feedback.textContent = message;
    feedback.dataset.state = state;
  }

  if (logoutButton) {
    logoutButton.addEventListener('click', async () => {
      setFeedback('로그아웃 처리 중...', 'info');
      try {
        const response = await fetch('/internal-api/auth/logout', { method: 'POST' });
        if (!response.ok) {
          setFeedback('로그아웃에 실패했습니다.', 'error');
          return;
        }
        window.location.href = '/admin/login';
      } catch {
        setFeedback('네트워크 오류가 발생했습니다.', 'error');
      }
    });
  }
</script>
