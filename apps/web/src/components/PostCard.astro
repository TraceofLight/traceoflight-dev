---
import { Image } from "astro:assets";

import FormattedDate from "./FormattedDate.astro";
import type { PostCard as PostCardData } from "../lib/content-source";
import { formatReadingTimeLabel } from "../lib/reading-time.ts";

interface Props {
  post: PostCardData;
  variant?: 'default' | 'archive';
  imageWidth?: number;
  imageHeight?: number;
  showVisibility?: boolean;
}

const {
  post,
  variant = 'default',
  imageWidth = 1200,
  imageHeight = 630,
  showVisibility = false,
} = Astro.props;
const normalizedVisibility = post.visibility === 'private' ? 'private' : 'public';
const descriptionText = post.description?.trim() ?? '';
const hasDescription = descriptionText.length > 0;
const postTags = (post.tags ?? [])
  .map((tag) => tag.trim().toLowerCase())
  .filter(Boolean);
const hasTags = postTags.length > 0;
const fallbackHeroImage = '/images/empty-article-image.png';
const readingLabel = formatReadingTimeLabel(post.body ?? "");
const cardClass = variant === 'archive' ? 'post-card post-card-archive' : 'post-card';
---

<article
  class={cardClass}
  data-title={post.title.toLowerCase()}
  data-description={descriptionText.toLowerCase()}
  data-visibility={normalizedVisibility}
  data-tags={postTags.join(',')}
  data-published-at={String(post.pubDate.valueOf())}
  data-sort-title={post.title.toLowerCase()}
>
  {
    variant === 'archive' ? (
      <>
        <a class="post-card-archive-anchor" href={`/blog/${post.slug}/`} aria-label={`${post.title} 읽기`}>
          <div class="thumb post-card-archive-thumb">
            {
              post.heroImage ? (
                typeof post.heroImage === 'string' ? (
                  <img src={post.heroImage} alt={post.title} loading="lazy" />
                ) : (
                  <Image src={post.heroImage} alt={post.title} width={imageWidth} height={imageHeight} />
                )
              ) : (
                <img src={fallbackHeroImage} alt={post.title} loading="lazy" />
              )
            }
          </div>
          <div class="post-card-archive-body">
            {
              showVisibility && (
                <p class="post-card-archive-kicker">
                  {normalizedVisibility === 'private' ? '비공개 포스트' : '공개 포스트'}
                </p>
              )
            }
            <h3>{post.title}</h3>
            <p class={`post-card-archive-description${hasDescription ? '' : ' is-empty'}`}>
              {hasDescription ? descriptionText : ' '}
            </p>
            <ul class={`post-card-tag-list${hasTags ? '' : ' is-empty'}`} aria-hidden={hasTags ? undefined : 'true'}>
              {postTags.map((tag) => <li class="post-card-tag-chip">{tag}</li>)}
            </ul>
            <p class="post-card-archive-meta">
              <span><FormattedDate date={post.pubDate} /></span>
              <span aria-hidden="true">•</span>
              <span>{readingLabel}</span>
            </p>
          </div>
        </a>
      </>
    ) : (
      <>
        <a class="post-card-default-anchor" href={`/blog/${post.slug}/`} aria-label={`${post.title} 읽기`}>
          <div class="thumb post-card-default-thumb">
            {
              post.heroImage ? (
                typeof post.heroImage === 'string' ? (
                  <img src={post.heroImage} alt={post.title} loading="lazy" />
                ) : (
                  <Image src={post.heroImage} alt={post.title} width={imageWidth} height={imageHeight} />
                )
              ) : (
                <img src={fallbackHeroImage} alt={post.title} loading="lazy" />
              )
            }
          </div>
          <div class="post-card-default-body">
            <p class="post-meta">
              <FormattedDate date={post.pubDate} />
              {
                showVisibility && post.visibility === 'private' && <span class="post-visibility-badge">Private</span>
              }
            </p>
            <h3>{post.title}</h3>
            <p class={`post-card-default-description${hasDescription ? '' : ' is-empty'}`}>
              {hasDescription ? descriptionText : ' '}
            </p>
            <ul class={`post-card-tag-list${hasTags ? '' : ' is-empty'}`} aria-hidden={hasTags ? undefined : 'true'}>
              {postTags.map((tag) => <li class="post-card-tag-chip">{tag}</li>)}
            </ul>
          </div>
        </a>
      </>
    )
  }
</article>
