---
import CoverMediaImage from "./CoverMediaImage.astro";
import type { PostCard as PostCardData } from "../lib/content-source";
import { toBrowserImageUrl } from "../lib/cover-media";
import { formatDateLabel, toIsoDateTime } from "../lib/format-date";
import { formatReadingTimeLabel } from "../lib/reading-time.ts";

interface Props {
  post: PostCardData;
  variant?: "default" | "archive";
  imageWidth?: number;
  imageHeight?: number;
  showVisibility?: boolean;
}

const {
  post,
  variant = "default",
  imageWidth = 1200,
  imageHeight = 630,
  showVisibility = false,
} = Astro.props;
const normalizedVisibility = post.visibility === "private" ? "private" : "public";
const descriptionText = post.description?.trim() ?? "";
const hasDescription = descriptionText.length > 0;
const postTags = (post.tags ?? [])
  .map((tag) => tag.trim().toLowerCase())
  .filter(Boolean);
const hasTags = postTags.length > 0;
const fallbackCoverImage = "/images/empty-article-image.png";
const fallbackCoverImageSrc = toBrowserImageUrl(fallbackCoverImage, {
  width: imageWidth,
  height: imageHeight,
});
const formattedPubDate = formatDateLabel(post.pubDate);
const pubDateIso = toIsoDateTime(post.pubDate);
const readingLabel = formatReadingTimeLabel(post.body ?? "");
const anchorClass =
  variant === "archive"
    ? "flex h-full flex-col rounded-[2rem] border border-white/80 bg-white/95 p-3 shadow-[0_28px_80px_rgba(15,23,42,0.10)] text-card-foreground transition duration-300 hover:-translate-y-2 hover:bg-white hover:shadow-[0_38px_90px_rgba(15,23,42,0.14)]"
    : "flex h-full flex-col rounded-[2rem] border border-white/80 bg-white/95 p-3 shadow-[0_28px_80px_rgba(15,23,42,0.10)] text-card-foreground transition duration-300 hover:-translate-y-2 hover:bg-white hover:shadow-[0_38px_90px_rgba(15,23,42,0.14)]";
---

<article
  class="group h-full"
  data-title={post.title.toLowerCase()}
  data-description={descriptionText.toLowerCase()}
  data-visibility={normalizedVisibility}
  data-tags={postTags.join(",")}
  data-published-at={String(post.pubDate.valueOf())}
  data-sort-title={post.title.toLowerCase()}
>
  {
    variant === "archive" ? (
      <>
        <a class={anchorClass} href={`/blog/${post.slug}/`} aria-label={`${post.title} 읽기`}>
          <div class="aspect-[4/5] min-h-[18rem] overflow-hidden rounded-[1.5rem] bg-slate-100 sm:min-h-[22rem]">
            {
              post.coverMedia ? (
                <CoverMediaImage
                  className="block h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.04]"
                  media={post.coverMedia}
                  alt={post.title}
                  width={imageWidth}
                  height={imageHeight}
                  sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
                />
              ) : (
                <img
                  class="block h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.04]"
                  src={fallbackCoverImageSrc}
                  alt={post.title}
                  loading="lazy"
                />
              )
            }
          </div>
          <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
            {
              showVisibility && (
                <div class="flex items-center gap-2 text-xs text-muted-foreground">
                  <span>{normalizedVisibility === "private" ? "비공개 포스트" : "공개 포스트"}</span>
                </div>
              )
            }
            <div class="space-y-2">
              <h3 class="text-xl font-semibold tracking-tight">{post.title}</h3>
              <p class="line-clamp-2 text-sm text-muted-foreground">
                {hasDescription ? descriptionText : " "}
              </p>
            </div>
            {
              hasTags && (
                <div class="flex flex-wrap gap-2">
                  {postTags.map((tag) => (
                    <span class="rounded-full border border-white/80 bg-slate-100/88 px-2.5 py-0.5 text-[0.72rem] font-medium text-muted-foreground">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
            <p class="mt-auto flex items-center gap-2 text-xs text-muted-foreground">
              <time datetime={pubDateIso}>{formattedPubDate}</time>
              <span aria-hidden="true">•</span>
              <span>{readingLabel}</span>
            </p>
          </div>
        </a>
      </>
    ) : (
      <>
        <a class={anchorClass} href={`/blog/${post.slug}/`} aria-label={`${post.title} 읽기`}>
          <div class="aspect-[4/5] min-h-[18rem] overflow-hidden rounded-[1.5rem] bg-slate-100 sm:min-h-[22rem]">
            {
              post.coverMedia ? (
                <CoverMediaImage
                  className="block h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.04]"
                  media={post.coverMedia}
                  alt={post.title}
                  width={imageWidth}
                  height={imageHeight}
                  sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
                />
              ) : (
                <img
                  class="block h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.04]"
                  src={fallbackCoverImageSrc}
                  alt={post.title}
                  loading="lazy"
                />
              )
            }
          </div>
          <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
            <p class="flex items-center gap-2 text-xs text-muted-foreground">
              <time datetime={pubDateIso}>{formattedPubDate}</time>
              {
                showVisibility && post.visibility === 'private' && (
                  <span class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 text-[0.72rem] font-medium text-amber-700">
                    Private
                  </span>
                )
              }
            </p>
            <div class="space-y-2">
              <h3 class="text-xl font-semibold tracking-tight">{post.title}</h3>
              <p class="line-clamp-2 text-sm text-muted-foreground">
                {hasDescription ? descriptionText : " "}
              </p>
            </div>
            {
              hasTags && (
                <div class="mt-auto flex flex-wrap gap-2">
                  {postTags.map((tag) => (
                    <span class="rounded-full border border-white/80 bg-slate-100/88 px-2.5 py-0.5 text-[0.72rem] font-medium text-muted-foreground">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </div>
        </a>
      </>
    )
  }
</article>
