---
import FormattedDate from "./FormattedDate.astro";
import {
  buildBrowserImageSrcSet,
  buildImageFallbackOnError,
  toBrowserImageUrl,
} from "../lib/cover-media";
import {
  PUBLIC_HOVER_CARD_CLASS,
  PUBLIC_MEDIA_FRAME_CLASS,
} from "../lib/ui-effects";

interface SeriesCardData {
  slug: string;
  title: string;
  description: string;
  postCount: number;
  updatedAt: Date;
  coverImageUrl?: string;
}

interface Props {
  series: SeriesCardData;
  imageWidth?: number;
  imageHeight?: number;
  fallbackCoverImageSrc?: string;
}

const {
  series,
  imageWidth = 960,
  imageHeight = 640,
  fallbackCoverImageSrc,
} = Astro.props;
const fallbackCoverImage = "/images/empty-series-image.png";
const resolvedFallbackCoverImageSrc = fallbackCoverImageSrc ?? toBrowserImageUrl(fallbackCoverImage, {
  width: imageWidth,
  height: imageHeight,
  fit: "inside",
});
const coverImageFallbackOnError = buildImageFallbackOnError(resolvedFallbackCoverImageSrc);
const coverImageSource = series.coverImageUrl ?? fallbackCoverImage;
const resolvedCoverImageSrc = series.coverImageUrl
  ? toBrowserImageUrl(series.coverImageUrl, {
      width: imageWidth,
      height: imageHeight,
      fit: "inside",
    })
  : resolvedFallbackCoverImageSrc;
const resolvedCoverImageSrcSet = buildBrowserImageSrcSet(coverImageSource, {
  width: imageWidth,
  height: imageHeight,
  fit: "inside",
});
const mediaFrameClass = PUBLIC_MEDIA_FRAME_CLASS;
const cardImageSizes = "(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw";
---

<article class="group h-full">
  <a
    class={`flex h-full flex-col p-3 ${PUBLIC_HOVER_CARD_CLASS}`}
    href={`/series/${series.slug}`}
  >
    <div class={mediaFrameClass}>
      <img
        alt={series.title}
        class="absolute inset-0 block !h-full !w-full !max-w-none object-cover object-center transition duration-500 group-hover:scale-[1.06]"
        decoding="async"
        height={imageHeight}
        loading="lazy"
        onerror={coverImageFallbackOnError}
        sizes={cardImageSizes}
        src={resolvedCoverImageSrc}
        srcset={resolvedCoverImageSrcSet}
        width={imageWidth}
      />
    </div>
    <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          {series.title}
        </h2>
        <p class="line-clamp-2 text-sm text-muted-foreground">
          {series.description.trim().length > 0 ? series.description : " "}
        </p>
      </div>
      <p class="mt-auto flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
        <span>{series.postCount} posts</span>
        <span aria-hidden="true">•</span>
        <FormattedDate date={series.updatedAt} />
      </p>
    </div>
  </a>
</article>
