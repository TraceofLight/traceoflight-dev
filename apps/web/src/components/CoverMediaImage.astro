---
import { Image } from "astro:assets";

import {
  buildBrowserImageSrcSet,
  normalizeImageFallbackSrc,
  toBrowserImageUrl,
  type CoverMedia,
} from "../lib/cover-media";

interface Props {
  media: CoverMedia;
  alt: string;
  className?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  sizes?: string;
  fallbackSrc?: string;
  fit?: "cover" | "contain" | "inside";
  mediaLoad?: boolean;
}

const {
  media,
  alt,
  className,
  width,
  height,
  loading = "lazy",
  sizes,
  fallbackSrc,
  fit = "cover",
  mediaLoad = true,
} = Astro.props;
const normalizedClassName = className?.trim() || undefined;
const normalizedFallbackSrc = normalizeImageFallbackSrc(fallbackSrc);
const mediaLoadAttr = mediaLoad ? "" : undefined;

const browserSizedSrc =
  media.kind === "native"
    ? toBrowserImageUrl(media.src, { width, height, fit })
    : undefined;
const nativeSrcSet =
  media.kind === "native"
    ? buildBrowserImageSrcSet(media.src, { width, height, fit })
    : undefined;
---

{
  media.kind === "optimized" ? (
    <Image
      class={normalizedClassName}
      src={media.src}
      alt={alt}
      width={width ?? media.src.width}
      height={height ?? media.src.height}
      loading={loading}
      sizes={sizes}
      data-media-load={mediaLoadAttr}
    />
  ) : (
    <img
      class={normalizedClassName}
      src={browserSizedSrc ?? media.src}
      srcset={nativeSrcSet}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      sizes={sizes}
      data-fallback-src={normalizedFallbackSrc}
      data-media-load={mediaLoadAttr}
    />
  )
}
