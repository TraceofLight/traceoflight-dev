---
import type { HTMLAttributes } from 'astro/types';
import { PUBLIC_NAV_ACTIVE_PILL_CLASS } from "../lib/ui-effects";

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const normalize = (value: string): string => `/${value.replace(/^\/+|\/+$/g, '')}`;
const hrefStr = typeof href === 'string' ? href : '';
const normalizedHref = hrefStr ? normalize(hrefStr) : '';
const normalizedPath = normalize(pathname);
const segments = normalizedPath.split('/').filter(Boolean);
// Active when the path matches exactly, or is a child of the link target. Treat
// `/{locale}/` (length 1) as the home root and `/{locale}/{section}` as the
// section root, so deep links keep the parent nav highlighted.
const sectionRoot = segments.length >= 2 ? `/${segments[0]}/${segments[1]}` : `/${segments[0] ?? ''}`;
const isActive =
  normalizedHref === normalizedPath ||
  normalizedHref === sectionRoot;
---

<a
  href={href}
  aria-current={isActive ? 'page' : undefined}
  class:list={[
    "inline-flex select-none items-center rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-white/84 hover:text-foreground hover:shadow-[0_8px_24px_rgba(15,23,42,0.08)]",
    className,
    {
      [PUBLIC_NAV_ACTIVE_PILL_CLASS]: isActive,
    },
  ]}
  {...props}
>
  <slot />
</a>
