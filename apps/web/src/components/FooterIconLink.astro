---
import githubIcon from "../assets/icons/footer/github.svg?raw";
import mailIcon from "../assets/icons/footer/mail.svg?raw";

type FooterIconName = "mail" | "github";

type Props = {
  href: string;
  label: string;
  icon: FooterIconName;
  external?: boolean;
};

const { href, label, icon, external = false } = Astro.props as Props;

const iconSvgs: Record<FooterIconName, string> = {
  mail: mailIcon,
  github: githubIcon,
};
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
  class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/80 bg-white/88 text-muted-foreground shadow-[0_10px_30px_rgba(15,23,42,0.08)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-white hover:text-foreground"
  data-icon={icon}
  aria-label={label}
>
  <span class="h-4 w-4 [&>svg]:h-4 [&>svg]:w-4" aria-hidden="true" set:html={iconSvgs[icon]}></span>
</a>
