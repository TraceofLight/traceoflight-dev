---
import { DEFAULT_SERIES_IMAGE, IMAGE_SIZES } from "../consts";
import type { ProjectItem } from "../lib/projects";
import {
  buildBrowserImageSrcSet,
  buildImageFallbackOnError,
  toBrowserImageUrl,
} from "../lib/cover-media";
import { mediaFrame, statusBadge, surface } from "../lib/ui";

interface Props {
  project: ProjectItem;
  imageWidth?: number;
  imageHeight?: number;
  stackLimit?: number;
  locale?: string;
}

const {
  project,
  imageWidth = IMAGE_SIZES.postCard.width,
  imageHeight = IMAGE_SIZES.postCard.height,
  stackLimit,
  locale,
} = Astro.props;
const projectHref = locale ? `/${locale}/projects/${project.slug}` : `/projects/${project.slug}`;
const visibleStack =
  typeof stackLimit === "number"
    ? project.stack.slice(0, stackLimit)
    : project.stack;
const fallbackCoverImage = DEFAULT_SERIES_IMAGE;
const coverImageSource = project.coverImageUrl ?? fallbackCoverImage;
const resolvedCoverImageSrc = toBrowserImageUrl(coverImageSource, {
  width: imageWidth,
  height: imageHeight,
  fit: "inside",
});
const resolvedCoverImageSrcSet = buildBrowserImageSrcSet(coverImageSource, {
  width: imageWidth,
  height: imageHeight,
  fit: "inside",
});
const fallbackCoverImageSrc = toBrowserImageUrl(fallbackCoverImage, {
  width: imageWidth,
  height: imageHeight,
  fit: "inside",
});
const coverImageFallbackOnError = buildImageFallbackOnError(fallbackCoverImageSrc);
const mediaFrameClass = mediaFrame();
const anchorClass = `flex h-full flex-col p-3 ${surface({ kind: "card", interactive: true })}`;
const stackPillClass = statusBadge({ tone: "neutral", size: "sm" });
const cardImageSizes = "(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw";
---

<article class="group h-full">
  <a
    class={anchorClass}
    data-astro-reload
    href={projectHref}
  >
    <div class={mediaFrameClass}>
      <img
        alt={project.title}
        class="absolute inset-0 block !h-full !w-full !max-w-none object-cover object-center transition duration-500 group-hover:scale-[1.06]"
        decoding="async"
        height={imageHeight}
        loading="lazy"
        onerror={coverImageFallbackOnError}
        sizes={cardImageSizes}
        src={resolvedCoverImageSrc}
        srcset={resolvedCoverImageSrcSet}
        width={imageWidth}
      />
    </div>
    <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground"
      >
        {project.period}
      </p>
      <div class="space-y-2">
        <h3 class="text-xl font-semibold tracking-tight text-foreground">
          {project.title}
        </h3>
        <p class="line-clamp-3 text-sm text-muted-foreground">
          {project.summary}
        </p>
      </div>
      <div class="mt-auto flex flex-wrap gap-2">
        {
          visibleStack.map((skill) => (
            <span class={stackPillClass}>{skill}</span>
          ))
        }
      </div>
    </div>
  </a>
</article>
