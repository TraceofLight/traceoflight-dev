---
import type { ProjectItem } from "../lib/projects";
import {
  PUBLIC_HOVER_CARD_CLASS,
  PUBLIC_MEDIA_FRAME_CLASS,
} from "../lib/ui-effects";

interface Props {
  project: ProjectItem;
  imageWidth?: number;
  imageHeight?: number;
  stackLimit?: number;
}

const {
  project,
  imageWidth = 1200,
  imageHeight = 640,
  stackLimit,
} = Astro.props;
const visibleStack =
  typeof stackLimit === "number"
    ? project.stack.slice(0, stackLimit)
    : project.stack;
const mediaFrameClass = PUBLIC_MEDIA_FRAME_CLASS;
const anchorClass = `flex h-full flex-col p-3 ${PUBLIC_HOVER_CARD_CLASS}`;
---

<article class="group h-full">
  <a
    class={anchorClass}
    href={`/projects/${project.slug}`}
  >
    <div class={mediaFrameClass}>
      <img
        alt={project.title}
        class="absolute inset-0 block !h-full !w-full !max-w-none object-cover object-center transition duration-500 group-hover:scale-[1.06]"
        height={imageHeight}
        loading="lazy"
        src={project.coverImageUrl ?? "/images/empty-series-image.png"}
        width={imageWidth}
      />
    </div>
    <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground"
      >
        {project.period}
      </p>
      <div class="space-y-2">
        <h3 class="text-xl font-semibold tracking-tight text-foreground">
          {project.title}
        </h3>
        <p class="line-clamp-3 text-sm text-muted-foreground">
          {project.summary}
        </p>
      </div>
      <div class="mt-auto flex flex-wrap gap-2">
        {
          visibleStack.map((skill) => (
            <span class="rounded-full border border-white/80 bg-slate-100/88 px-2.5 py-0.5 text-[0.72rem] font-medium text-muted-foreground">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </a>
</article>
