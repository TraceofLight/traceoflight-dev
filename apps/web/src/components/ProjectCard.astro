---
import { Image } from "astro:assets";

import type { ProjectItem } from "../lib/projects";

interface Props {
  project: ProjectItem;
  imageWidth?: number;
  imageHeight?: number;
  stackLimit?: number;
}

const {
  project,
  imageWidth = 1200,
  imageHeight = 630,
  stackLimit,
} = Astro.props;
const visibleStack =
  typeof stackLimit === "number"
    ? project.stack.slice(0, stackLimit)
    : project.stack;
---

<article class="group h-full">
  <a
    class="flex h-full flex-col overflow-hidden rounded-3xl border border-white/80 bg-white/92 text-card-foreground shadow-[0_24px_60px_rgba(15,23,42,0.08)] transition duration-300 hover:-translate-y-1.5 hover:bg-white hover:shadow-[0_32px_80px_rgba(15,23,42,0.12)]"
    href={`/projects/${project.slug}`}
  >
    <div class="aspect-[16/9] overflow-hidden border-b border-white/80 bg-slate-100/90">
      <Image
        alt={project.title}
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        height={imageHeight}
        src={project.coverImage}
        width={imageWidth}
      />
    </div>
    <div class="flex flex-1 flex-col gap-4 p-5">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground"
      >
        {project.period}
      </p>
      <div class="space-y-2">
        <h3 class="text-xl font-semibold tracking-tight text-foreground">
          {project.title}
        </h3>
        <p class="line-clamp-3 text-sm text-muted-foreground">
          {project.summary}
        </p>
      </div>
      <div class="mt-auto flex flex-wrap gap-2">
        {
          visibleStack.map((skill) => (
            <span class="rounded-full border border-white/80 bg-slate-100/88 px-2.5 py-0.5 text-[0.72rem] font-medium text-muted-foreground">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </a>
</article>
