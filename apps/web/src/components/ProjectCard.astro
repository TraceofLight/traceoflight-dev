---
import { Image } from "astro:assets";

import type { ProjectItem } from "../lib/projects";

interface Props {
  project: ProjectItem;
  imageWidth?: number;
  imageHeight?: number;
  stackLimit?: number;
}

const {
  project,
  imageWidth = 1200,
  imageHeight = 640,
  stackLimit,
} = Astro.props;
const visibleStack =
  typeof stackLimit === "number"
    ? project.stack.slice(0, stackLimit)
    : project.stack;
const mediaFrameClass = "relative h-56 overflow-hidden rounded-[1.5rem] bg-slate-100 sm:h-64";
const anchorClass =
  "flex h-full flex-col rounded-[2rem] border border-white/80 bg-white/95 p-3 text-card-foreground shadow-[0_28px_80px_rgba(15,23,42,0.10)] transition duration-300 hover:-translate-y-2 hover:bg-white hover:shadow-[0_38px_90px_rgba(15,23,42,0.14)]";
---

<article class="group h-full">
  <a
    class={anchorClass}
    href={`/projects/${project.slug}`}
  >
    <div class={mediaFrameClass}>
      <Image
        alt={project.title}
        class="block !h-full !w-full !max-w-none object-cover object-center transition duration-500 group-hover:scale-[1.06]"
        height={imageHeight}
        src={project.coverImage}
        width={imageWidth}
      />
    </div>
    <div class="flex flex-1 flex-col gap-4 px-2 pb-2 pt-5">
      <p
        class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground"
      >
        {project.period}
      </p>
      <div class="space-y-2">
        <h3 class="text-xl font-semibold tracking-tight text-foreground">
          {project.title}
        </h3>
        <p class="line-clamp-3 text-sm text-muted-foreground">
          {project.summary}
        </p>
      </div>
      <div class="mt-auto flex flex-wrap gap-2">
        {
          visibleStack.map((skill) => (
            <span class="rounded-full border border-white/80 bg-slate-100/88 px-2.5 py-0.5 text-[0.72rem] font-medium text-muted-foreground">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </a>
</article>
