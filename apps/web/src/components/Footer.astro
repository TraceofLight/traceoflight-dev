---
import FooterIconLink from "./FooterIconLink.astro";
import { GITHUB_URL, SITE_TITLE } from "../consts";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-meta">
      <p class="footer-copy">ⓒ {currentYear}. {SITE_TITLE} All rights reserved.</p>
    </div>

    <div class="footer-links">
      <FooterIconLink href="mailto:rickyjun96@gmail.com" label="Email" icon="mail" />
      <FooterIconLink href={GITHUB_URL} label="GitHub" icon="github" external />
      <FooterIconLink href="/admin" label="Admin Settings" icon="admin" />
    </div>
  </div>
</footer>
