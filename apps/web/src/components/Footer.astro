---
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import { ADMIN_IMPORTS_PATH } from "../lib/admin/imports-page";
import { sanitizeNextPath } from "../lib/admin-redirect";
import type { VisitorSummary } from "../lib/server/ga4-summary";
import FooterIconLink from "./FooterIconLink.astro";
import FooterAdminModal from "./public/FooterAdminModal";
import { GITHUB_URL, SITE_TITLE } from "../consts";

interface Props {
  visitorSummary?: VisitorSummary | null;
}

const { visitorSummary = null } = Astro.props;
const currentYear = new Date().getFullYear();
const shouldOpenAdminLogin = Astro.url.searchParams.get("admin_login") === "1";
const adminNextPath = sanitizeNextPath(Astro.url.searchParams.get("next"));
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
---

<footer class="site-footer-surface border-t border-white/60 bg-white/72 backdrop-blur-xl">
  <div class="container flex flex-col gap-4 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <p class="text-sm text-muted-foreground">
        ⓒ {currentYear}. {SITE_TITLE} All rights reserved.
      </p>
      {
        visitorSummary ? (
          <p class="text-sm text-muted-foreground">
            Today {visitorSummary.todayVisitors} / Total {visitorSummary.totalVisitors}
          </p>
        ) : null
      }
    </div>

    <div class="site-footer-dock flex items-center gap-3 rounded-full border border-white/70 bg-white/72 px-3 py-2 shadow-[0_20px_50px_rgba(15,23,42,0.08)]">
      <FooterIconLink href="/portfolio" label="Portfolio PDF" icon="resume" external />
      <FooterIconLink
        href="mailto:rickyjun96@gmail.com"
        label="Email"
        icon="mail"
      />
      <FooterIconLink href={GITHUB_URL} label="GitHub" icon="github" external />
      {
        isAdminViewer ? (
          <FooterIconLink
            href={ADMIN_IMPORTS_PATH}
            label="Admin Console"
            icon="admin"
          />
        ) : (
          <FooterAdminModal
            client:only="react"
            adminNextPath={adminNextPath}
            shouldOpenOnLoad={shouldOpenAdminLogin}
          />
        )
      }
    </div>
  </div>
</footer>
