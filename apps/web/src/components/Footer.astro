---
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import { sanitizeNextPath } from "../lib/admin-redirect";
import FooterIconLink from "./FooterIconLink.astro";
import FooterAdminModal from "./public/FooterAdminModal";
import { GITHUB_URL, SITE_TITLE } from "../consts";

const currentYear = new Date().getFullYear();
const shouldOpenAdminLogin = Astro.url.searchParams.get("admin_login") === "1";
const adminNextPath = sanitizeNextPath(Astro.url.searchParams.get("next"));
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
---

<footer class="border-t bg-background/95">
  <div class="container flex flex-col gap-4 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <p class="text-sm text-muted-foreground">
        ⓒ {currentYear}. {SITE_TITLE} All rights reserved.
      </p>
    </div>

    <div class="flex items-center gap-3">
      <FooterIconLink
        href="mailto:rickyjun96@gmail.com"
        label="Email"
        icon="mail"
      />
      <FooterIconLink href={GITHUB_URL} label="GitHub" icon="github" external />
      <FooterAdminModal
        client:load
        adminNextPath={adminNextPath}
        isAdminViewer={isAdminViewer}
        shouldOpenOnLoad={shouldOpenAdminLogin}
      />
    </div>
  </div>
</footer>
