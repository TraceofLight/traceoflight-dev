---
import adminIcon from "../assets/icons/footer/admin.svg?raw";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import { sanitizeNextPath } from "../lib/admin-redirect";
import FooterIconLink from "./FooterIconLink.astro";
import { GITHUB_URL, SITE_TITLE } from "../consts";

const currentYear = new Date().getFullYear();
const shouldOpenAdminLogin = Astro.url.searchParams.get("admin_login") === "1";
const adminNextPath = sanitizeNextPath(Astro.url.searchParams.get("next"));
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-meta">
      <p class="footer-copy">
        ⓒ {currentYear}. {SITE_TITLE} All rights reserved.
      </p>
    </div>

    <div class="footer-links">
      <FooterIconLink
        href="mailto:rickyjun96@gmail.com"
        label="Email"
        icon="mail"
      />
      <FooterIconLink href={GITHUB_URL} label="GitHub" icon="github" external />
      <button
        id="footer-admin-trigger"
        class="icon-link footer-icon-link"
        type="button"
        aria-label={isAdminViewer ? "Admin Backup" : "Admin Login"}
      >
        <span
          class="footer-icon-glyph"
          aria-hidden="true"
          set:html={adminIcon}
        />
      </button>
    </div>
  </div>
</footer>

<div
  id="footer-admin-login-modal"
  class="footer-admin-login-modal"
  data-open="false"
  data-admin-viewer={isAdminViewer ? "true" : "false"}
  data-open-on-load={shouldOpenAdminLogin ? "true" : "false"}
  hidden
>
  <button
    id="footer-admin-login-backdrop"
    class="footer-admin-login-backdrop"
    type="button"
    aria-label="Close admin modal"></button>
  <section
    class="footer-admin-login-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="footer-admin-login-title"
  >
    {
      !isAdminViewer && (
        <form
          id="footer-admin-login-form"
          class="auth-form auth-shell"
          data-next={adminNextPath}
        >
          <p id="footer-admin-login-title" class="kicker auth-login-kicker">
            ADMIN LOGIN
          </p>
          <label>
            <span>아이디</span>
            <input
              id="footer-admin-username"
              name="username"
              type="text"
              autocomplete="username"
              required
            />
          </label>
          <label>
            <span>비밀번호</span>
            <input
              id="footer-admin-password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
            />
          </label>
          <button class="button" type="submit">로그인</button>
          <p id="footer-admin-feedback" class="auth-feedback" data-state="info">
            로그인 정보를 입력해 주세요.
          </p>
        </form>
      )
    }

    {
      isAdminViewer && (
        <section
          id="footer-admin-import-panel"
          class="auth-panel footer-admin-import-panel"
        >
          <p id="footer-admin-login-title" class="kicker auth-login-kicker">ADMIN BACKUP</p>
          <label class="footer-admin-import-field" for="footer-admin-backup-file">
            <span>백업 ZIP 파일</span>
            <input
              id="footer-admin-backup-file"
              type="file"
              accept=".zip,application/zip"
            />
          </label>
          <div class="footer-admin-import-actions">
            <button
              id="footer-admin-backup-download"
              class="button button-ghost"
              type="button"
            >
              DB 저장 ZIP 다운로드
            </button>
            <button
              id="footer-admin-backup-load"
              class="button button-brand"
              type="button"
            >
              ZIP 불러와 DB 복원
            </button>
          </div>
          <p
            id="footer-admin-import-feedback"
            class="auth-feedback"
            data-state="info"
          >
            현재 DB의 게시글/미디어를 ZIP으로 저장하거나 ZIP 파일로 복원하세요.
          </p>
        </section>
      )
    }
  </section>
</div>

<script type="module">
  const initializeFooterAdminLogin = () => {
    const trigger = document.querySelector("#footer-admin-trigger");
    const modal = document.querySelector("#footer-admin-login-modal");
    const backdrop = document.querySelector("#footer-admin-login-backdrop");
    const form = document.querySelector("#footer-admin-login-form");
    const usernameInput = document.querySelector("#footer-admin-username");
    const passwordInput = document.querySelector("#footer-admin-password");
    const feedback = document.querySelector("#footer-admin-feedback");
    const backupFileInput = document.querySelector("#footer-admin-backup-file");
    const backupDownloadButton = document.querySelector(
      "#footer-admin-backup-download",
    );
    const backupLoadButton = document.querySelector("#footer-admin-backup-load");
    const importFeedback = document.querySelector("#footer-admin-import-feedback");

    if (!(trigger instanceof HTMLButtonElement)) return;
    if (!(modal instanceof HTMLElement)) return;
    if (!(backdrop instanceof HTMLButtonElement)) return;

    const isAdminViewer = modal.dataset.adminViewer === "true";
    const nextPath = form instanceof HTMLFormElement ? form.dataset.next || "/" : "/";
    const setFeedback = (message, state = "info") => {
      if (!(feedback instanceof HTMLElement)) return;
      feedback.textContent = message;
      feedback.dataset.state = state;
    };
    const setImportFeedback = (message, state = "info") => {
      if (!(importFeedback instanceof HTMLElement)) return;
      importFeedback.textContent = message;
      importFeedback.dataset.state = state;
    };
    const setImportBusy = (busy) => {
      if (backupDownloadButton instanceof HTMLButtonElement) {
        backupDownloadButton.disabled = busy;
      }
      if (backupLoadButton instanceof HTMLButtonElement) {
        backupLoadButton.disabled = busy;
      }
      if (backupFileInput instanceof HTMLInputElement) {
        backupFileInput.disabled = busy;
      }
    };
    const readJsonSafe = async (response) => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };
    const resolveErrorMessage = (payload, fallback) => {
      if (payload && typeof payload === "object") {
        if (typeof payload.detail === "string" && payload.detail.trim()) {
          return payload.detail.trim();
        }
        if (typeof payload.message === "string" && payload.message.trim()) {
          return payload.message.trim();
        }
      }
      return fallback;
    };
    const openModal = () => {
      modal.dataset.mode = isAdminViewer ? "admin" : "login";
      modal.hidden = false;
      modal.dataset.open = "true";
    };

    const closeModal = () => {
      modal.hidden = true;
      modal.dataset.open = "false";
      if (!isAdminViewer) {
        setFeedback("로그인 정보를 입력해 주세요.", "info");
        return;
      }
      setImportFeedback("현재 DB의 게시글/미디어를 ZIP으로 저장하거나 ZIP 파일로 복원하세요.", "info");
    };

    if (modal.dataset.bound !== "true") {
      modal.dataset.bound = "true";

      trigger.addEventListener("click", openModal);
      backdrop.addEventListener("click", closeModal);

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") return;
        if (modal.dataset.open !== "true") return;
        event.preventDefault();
        closeModal();
      });

      if (
        form instanceof HTMLFormElement &&
        usernameInput instanceof HTMLInputElement &&
        passwordInput instanceof HTMLInputElement &&
        feedback instanceof HTMLElement
      ) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          setFeedback("로그인 처리 중...", "info");

          try {
            const response = await fetch("/internal-api/auth/login", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                username: usernameInput.value.trim(),
                password: passwordInput.value,
              }),
            });

            if (!response.ok) {
              const errorJson = await response.json().catch(() => ({}));
              setFeedback(errorJson.detail || "로그인에 실패했습니다.", "error");
              return;
            }

            window.location.assign(nextPath);
          } catch {
            setFeedback("네트워크 오류가 발생했습니다.", "error");
          }
        });
      }

      if (
        backupDownloadButton instanceof HTMLButtonElement &&
        backupLoadButton instanceof HTMLButtonElement &&
        importFeedback instanceof HTMLElement
      ) {
        backupDownloadButton.addEventListener("click", async () => {
          setImportBusy(true);
          setImportFeedback("DB 백업 ZIP을 생성 중입니다...", "pending");
          try {
            const response = await fetch("/internal-api/imports/backups/posts.zip");
            if (!response.ok) {
              const payload = await readJsonSafe(response);
              setImportFeedback(
                resolveErrorMessage(payload, "백업 ZIP 다운로드에 실패했습니다."),
                "error",
              );
              return;
            }

            const binary = await response.blob();
            const disposition = response.headers.get("content-disposition") ?? "";
            const matchedName = disposition.match(/filename=\"?([^\";]+)\"?/i);
            const fileName = matchedName?.[1]?.trim() || "traceoflight-posts-backup.zip";
            const url = URL.createObjectURL(binary);
            const anchor = document.createElement("a");
            anchor.href = url;
            anchor.download = fileName;
            document.body.append(anchor);
            anchor.click();
            anchor.remove();
            URL.revokeObjectURL(url);
            setImportFeedback("DB 백업 ZIP 다운로드를 시작했습니다.", "ok");
          } catch {
            setImportFeedback("백업 ZIP 다운로드 중 네트워크 오류가 발생했습니다.", "error");
          } finally {
            setImportBusy(false);
          }
        });

        backupLoadButton.addEventListener("click", async () => {
          if (!(backupFileInput instanceof HTMLInputElement)) {
            setImportFeedback("백업 파일 입력 UI를 찾을 수 없습니다.", "error");
            return;
          }
          const selectedFile = backupFileInput.files?.[0];
          if (!(selectedFile instanceof File)) {
            setImportFeedback("복원할 ZIP 파일을 선택해 주세요.", "error");
            return;
          }

          setImportBusy(true);
          setImportFeedback("백업 ZIP에서 DB 복원을 실행 중입니다...", "pending");
          try {
            const payloadBody = new FormData();
            payloadBody.set("file", selectedFile, selectedFile.name);
            const response = await fetch("/internal-api/imports/backups/load", {
              method: "POST",
              body: payloadBody,
            });
            const payload = await readJsonSafe(response);
            if (!response.ok) {
              setImportFeedback(
                resolveErrorMessage(payload, "DB 복원 실행에 실패했습니다."),
                "error",
              );
              return;
            }

            const restoredPosts =
              payload && typeof payload.restored_posts === "number"
                ? payload.restored_posts
                : 0;
            const restoredMedia =
              payload && typeof payload.restored_media === "number"
                ? payload.restored_media
                : 0;
            const restoredSeriesOverrides =
              payload && typeof payload.restored_series_overrides === "number"
                ? payload.restored_series_overrides
                : 0;
            backupFileInput.value = "";
            setImportFeedback(
              `DB 복원 완료: 게시글 ${restoredPosts}, 미디어 ${restoredMedia}, 시리즈 썸네일 ${restoredSeriesOverrides}`,
              "ok",
            );
          } catch {
            setImportFeedback("DB 복원 요청 중 네트워크 오류가 발생했습니다.", "error");
          } finally {
            setImportBusy(false);
          }
        });
      }
    }

    if (modal.dataset.openOnLoad === "true") {
      openModal();
      const current = new URL(window.location.href);
      current.searchParams.delete("admin_login");
      current.searchParams.delete("next");
      window.history.replaceState(
        {},
        "",
        `${current.pathname}${current.search}${current.hash}`,
      );
    }
  };

  initializeFooterAdminLogin();
  document.addEventListener("astro:page-load", initializeFooterAdminLogin);
</script>
