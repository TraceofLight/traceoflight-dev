---
import adminIcon from "../assets/icons/footer/admin.svg?raw";
import { sanitizeNextPath } from "../lib/admin-redirect";
import FooterIconLink from "./FooterIconLink.astro";
import { GITHUB_URL, SITE_TITLE } from "../consts";

const currentYear = new Date().getFullYear();
const shouldOpenAdminLogin = Astro.url.searchParams.get("admin_login") === "1";
const adminNextPath = sanitizeNextPath(Astro.url.searchParams.get("next"));
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-meta">
      <p class="footer-copy">
        ⓒ {currentYear}. {SITE_TITLE} All rights reserved.
      </p>
    </div>

    <div class="footer-links">
      <FooterIconLink
        href="mailto:rickyjun96@gmail.com"
        label="Email"
        icon="mail"
      />
      <FooterIconLink href={GITHUB_URL} label="GitHub" icon="github" external />
      <button
        id="footer-admin-trigger"
        class="icon-link footer-icon-link"
        type="button"
        aria-label="Admin Login"
      >
        <span
          class="footer-icon-glyph"
          aria-hidden="true"
          set:html={adminIcon}
        />
      </button>
    </div>
  </div>
</footer>

<div
  id="footer-admin-login-modal"
  class="footer-admin-login-modal"
  data-open="false"
  data-open-on-load={shouldOpenAdminLogin ? "true" : "false"}
  hidden
>
  <button
    id="footer-admin-login-backdrop"
    class="footer-admin-login-backdrop"
    type="button"
    aria-label="Close admin login"></button>
  <section
    class="footer-admin-login-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="footer-admin-login-title"
  >
    <form
      id="footer-admin-login-form"
      class="auth-form auth-shell"
      data-next={adminNextPath}
    >
      <p id="footer-admin-login-title" class="kicker auth-login-kicker">
        ADMIN LOGIN
      </p>
      <label>
        <span>아이디</span>
        <input
          id="footer-admin-username"
          name="username"
          type="text"
          autocomplete="username"
          required
        />
      </label>
      <label>
        <span>비밀번호</span>
        <input
          id="footer-admin-password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
        />
      </label>
      <button class="button" type="submit">로그인</button>
      <p id="footer-admin-feedback" class="auth-feedback" data-state="info">
        로그인 정보를 입력해 주세요.
      </p>
    </form>
  </section>
</div>

<script type="module">
  const initializeFooterAdminLogin = () => {
    const trigger = document.querySelector("#footer-admin-trigger");
    const modal = document.querySelector("#footer-admin-login-modal");
    const backdrop = document.querySelector("#footer-admin-login-backdrop");
    const form = document.querySelector("#footer-admin-login-form");
    const usernameInput = document.querySelector("#footer-admin-username");
    const passwordInput = document.querySelector("#footer-admin-password");
    const feedback = document.querySelector("#footer-admin-feedback");

    if (!(trigger instanceof HTMLButtonElement)) return;
    if (!(modal instanceof HTMLElement)) return;
    if (!(backdrop instanceof HTMLButtonElement)) return;
    if (!(form instanceof HTMLFormElement)) return;
    if (!(usernameInput instanceof HTMLInputElement)) return;
    if (!(passwordInput instanceof HTMLInputElement)) return;
    if (!(feedback instanceof HTMLElement)) return;
    if (modal.dataset.bound === "true") return;
    modal.dataset.bound = "true";

    const nextPath = form.dataset.next || "/";
    const setFeedback = (message, state = "info") => {
      feedback.textContent = message;
      feedback.dataset.state = state;
    };

    const openModal = () => {
      modal.hidden = false;
      modal.dataset.open = "true";
    };

    const closeModal = () => {
      modal.hidden = true;
      modal.dataset.open = "false";
      setFeedback("로그인 정보를 입력해 주세요.", "info");
    };

    trigger.addEventListener("click", openModal);
    backdrop.addEventListener("click", closeModal);

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (modal.dataset.open !== "true") return;
      event.preventDefault();
      closeModal();
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      setFeedback("로그인 처리 중...", "info");

      try {
        const response = await fetch("/internal-api/auth/login", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            username: usernameInput.value.trim(),
            password: passwordInput.value,
          }),
        });

        if (!response.ok) {
          const errorJson = await response.json().catch(() => ({}));
          setFeedback(errorJson.detail || "로그인에 실패했습니다.", "error");
          return;
        }

        window.location.assign(nextPath);
      } catch {
        setFeedback("네트워크 오류가 발생했습니다.", "error");
      }
    });

    if (modal.dataset.openOnLoad === "true") {
      openModal();
      const current = new URL(window.location.href);
      current.searchParams.delete("admin_login");
      current.searchParams.delete("next");
      window.history.replaceState(
        {},
        "",
        `${current.pathname}${current.search}${current.hash}`,
      );
    }
  };

  initializeFooterAdminLogin();
  document.addEventListener("astro:page-load", initializeFooterAdminLogin);
</script>
