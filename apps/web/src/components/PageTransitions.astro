---
import { ClientRouter } from 'astro:transitions';

import { createPageTransitionStyles } from '../lib/page-transition';

const transitionStyles = createPageTransitionStyles({
  rootName: 'root',
  durationMs: 260,
  distancePx: 0,
});
---

<ClientRouter fallback="swap" />
<style is:global set:html={transitionStyles} />
