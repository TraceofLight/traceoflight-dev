---
import menuIcon from "../../assets/icons/utility/menu.svg?raw";
import {
  PUBLIC_DANGER_OUTLINE_ACTION_CLASS,
  PUBLIC_ICON_ACTION_CLASS,
} from "../../lib/ui-effects";

type NavItem = {
  href: string;
  label: string;
};

interface Props {
  items: readonly NavItem[];
  isAdminViewer: boolean;
}

const { items, isAdminViewer } = Astro.props;
const ADMIN_IMPORTS_PATH = "/admin";
const triggerClass = `${PUBLIC_ICON_ACTION_CLASS} focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2`;
---

<button
  aria-label="Open navigation"
  type="button"
  data-mobile-nav-trigger
  class={triggerClass}
>
  <span class="h-4 w-4 [&>svg]:h-4 [&>svg]:w-4" aria-hidden="true" set:html={menuIcon}></span>
</button>

<dialog
  class="mobile-nav-sheet"
  data-mobile-nav-sheet
  aria-label="Mobile navigation"
>
  <button
    aria-label="닫기"
    type="button"
    data-mobile-nav-close
    class="mobile-nav-close absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/80 bg-white/90 text-base text-muted-foreground shadow-[0_8px_20px_rgba(15,23,42,0.08)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-white hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
  >
    <span aria-hidden="true">×</span>
  </button>
  <nav class="mt-2 flex flex-col gap-1.5" aria-label="Mobile navigation">
    {items.map((item) => (
      <a
        class="rounded-2xl px-4 py-3 text-base font-medium text-foreground transition-all duration-200 hover:bg-white/84 hover:shadow-[0_8px_24px_rgba(15,23,42,0.08)]"
        href={item.href}
      >
        {item.label}
      </a>
    ))}
    {isAdminViewer && (
      <>
        <a
          class="rounded-2xl px-4 py-3 text-base font-medium text-red-700 transition-all duration-200 hover:bg-red-50 hover:shadow-[0_8px_24px_rgba(239,68,68,0.12)]"
          href={ADMIN_IMPORTS_PATH}
        >
          Admin
        </a>
        <form action="/logout?next=/" class="pt-3" method="POST">
          <button
            class={`w-full justify-center ${PUBLIC_DANGER_OUTLINE_ACTION_CLASS}`}
            type="submit"
          >
            Logout
          </button>
        </form>
      </>
    )}
  </nav>
</dialog>

<style>
  .mobile-nav-sheet {
    /* Floating right-side slide-out panel; inset overrides Tailwind preflight margin reset. */
    inset: 0.75rem 0.75rem 0.75rem auto;
    margin: 0;
    width: min(22rem, calc(100vw - 1.5rem));
    max-width: none;
    height: auto;
    max-height: calc(100vh - 1.5rem);
    padding: 3rem 1.25rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 1.75rem;
    background-color: rgba(255, 255, 255, 0.95);
    color: hsl(var(--foreground));
    box-shadow: -24px 24px 64px rgba(15, 23, 42, 0.18);
    backdrop-filter: blur(24px);
    opacity: 0;
    transform: translateX(110%);
    transition:
      transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 260ms ease,
      overlay 260ms ease allow-discrete,
      display 260ms ease allow-discrete;
  }

  .mobile-nav-sheet[open] {
    opacity: 1;
    transform: translateX(0);
  }

  @starting-style {
    .mobile-nav-sheet[open] {
      opacity: 0;
      transform: translateX(110%);
    }
  }

  .mobile-nav-sheet::backdrop {
    background-color: rgba(2, 6, 23, 0);
    backdrop-filter: blur(0);
    transition:
      background-color 260ms ease,
      backdrop-filter 260ms ease,
      display 260ms ease allow-discrete;
  }

  .mobile-nav-sheet[open]::backdrop {
    background-color: rgba(2, 6, 23, 0.16);
    backdrop-filter: blur(4px);
  }

  @starting-style {
    .mobile-nav-sheet[open]::backdrop {
      background-color: rgba(2, 6, 23, 0);
      backdrop-filter: blur(0);
    }
  }

  :root[data-theme="dark"] .mobile-nav-sheet {
    border-color: rgba(255, 255, 255, 0.08);
    background-color: rgba(15, 23, 42, 0.96);
  }
</style>

<script is:inline>
  (() => {
    const setup = () => {
      const dialog = document.querySelector("[data-mobile-nav-sheet]");
      const trigger = document.querySelector("[data-mobile-nav-trigger]");
      if (!(dialog instanceof HTMLDialogElement) || !(trigger instanceof HTMLElement)) {
        return;
      }
      // Per-element guard so View Transition swaps wire fresh DOM but never double-bind.
      if (dialog.dataset.bound === "true") {
        return;
      }
      dialog.dataset.bound = "true";

      trigger.addEventListener("click", () => {
        if (!dialog.open) {
          dialog.showModal();
        }
      });

      const closeButton = dialog.querySelector("[data-mobile-nav-close]");
      if (closeButton instanceof HTMLElement) {
        closeButton.addEventListener("click", () => {
          dialog.close();
        });
      }

      // Close when clicking on the backdrop (outside the dialog content rect).
      dialog.addEventListener("click", (event) => {
        if (event.target !== dialog) return;
        const rect = dialog.getBoundingClientRect();
        const clickedInside =
          event.clientX >= rect.left &&
          event.clientX <= rect.right &&
          event.clientY >= rect.top &&
          event.clientY <= rect.bottom;
        if (!clickedInside) {
          dialog.close();
        }
      });

      // Auto-close when navigating via an in-sheet link (browser doesn't fire
      // a navigation event before unload on same-document jumps, but anchor
      // clicks should dismiss the panel for visual cleanliness).
      dialog.addEventListener("click", (event) => {
        const target = event.target;
        if (target instanceof HTMLAnchorElement && dialog.contains(target)) {
          dialog.close();
        }
      });
    };

    document.addEventListener("astro:page-load", setup);
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup);
    } else {
      setup();
    }
  })();
</script>
