---
import { pickDictionary } from "../../lib/i18n/dictionary";

interface AlternateLink {
  hrefLang: string;
  href: URL | string;
}

interface Props {
  locale: string;
  alternates: ReadonlyArray<AlternateLink>;
}

// Native-names pattern: always show each language in its own name regardless of viewer locale.
const LANG_LABELS = pickDictionary("ko").languageToggle;

const { locale, alternates } = Astro.props;
const visible = alternates.filter(
  (alt) => alt.hrefLang !== "x-default" && alt.hrefLang !== locale,
);
---

<nav aria-label="Language" class="flex flex-wrap gap-2 text-xs text-slate-500">
  {visible.map((alt) => (
    <a
      class="rounded-md px-2 py-1 underline-offset-2 transition hover:bg-white/60 hover:text-slate-700"
      hreflang={alt.hrefLang}
      href={typeof alt.href === "string" ? alt.href : alt.href.toString()}
      lang={alt.hrefLang}
    >
      {LANG_LABELS[alt.hrefLang as keyof typeof LANG_LABELS] ?? alt.hrefLang}
    </a>
  ))}
</nav>
