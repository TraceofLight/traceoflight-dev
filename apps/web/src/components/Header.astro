---
import { Image } from "astro:assets";

import profileImage from "../assets/traceoflight-profile.png";
import { NAV_LINKS, SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <Image
        src={profileImage}
        alt={`${SITE_TITLE} profile`}
        width={36}
        height={36}
        class="brand-avatar"
      />
      <span class="brand-name">{SITE_TITLE}</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      {
        NAV_LINKS.map((item) => (
          <HeaderLink href={item.href}>{item.label}</HeaderLink>
        ))
      }
    </nav>
  </div>
</header>
