---
import { NAV_LINKS, SITE_TITLE } from "../consts";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import { ADMIN_IMPORTS_PATH } from "../lib/admin/imports-page";
import { DANGER_PILL_ACTION_CLASS } from "../lib/ui-effects";
import HeaderLink from "./HeaderLink.astro";
import MobileNavSheet from "./public/MobileNavSheet.astro";
import LanguageToggle from "./public/LanguageToggle.astro";

interface Props {
  locale?: string;
  alternates?: ReadonlyArray<{ hrefLang: string; href: URL | string }>;
}

const { locale = 'ko', alternates = [] } = Astro.props;
const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? await verifyAccessToken(accessToken) : false;
---

<header class="site-header-surface sticky top-0 z-40 border-b border-white/60 bg-white/78 backdrop-blur-xl supports-[backdrop-filter]:bg-white/64">
  <div class="container flex min-h-16 items-center justify-between gap-4 py-3">
    <div class="flex items-center gap-3">
      <a href="/" class="text-base font-semibold tracking-tight text-foreground">
        {SITE_TITLE}
      </a>
      {
        isAdminViewer && (
          <div class="hidden items-center gap-2 md:flex">
            <form class="flex" method="GET" action={ADMIN_IMPORTS_PATH}>
              <button
                id="header-admin-link"
                class={DANGER_PILL_ACTION_CLASS}
                type="submit"
              >
                Admin
              </button>
            </form>
            <form class="flex" method="POST" action="/logout?next=/">
              <button
                id="header-admin-logout"
                class={DANGER_PILL_ACTION_CLASS}
                type="submit"
              >
                Logout
              </button>
            </form>
          </div>
        )
      }
    </div>
    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
        {
          NAV_LINKS.map((item) => (
            <HeaderLink href={item.href}>{item.label}</HeaderLink>
          ))
        }
      </nav>
      {alternates.length > 0 && <LanguageToggle locale={locale} alternates={alternates} />}
      <div class="md:hidden">
        <MobileNavSheet items={NAV_LINKS} isAdminViewer={isAdminViewer} />
      </div>
    </div>
  </div>
</header>
