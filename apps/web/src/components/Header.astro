---
import { NAV_LINKS, SITE_TITLE } from "../consts";
import { ADMIN_ACCESS_COOKIE, verifyAccessToken } from "../lib/admin-auth";
import HeaderLink from "./HeaderLink.astro";
import MobileNavSheet from "./public/MobileNavSheet";

const accessToken = Astro.cookies.get(ADMIN_ACCESS_COOKIE)?.value ?? "";
const isAdminViewer = accessToken ? verifyAccessToken(accessToken) : false;
---

<header class="sticky top-0 z-40 border-b border-white/60 bg-white/78 backdrop-blur-xl supports-[backdrop-filter]:bg-white/64">
  <div class="container flex min-h-16 items-center justify-between gap-4 py-3">
    <div class="flex items-center gap-3">
      <a href="/" class="text-base font-semibold tracking-tight text-foreground">
        {SITE_TITLE}
      </a>
      {
        isAdminViewer && (
          <div class="hidden items-center gap-2 md:flex">
            <span
              id="header-admin-link"
              class="inline-flex rounded-full border border-white/80 bg-white/88 px-2.5 py-1 text-xs font-medium text-muted-foreground shadow-[0_10px_30px_rgba(15,23,42,0.06)]"
              aria-disabled="true"
            >
              Admin
            </span>
            <form method="POST" action="/internal-api/auth/logout?next=/">
              <button
                id="header-admin-logout"
                class="inline-flex items-center rounded-full border border-white/80 bg-white/88 px-3 py-1.5 text-xs font-medium text-muted-foreground shadow-[0_10px_30px_rgba(15,23,42,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-white hover:text-foreground"
                type="submit"
              >
                Logout
              </button>
            </form>
          </div>
        )
      }
    </div>
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        NAV_LINKS.map((item) => (
          <HeaderLink href={item.href}>{item.label}</HeaderLink>
        ))
      }
    </nav>

    <div class="md:hidden">
      <MobileNavSheet client:load items={NAV_LINKS} isAdminViewer={isAdminViewer} />
    </div>
  </div>
</header>
