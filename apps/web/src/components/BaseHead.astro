---
import '../styles/global.css';

import type { ImageMetadata } from 'astro';

import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';
import { resolvePublicSiteOrigin } from '../lib/public-url';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  imageUrl?: string;
  pageType?: 'website' | 'article';
  author?: string;
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  structuredData?: Record<string, unknown>;
  robots?: string;
}

const {
  title,
  description,
  image,
  imageUrl,
  pageType = 'website',
  author,
  publishedTime,
  modifiedTime,
  structuredData,
  robots,
} = Astro.props;

const canonicalBase = resolvePublicSiteOrigin(Astro.site ?? SITE_URL);
const canonicalURL = new URL(Astro.url.pathname, canonicalBase);
const fallbackOgImageWidth = 512;
const fallbackOgImageHeight = 512;
const ogImage = image
  ? new URL(image.src, canonicalBase)
  : new URL('/android-chrome-512x512.png', canonicalBase);
const resolvedOgImage = imageUrl ? new URL(imageUrl, canonicalBase) : ogImage;
const ogImageWidth = imageUrl ? undefined : (image?.width ?? fallbackOgImageWidth);
const ogImageHeight = imageUrl ? undefined : (image?.height ?? fallbackOgImageHeight);
const fullTitle = title.includes(SITE_TITLE) ? title : `${title} | ${SITE_TITLE}`;
const resolvedAuthor = author?.trim() || SITE_AUTHOR;
const publishedTimeIso = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedTimeIso = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : undefined;
const iconVersion = '20260313';
const ga4MeasurementIdRaw = (process.env.GA4_MEASUREMENT_ID ?? '').trim();
const ga4MeasurementId = /^G-[A-Z0-9]+$/i.test(ga4MeasurementIdRaw) ? ga4MeasurementIdRaw : '';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<link
  rel="preload"
  as="style"
  href="/fonts/pretendard/pretendardvariable-dynamic-subset.css"
/>
<link
  rel="stylesheet"
  href="/fonts/pretendard/pretendardvariable-dynamic-subset.css"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link rel="stylesheet" href="/fonts/pretendard/pretendardvariable-dynamic-subset.css" />
</noscript>

<meta name="application-name" content={SITE_TITLE} />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />
<meta name="naver-site-verification" content="1aa143e14a9d879989a4feba3cb5760163acb7a5" />
<link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${iconVersion}`} />
<link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32x32.png?v=${iconVersion}`} />
<link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16x16.png?v=${iconVersion}`} />
<link rel="shortcut icon" href={`/favicon.ico?v=${iconVersion}`} />
<link rel="icon" href={`/favicon.ico?v=${iconVersion}`} sizes="any" />
<link rel="manifest" href={`/site.webmanifest?v=${iconVersion}`} />
<link rel="sitemap" href="/sitemap.xml" />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', canonicalBase)} />

<script is:inline>
  (() => {
    const storageKey = "traceoflight-theme";
    const applyTheme = () => {
      const storedTheme = localStorage.getItem(storageKey);
      const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const theme = storedTheme === "dark" || storedTheme === "light"
        ? storedTheme
        : systemPrefersDark
          ? "dark"
          : "light";
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme;
    };

    applyTheme();

    if (!window.__traceoflightThemeListenerBound) {
      document.addEventListener("astro:after-swap", applyTheme);
      document.addEventListener("astro:page-load", applyTheme);
      window.__traceoflightThemeListenerBound = true;
    }
  })();
</script>

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={resolvedAuthor} />
{robots && <meta name="robots" content={robots} />}

<meta property="og:type" content={pageType} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:alt" content={fullTitle} />
{ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
{ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
<meta property="og:locale" content="ko_KR" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedOgImage} />
<meta property="twitter:image:alt" content={fullTitle} />

{
  pageType === 'article' && publishedTimeIso && (
    <meta property="article:published_time" content={publishedTimeIso} />
  )
}
{
  pageType === 'article' && modifiedTimeIso && (
    <meta property="article:modified_time" content={modifiedTimeIso} />
  )
}
{structuredDataJson && <script is:inline type="application/ld+json" set:html={structuredDataJson} />}

{
  ga4MeasurementId && (
    <>
      <script is:inline define:vars={{ ga4MeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = window.gtag || gtag;

        if (!window.__traceoflightGa4Configured) {
          window.gtag('js', new Date());
          window.gtag('config', ga4MeasurementId, {
            send_page_view: false,
            anonymize_ip: true,
          });
          window.__traceoflightGa4Configured = true;
        }

        // gtag.js 자체는 LCP 이후 idle 시점에 동적 주입.
        // dataLayer가 큐 역할이라 그 전 호출(gtag('config'), page_view 등)은 보존됨.
        if (!window.__traceoflightGa4ScriptScheduled) {
          window.__traceoflightGa4ScriptScheduled = true;
          var injectGa4Script = function () {
            if (window.__traceoflightGa4ScriptInjected) return;
            window.__traceoflightGa4ScriptInjected = true;
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4MeasurementId;
            document.head.appendChild(script);
          };
          if (typeof window.requestIdleCallback === 'function') {
            window.requestIdleCallback(injectGa4Script, { timeout: 4000 });
          } else {
            window.setTimeout(injectGa4Script, 2500);
          }
        }

        window.__traceoflightTrackPageView =
          window.__traceoflightTrackPageView ||
          function () {
            if (typeof window.gtag !== 'function') return;
            window.gtag('event', 'page_view', {
              page_location: window.location.href,
              page_path: `${window.location.pathname}${window.location.search}`,
              page_title: document.title,
            });
          };

        if (!window.__traceoflightGa4ListenerBound) {
          document.addEventListener('astro:page-load', window.__traceoflightTrackPageView);
          window.__traceoflightGa4ListenerBound = true;
        }

        window.__traceoflightTrackPageView();
      </script>
    </>
  )
}
