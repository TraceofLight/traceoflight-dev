---
interface Props {
  title: string;
  description: string;
  href: string;
  actionLabel: string;
}

const { title, description, href, actionLabel } = Astro.props;
---

<div
  class="mx-auto grid max-w-2xl gap-4 rounded-3xl border border-dashed border-border/70 bg-card/80 px-6 py-10 text-center shadow-sm"
>
  <h2
    class="text-balance text-2xl font-semibold tracking-tight text-foreground sm:text-3xl"
  >
    {title}
  </h2>
  <p
    class="mx-auto max-w-xl text-sm leading-7 text-muted-foreground sm:text-base"
  >
    {description}
  </p>
  <a
    class="inline-flex justify-self-center rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
    href={href}
  >
    {actionLabel}
  </a>
</div>
