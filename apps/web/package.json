{
  "name": "traceoflight-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "fonts:sync": "node scripts/copy-pretendard-fonts.mjs",
    "predev": "bun run fonts:sync",
    "prebuild": "bun run fonts:sync",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:guards": "bash -O globstar -c 'mkdir -p test-results && node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results/guards-junit.xml tests/**/*.test.mjs'",
    "test:ui": "mkdir -p test-results && vitest run tests/ui --reporter=default --reporter=junit --outputFile.junit=test-results/ui-junit.xml",
    "test:auth": "bash -O globstar -c 'mkdir -p test-results && node --import tsx --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results/auth-junit.xml tests/admin-auth/**/*.test.ts'",
    "test": "bun run typecheck && bun run test:guards && bun run test:ui && bun run test:auth",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@google-analytics/data": "^5.2.1",
    "@milkdown/crepe": "^7.19.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "astro": "5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "pretendard": "^1.3.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "private": true,
  "trustedDependencies": [
    "esbuild",
    "protobufjs",
    "sharp"
  ],
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
