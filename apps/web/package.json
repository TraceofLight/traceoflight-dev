{
  "name": "traceoflight-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:guards": "node --test tests/**/*.test.mjs",
    "test:ui": "vitest run tests/ui",
    "test:auth": "node --import tsx --test tests/admin-auth/**/*.test.ts",
    "test": "npm run typecheck && npm run test:guards && npm run test:ui && npm run test:auth",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@milkdown/crepe": "^7.19.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "astro": "5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
