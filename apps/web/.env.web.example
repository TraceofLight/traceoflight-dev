# IndexNow ownership-verification key file. Web hosts /<INDEXNOW_KEY>.txt
# echoing the key, and apps/api uses the same value to ping the protocol
# endpoint when posts publish. Leave empty to disable the verification route.
INDEXNOW_KEY=
