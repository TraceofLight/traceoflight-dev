APP_NAME=traceoflight-api-rs
APP_ENV=production
# Port convention: 6101=api-rs, 6102=postgres, 6103=minio-api,
# 6104=minio-console, 6105=redis.
API_RS_PORT=6101
RUST_LOG=info,sqlx=warn
LOG_FORMAT=pretty

# Either set DATABASE_URL directly, OR set POSTGRES_* discrete vars.
# DATABASE_URL takes precedence if both are present.
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=postgres
POSTGRES_PORT=

DATABASE_MAX_CONNECTIONS=10

# Comma-separated origin list. Empty disables CORS headers entirely (curl-only).
# Example: https://www.traceoflight.dev,http://localhost:4321
CORS_ALLOW_ORIGINS=

# Shared secret for `x-internal-api-secret` header. Trusted callers can request
# draft/private posts and (in the future) write endpoints. Empty disables the
# trust check entirely (no internal access). Must match the web app.
INTERNAL_API_SECRET=

# Reading-time estimate words/minute used by `reading_label` on summaries.
READING_WORDS_PER_MINUTE=200

# Object storage (MinIO / S3-compatible). MINIO_ENDPOINT is consumed by the
# backend; MINIO_API_PORT / MINIO_CONSOLE_PORT are consumed by the infra
# compose to start the MinIO server itself.
MINIO_ENDPOINT=
MINIO_API_PORT=
MINIO_CONSOLE_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=900
# MINIO_REGION=us-east-1

# Redis (refresh-token rotation store, optional but required for /admin/auth/*).
# REDIS_URL is consumed by the backend; REDIS_PORT is consumed by the infra
# compose to start the redis server.
REDIS_URL=
REDIS_PORT=

# Admin auth.
ADMIN_LOGIN_ID=
ADMIN_LOGIN_PASSWORD=
ADMIN_LOGIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_ACCESS_TOKEN_MAX_AGE_SECONDS=900
ADMIN_REFRESH_TOKEN_MAX_AGE_SECONDS=1209600
