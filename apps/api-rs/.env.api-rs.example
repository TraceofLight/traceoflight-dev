APP_NAME=traceoflight-api-rs
APP_ENV=production
# Port convention (apps/api/.env.api): 6101=api, 6102=postgres, 6103=minio-api,
# 6104=minio-console, 6105=redis. api-rs targets 6101 at cutover (replaces
# FastAPI). During parallel testing while FastAPI still runs, set to 6106.
API_RS_PORT=6101
RUST_LOG=info,sqlx=warn
LOG_FORMAT=pretty

# Either set DATABASE_URL directly, OR set POSTGRES_* (same values as apps/api).
# DATABASE_URL takes precedence if both are present.
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=postgres
POSTGRES_PORT=

DATABASE_MAX_CONNECTIONS=10

# Comma-separated origin list. Empty disables CORS headers entirely (curl-only).
# Example: https://www.traceoflight.dev,http://localhost:4321
CORS_ALLOW_ORIGINS=

# Shared secret for `x-internal-api-secret` header. Trusted callers can request
# draft/private posts and (in the future) write endpoints. Empty disables the
# trust check entirely (no internal access). Must match apps/api/.env.api.
INTERNAL_API_SECRET=

# Reading-time estimate words/minute used by `reading_label` on summaries.
READING_WORDS_PER_MINUTE=200

# Object storage (MinIO / S3-compatible). Used by /media/upload-url to issue
# presigned PUT URLs and by /media/upload-proxy as the upstream target.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=900
# MINIO_REGION=us-east-1
