APP_NAME=your-api-name
APP_ENV=production
API_PORT=your_api_port
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=https://example.com,https://www.example.com,http://localhost:3000

POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db
POSTGRES_HOST=postgres
POSTGRES_PORT=your_postgres_port

MINIO_ENDPOINT=your_minio_endpoint
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=your_media_bucket
REDIS_URL=redis://redis:your_redis_port/0
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=900
ADMIN_LOGIN_ID=your_master_admin_id
ADMIN_LOGIN_PASSWORD_HASH=your_master_admin_password_hash
ADMIN_LOGIN_PASSWORD=
ADMIN_SESSION_SECRET=your_admin_session_secret
ADMIN_ACCESS_TOKEN_MAX_AGE_SECONDS=900
ADMIN_REFRESH_TOKEN_MAX_AGE_SECONDS=1209600

DRAFT_RETENTION_DAYS=7
MEDIA_ORPHAN_RETENTION_DAYS=7
DRAFT_CLEANUP_START_HOUR=0
DRAFT_CLEANUP_END_HOUR=5
