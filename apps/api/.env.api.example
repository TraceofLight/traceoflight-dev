APP_NAME=traceoflight-api
APP_ENV=production
# Port convention: 6101=api, 6102=postgres, 6103=minio-api,
# 6104=minio-console, 6105=redis.
API_PORT=6101
RUST_LOG=info,sqlx=warn
LOG_FORMAT=pretty

# Either set DATABASE_URL directly, OR set POSTGRES_* discrete vars.
# DATABASE_URL takes precedence if both are present.
#
# Defaults below match `infra/docker/infra/docker-compose.yml`'s built-in
# fallbacks — `cp .env.api.example .env.api` is enough to bring up infra
# locally. Production deploys overwrite POSTGRES_PASSWORD / secrets via the
# Jenkins credential file.
DATABASE_URL=
POSTGRES_USER=traceoflight
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=traceoflight
POSTGRES_HOST=postgres
POSTGRES_PORT=6102

DATABASE_MAX_CONNECTIONS=10

# Comma-separated origin list. Empty disables CORS headers entirely (curl-only).
# Example: https://www.traceoflight.dev,http://localhost:4321
CORS_ALLOW_ORIGINS=

# Shared secret for `x-internal-api-secret` header. Trusted callers can request
# draft/private posts and write operations. Must match the web app.
# REPLACE for any non-local deploy.
INTERNAL_API_SECRET=change-this-internal-api-secret-please-replace

# Reading-time estimate words/minute used by `reading_label` on summaries.
READING_WORDS_PER_MINUTE=200

# Object storage (MinIO / S3-compatible). MINIO_ENDPOINT is consumed by the
# backend; MINIO_API_PORT / MINIO_CONSOLE_PORT are consumed by the infra
# compose to start the MinIO server itself.
MINIO_ENDPOINT=minio:6103
MINIO_API_PORT=6103
MINIO_CONSOLE_PORT=6104
MINIO_ACCESS_KEY=traceoflight
MINIO_SECRET_KEY=change-this-minio-password
MINIO_BUCKET=traceoflight-media
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=900
# MINIO_REGION=us-east-1

# Redis (refresh-token rotation store, optional but required for /admin/auth/*).
# REDIS_URL is consumed by the backend; REDIS_PORT is consumed by the infra
# compose to start the redis server.
REDIS_URL=redis://redis:6105/0
REDIS_PORT=6105

# Admin auth. REPLACE the passwords/secrets for any non-local deploy.
ADMIN_LOGIN_ID=admin
ADMIN_LOGIN_PASSWORD=change-this-admin-password
ADMIN_LOGIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=change-this-session-secret-32-bytes-or-more-please-replace
ADMIN_ACCESS_TOKEN_MAX_AGE_SECONDS=900
ADMIN_REFRESH_TOKEN_MAX_AGE_SECONDS=1209600
