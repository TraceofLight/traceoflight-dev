# Local test runner env. After `git clone`, just run:
#
#   bash apps/api/scripts/test-local.sh
#
# That script bootstraps everything that's missing — copies this file to
# `.env.test`, copies `.env.api.example` to `.env.api`, brings up the
# compose stack with `--env-file`, builds the test image, and runs
# `cargo test` inside a container joined to the `api_internal` network so
# postgres / redis / minio are reachable by service name (no host ports
# needed).
#
# All values below match `docker-compose.yml`'s built-in defaults so a
# fresh-clone run works with zero edits.
#
# Note: if you previously ran the compose with different credentials (e.g.
# pulled prod values into `.env.api`), the postgres volume retains the old
# password and dummy creds will be rejected. `docker compose -f
# infra/docker/infra/docker-compose.yml --env-file apps/api/.env.api down
# -v` wipes volumes so the new init values take effect.

# --- Test runner connection (sqlx::test admin handle) ----------------------
# Hostnames are docker compose service names — only resolvable from inside
# the api_internal network. The test container joins that network.
DATABASE_URL=postgres://traceoflight:change-this-password@postgres:6102/traceoflight_test
TEST_DATABASE_URL=postgres://traceoflight:change-this-password@postgres:6102/traceoflight_test
DATABASE_URL_ADMIN=postgres://traceoflight:change-this-password@postgres:6102/postgres

POSTGRES_USER=traceoflight
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=traceoflight
POSTGRES_HOST=postgres
POSTGRES_PORT=6102

# --- Redis (key prefix UUID is added per-test by spawn_test_app) -----------
REDIS_URL=redis://redis:6105/0
REDIS_PORT=6105

# --- MinIO (bucket UUID is added per-test by spawn_test_app) ---------------
MINIO_ENDPOINT=minio:6103
MINIO_API_PORT=6103
MINIO_CONSOLE_PORT=6104
MINIO_ACCESS_KEY=traceoflight
MINIO_SECRET_KEY=change-this-minio-password
MINIO_BUCKET=traceoflight-media-test
MINIO_REGION=us-east-1
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=900

# --- Admin auth (any non-empty value works for tests) ----------------------
ADMIN_LOGIN_ID=test-admin
ADMIN_LOGIN_PASSWORD=test-password-please-change
ADMIN_LOGIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=test-session-secret-please-change
ADMIN_ACCESS_TOKEN_MAX_AGE_SECONDS=900
ADMIN_REFRESH_TOKEN_MAX_AGE_SECONDS=1209600

# --- Internal API secret ---------------------------------------------------
INTERNAL_API_SECRET=test-internal-secret

# --- API server (used only if a test boots the full router) ----------------
API_PORT=6655
API_PREFIX=/api/v1/web-service
