# syntax=docker/dockerfile:1.4
# Test runner image. The cargo registry/git stays in BuildKit cache mounts
# instead of image layers — a layer carrying thousands of small registry
# files races with the containerd snapshotter's tmpmount GC during export
# ("failed to export layer / lstat ... no such file"). Test binaries are
# packed into a self-contained nextest archive at build time, so the test
# stage runs from the archive without needing the registry at run time.
FROM rust:1-bookworm

RUN apt-get update \
 && apt-get install -y --no-install-recommends postgresql-client \
 && rm -rf /var/lib/apt/lists/*

# cargo-nextest provides JUnit XML output for the orchestrator's `junit`
# post-step. The bin lands in /usr/local/cargo/bin (image layer); the
# downloaded crates that compile it stay in the cache mount.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo install --locked cargo-nextest \
 && cargo-nextest --version

WORKDIR /work
COPY . .

# Pre-compile every test target and pack them into one archive. The archive
# carries the binaries plus the metadata nextest needs to dispatch them, so
# the test stage invokes `cargo nextest run --archive-file` and never has to
# touch the cargo registry.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo nextest archive --locked --archive-file /work/tests.tar.zst
